#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_DIR=$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/dev-environment-paths.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/dev-environment-common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/kube.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/terraform.sh"
# shellcheck disable=SC2034
SCRIPT_NAME="dev"
TF_DIR="${TF_DIR_DEFAULT}"

usage() {
  cat <<EOF
Usage:
  ./scripts/dev <command> [args]

Commands:
  up [terraform args]         Apply the dev environment and run post-apply setup
  down [terraform args]       Tear down the dev environment
  measure [measure args]      Run the dynamic GPU serving measurement flow
  doctor                      Check local prerequisites and cluster readiness
  status                      Print a compact cluster status snapshot
  help                        Show this help

Examples:
  ./scripts/dev up -auto-approve
  ./scripts/dev measure --report docs/reports/latest.md
  ./scripts/dev down -auto-approve
  ./scripts/dev doctor
  ./scripts/dev status
EOF
}

doctor_check_command() {
  local command_name=$1

  if command -v "${command_name}" >/dev/null 2>&1; then
    log_success "found command: ${command_name}"
    return 0
  fi

  log_error "missing command: ${command_name}"
  return 1
}

doctor_check_resource() {
  local description=$1
  shift

  if "$@"; then
    log_success "${description}"
    return 0
  fi

  log_warn "${description}"
  return 1
}

run_doctor() {
  local exit_code=0
  local cluster_name
  local aws_region
  local current_context

  log_section "checking local prerequisites"
  require_directory "${TF_DIR}" "Terraform directory"

  for command_name in terraform aws kubectl helm; do
    if ! doctor_check_command "${command_name}"; then
      exit_code=1
    fi
  done

  if (( exit_code != 0 )); then
    return "${exit_code}"
  fi

  log_section "checking Terraform context"
  cluster_name=$(terraform_output_optional "${TF_DIR}" cluster_name)
  aws_region=$(terraform_output_optional "${TF_DIR}" aws_region)

  if [[ -n "${cluster_name}" ]]; then
    log_success "Terraform output cluster_name=${cluster_name}"
  else
    log_warn "Terraform output cluster_name is unavailable"
    exit_code=1
  fi

  if [[ -n "${aws_region}" ]]; then
    log_success "Terraform output aws_region=${aws_region}"
  else
    log_warn "Terraform output aws_region is unavailable"
    exit_code=1
  fi

  log_section "checking Kubernetes access"
  if verify_cluster_connectivity; then
    current_context=$(kubectl config current-context 2>/dev/null || printf 'unknown')
    log_success "kubectl can reach the current cluster via context: ${current_context}"
  else
    current_context=$(kubectl config current-context 2>/dev/null || printf 'unknown')
    log_error "kubectl cannot reach a cluster via context: ${current_context}"
    return 1
  fi

  if ! doctor_check_resource "metrics-server deployment is present" resource_exists deployment "${METRICS_SERVER_DEPLOYMENT_NAME}" kube-system; then
    exit_code=1
  fi
  if ! doctor_check_resource "karpenter namespace is present" namespace_exists "${KARPENTER_NAMESPACE}"; then
    exit_code=1
  fi
  if ! doctor_check_resource "karpenter deployment is present" resource_exists deployment "${KARPENTER_RELEASE_NAME}" "${KARPENTER_NAMESPACE}"; then
    exit_code=1
  fi
  if ! doctor_check_resource "Karpenter NodePool CRD is present" crd_exists nodepools.karpenter.sh; then
    exit_code=1
  fi
  if ! doctor_check_resource "Karpenter NodeClaim CRD is present" crd_exists nodeclaims.karpenter.sh; then
    exit_code=1
  fi
  if ! doctor_check_resource "Karpenter EC2NodeClass CRD is present" crd_exists ec2nodeclasses.karpenter.k8s.aws; then
    exit_code=1
  fi
  if ! doctor_check_resource "GPU NodePool is present" resource_exists nodepool "${KARPENTER_NODEPOOL_NAME}"; then
    exit_code=1
  fi
  if ! doctor_check_resource "GPU EC2NodeClass is present" resource_exists ec2nodeclass "${KARPENTER_NODECLASS_NAME}"; then
    exit_code=1
  fi
  if ! doctor_check_resource "NVIDIA device plugin is present" resource_exists daemonset "${NVIDIA_DEVICE_PLUGIN_DAEMONSET_NAME}" kube-system; then
    exit_code=1
  fi

  return "${exit_code}"
}

run_status() {
  require_command kubectl

  if ! verify_cluster_connectivity; then
    log_error "kubectl cannot reach the current cluster"
    return 1
  fi

  log_section "cluster"
  kubectl config current-context
  kubectl get nodes -L workload,node.kubernetes.io/instance-type -o wide

  log_section "platform"
  kubectl get deployment "${METRICS_SERVER_DEPLOYMENT_NAME}" -n kube-system || true
  kubectl get deployment "${KARPENTER_RELEASE_NAME}" -n "${KARPENTER_NAMESPACE}" || true
  kubectl get nodepools || true
  kubectl get ec2nodeclasses || true
  kubectl get daemonset "${NVIDIA_DEVICE_PLUGIN_DAEMONSET_NAME}" -n kube-system || true

  log_section "app"
  kubectl get ingress -n "${APP_NAMESPACE}" || true
  kubectl get deployment -n "${APP_NAMESPACE}" || true
  kubectl get hpa -n "${APP_NAMESPACE}" || true
}

main() {
  local command=${1:-help}

  case "${command}" in
    up)
      shift
      exec "${SCRIPT_DIR}/apply-dev.sh" "$@"
      ;;
    down)
      shift
      exec "${SCRIPT_DIR}/destroy-dev.sh" "$@"
      ;;
    measure)
      shift
      exec "${SCRIPT_DIR}/measure-gpu-serving-path.sh" "$@"
      ;;
    doctor)
      shift
      run_doctor "$@"
      ;;
    status)
      shift
      run_status "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      log_error "unknown command: ${command}"
      usage >&2
      return 1
      ;;
  esac
}

main "$@"
