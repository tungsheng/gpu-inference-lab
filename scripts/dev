#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_DIR=$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/dev-environment-paths.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/dev-environment-common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/kube.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/json.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/terraform.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/dev-state.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/dev-render.sh"
# shellcheck disable=SC2034
SCRIPT_NAME="dev"
TF_DIR="${TF_DIR:-${TF_DIR_DEFAULT}}"

usage() {
  cat <<EOF
Usage:
  ./scripts/dev <command> [args]

Commands:
  up [terraform args]         Apply the dev environment and run post-apply setup
  down [terraform args]       Tear down the dev environment
  measure [measure args]      Run the dynamic GPU serving measurement flow
  doctor [--json]             Check local prerequisites and cluster readiness
  status [--verbose|--json]   Print a compact cluster status snapshot
  help                        Show this help

Examples:
  ./scripts/dev up -auto-approve
  ./scripts/dev measure --report docs/reports/latest.md --json-report docs/reports/latest.json
  ./scripts/dev down -auto-approve
  ./scripts/dev doctor
  ./scripts/dev doctor --json
  ./scripts/dev status
  ./scripts/dev status --verbose
  ./scripts/dev status --json
EOF
}

doctor_usage() {
  cat <<EOF
Usage:
  ./scripts/dev doctor [--json]

Options:
  --json     Emit a machine-readable readiness report
  -h, --help Show this help
EOF
}

status_usage() {
  cat <<EOF
Usage:
  ./scripts/dev status [--verbose|--json]

Options:
  --verbose  Include the detailed kubectl tables used for troubleshooting
  --json     Emit a machine-readable cluster snapshot
  -h, --help Show this help
EOF
}

run_doctor() {
  local output_mode=text

  while (($# > 0)); do
    case "$1" in
      --json)
        output_mode=json
        ;;
      help|-h|--help)
        doctor_usage
        return 0
        ;;
      *)
        log_error "unknown doctor option: $1"
        doctor_usage >&2
        return 1
        ;;
    esac
    shift
  done

  collect_doctor_state

  if [[ "${output_mode}" == "json" ]]; then
    render_doctor_json
  else
    render_doctor_text
  fi

  [[ "${DOCTOR_READY}" == "1" ]]
}

run_status() {
  local output_mode=text
  local verbose_mode=0

  while (($# > 0)); do
    case "$1" in
      --json)
        output_mode=json
        ;;
      --verbose)
        verbose_mode=1
        ;;
      help|-h|--help)
        status_usage
        return 0
        ;;
      *)
        log_error "unknown status option: $1"
        status_usage >&2
        return 1
        ;;
    esac
    shift
  done

  if [[ "${output_mode}" == "json" && "${verbose_mode}" == "1" ]]; then
    log_error "status accepts either --json or --verbose, not both"
    return 1
  fi

  collect_status_state

  if [[ "${output_mode}" == "json" ]]; then
    render_status_json
  else
    render_status_text "${verbose_mode}"
  fi

  [[ "${STATUS_OK}" == "1" ]]
}

main() {
  local command=${1:-help}

  case "${command}" in
    up)
      shift
      exec "${SCRIPT_DIR}/apply-dev.sh" "$@"
      ;;
    down)
      shift
      exec "${SCRIPT_DIR}/destroy-dev.sh" "$@"
      ;;
    measure)
      shift
      exec "${SCRIPT_DIR}/measure-gpu-serving-path.sh" "$@"
      ;;
    doctor)
      shift
      run_doctor "$@"
      ;;
    status)
      shift
      run_status "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      log_error "unknown command: ${command}"
      usage >&2
      return 1
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
