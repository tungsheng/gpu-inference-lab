#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_DIR=$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/_common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/destroy-recovery.sh"

TOTAL_STAGES=8
CLEANUP_ORPHAN_NETWORK_DEPENDENCIES=0
ORPHAN_ENI_DELETE_COUNT=0
ORPHAN_SECURITY_GROUP_DELETE_COUNT=0
TERRAFORM_ONLY=0
DESTROY_ARGS=()

usage() {
  cat <<EOF
Usage:
  ./scripts/down [--cleanup-orphan-enis|--cleanup-orphan-network-dependencies] [--terraform-only|--skip-kubernetes-cleanup] [terraform destroy args]

Examples:
  ./scripts/down
  ./scripts/down -auto-approve
  ./scripts/down --cleanup-orphan-enis -auto-approve
  ./scripts/down --cleanup-orphan-network-dependencies -auto-approve
  ./scripts/down --terraform-only -auto-approve
EOF
}

check_down_prereqs() {
  require_commands terraform

  if [[ "${TERRAFORM_ONLY}" != "1" ]]; then
    require_commands aws helm kubectl
  fi
}

run_terraform_init() {
  terraform -chdir="${TF_DIR}" init -input=false
}

resolve_destroy_command() {
  command_string terraform "-chdir=${TF_DIR}" destroy "$@"
}

parse_args() {
  DESTROY_ARGS=()

  while (($# > 0)); do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      --cleanup-orphan-enis|--cleanup-orphan-network-dependencies)
        CLEANUP_ORPHAN_NETWORK_DEPENDENCIES=1
        ;;
      --terraform-only|--skip-kubernetes-cleanup)
        TERRAFORM_ONLY=1
        ;;
      --)
        shift
        DESTROY_ARGS+=("$@")
        break
        ;;
      *)
        DESTROY_ARGS+=("$1")
        ;;
    esac
    shift
  done
}

prepare_cluster_connection() {
  try_load_cluster_context && update_kubeconfig && kubectl cluster-info >/dev/null
}

teardown_runtime_surface() {
  local ingress_hostname
  local -a ingress_alb_hostnames=()

  ingress_hostname=$(kubectl get ingress "${GPU_INFERENCE_INGRESS_NAME}" \
    -n "${APP_NAMESPACE}" \
    -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null || true)

  if [[ -n "${ingress_hostname}" ]]; then
    ingress_alb_hostnames+=("${ingress_hostname}")
  else
    while IFS= read -r ingress_hostname; do
      if [[ -n "${ingress_hostname}" ]]; then
        ingress_alb_hostnames+=("${ingress_hostname}")
      fi
    done < <(discover_inference_alb_hostnames)
  fi

  kubectl delete -f "${GPU_LOAD_TEST_MANIFEST}" --ignore-not-found=true || return 1
  wait_for_resource_deletion job "${GPU_LOAD_TEST_JOB_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  kubectl delete -f "${GPU_WARM_PLACEHOLDER_MANIFEST}" --ignore-not-found=true || return 1
  wait_for_resource_deletion deployment "${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  kubectl delete -f "${GPU_INFERENCE_HPA_MANIFEST}" --ignore-not-found=true || return 1
  wait_for_resource_deletion hpa "${GPU_INFERENCE_HPA_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  kubectl delete -f "${GPU_INFERENCE_INGRESS_MANIFEST}" --ignore-not-found=true || return 1
  wait_for_resource_deletion ingress "${GPU_INFERENCE_INGRESS_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  if ((${#ingress_alb_hostnames[@]} > 0)); then
    wait_for_alb_deletions "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" "${ingress_alb_hostnames[@]}" || return 1
  else
    wait_for_alb_deletions "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  fi
  kubectl delete -f "${GPU_INFERENCE_SERVICE_MANIFEST}" --ignore-not-found=true || return 1
  wait_for_resource_deletion service "${GPU_INFERENCE_SERVICE_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  kubectl delete -f "${GPU_INFERENCE_DEPLOYMENT_MANIFEST}" --ignore-not-found=true || return 1
  wait_for_resource_deletion deployment "${GPU_INFERENCE_DEPLOYMENT_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}"
}

wait_for_gpu_capacity_drained() {
  if crd_exists nodeclaims.karpenter.sh; then
    wait_for_nodeclaims_at_most 0 "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  else
    printf 'Karpenter NodeClaim CRD is not installed; skipping NodeClaim drain wait.\n'
  fi

  wait_for_all_gpu_nodes_at_most 0 "${VERIFY_CLEANUP_TIMEOUT_SECONDS}"
}

delete_gpu_capacity() {
  if crd_exists nodepools.karpenter.sh; then
    kubectl delete -f "${KARPENTER_WARM_NODEPOOL_MANIFEST}" --ignore-not-found=true || return 1
    wait_for_resource_deletion nodepool "${KARPENTER_WARM_NODEPOOL_NAME}" "" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
    kubectl delete -f "${KARPENTER_SPOT_NODEPOOL_MANIFEST}" --ignore-not-found=true || return 1
    wait_for_resource_deletion nodepool "${KARPENTER_SPOT_NODEPOOL_NAME}" "" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
    kubectl delete -f "${KARPENTER_ONDEMAND_NODEPOOL_MANIFEST}" --ignore-not-found=true || return 1
    wait_for_resource_deletion nodepool "${KARPENTER_ONDEMAND_NODEPOOL_NAME}" "" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
    kubectl delete "nodepool/${KARPENTER_LEGACY_NODEPOOL_NAME}" --ignore-not-found=true || return 1
    wait_for_resource_deletion nodepool "${KARPENTER_LEGACY_NODEPOOL_NAME}" "" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  else
    printf 'Karpenter NodePool CRD is not installed; skipping NodePool deletion.\n'
  fi

  if crd_exists ec2nodeclasses.karpenter.k8s.aws; then
    kubectl delete -f "${KARPENTER_NODECLASS_MANIFEST}" --ignore-not-found=true || return 1
    wait_for_resource_deletion ec2nodeclass "${KARPENTER_NODECLASS_NAME}" "" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}"
  else
    printf 'Karpenter EC2NodeClass CRD is not installed; skipping EC2NodeClass deletion.\n'
  fi

  wait_for_gpu_capacity_drained
}

uninstall_karpenter_and_gpu_plugin() {
  if helm status "${KARPENTER_RELEASE_NAME}" -n "${KARPENTER_NAMESPACE}" >/dev/null 2>&1; then
    helm uninstall "${KARPENTER_RELEASE_NAME}" -n "${KARPENTER_NAMESPACE}" --wait || return 1
  fi
  if helm status "${KARPENTER_CRD_RELEASE_NAME}" -n "${KARPENTER_NAMESPACE}" >/dev/null 2>&1; then
    helm uninstall "${KARPENTER_CRD_RELEASE_NAME}" -n "${KARPENTER_NAMESPACE}" --wait || return 1
  fi
  kubectl delete -f "${KARPENTER_SERVICE_ACCOUNT_MANIFEST}" --ignore-not-found=true || return 1
  kubectl delete -f "${NVIDIA_DEVICE_PLUGIN_MANIFEST}" --ignore-not-found=true || return 1
  wait_for_resource_deletion daemonset nvidia-device-plugin-daemonset kube-system "${VERIFY_CLEANUP_TIMEOUT_SECONDS}"
}

run_terraform_destroy() {
  terraform -chdir="${TF_DIR}" destroy "$@"
}

skip_stage() {
  local number=$1
  local label=$2

  print_stage_banner "${number}" "${TOTAL_STAGES}" "${label}"
  print_stage_result "SKIP" "${number}" "${TOTAL_STAGES}" "${label}"
}

main() {
  local status
  local diagnostics_printed=0
  local cleanup_status=0

  parse_args "$@"

  if [[ "${TERRAFORM_ONLY}" == "1" ]]; then
    set_failure_hints \
      "command -v terraform" \
      "terraform -chdir=${TF_DIR} version"
  else
    set_failure_hints \
      "command -v terraform aws kubectl helm" \
      "terraform -chdir=${TF_DIR} version" \
      "kubectl version --client"
  fi
  run_stage 1 "${TOTAL_STAGES}" "checking prerequisites" check_down_prereqs

  set_failure_hints \
    "terraform -chdir=${TF_DIR} init -input=false" \
    "terraform -chdir=${TF_DIR} providers" \
    "terraform -chdir=${TF_DIR} validate"
  run_stage 2 "${TOTAL_STAGES}" "terraform init" run_terraform_init

  if [[ "${TERRAFORM_ONLY}" == "1" ]]; then
    skip_stage 3 "connect cluster context"
    skip_stage 4 "remove inference and load artifacts"
    skip_stage 5 "delete gpu capacity definitions"
    skip_stage 6 "remove observability stack"
    skip_stage 7 "uninstall karpenter and nvidia device plugin"
  else
    print_stage_banner 3 "${TOTAL_STAGES}" "connect cluster context"
    if ! prepare_cluster_connection; then
      set_failure_hints \
        "$(resolve_destroy_command "${DESTROY_ARGS[@]}")" \
        "terraform -chdir=${TF_DIR} output" \
        "aws eks update-kubeconfig --name gpu-inference --region us-west-2"
      print_stage_result "FAIL" 3 "${TOTAL_STAGES}" "connect cluster context"
      print_failure_hints
      exit 1
    fi
    print_stage_result "OK" 3 "${TOTAL_STAGES}" "connect cluster context"

    set_failure_hints \
      "kubectl get ingress,service,deployment,hpa,job -n ${APP_NAMESPACE}" \
      "kubectl get events -n ${APP_NAMESPACE} --sort-by=.lastTimestamp | tail -n 40" \
      "aws elbv2 describe-load-balancers --region ${AWS_REGION}"
    run_stage 4 "${TOTAL_STAGES}" "remove inference and load artifacts" teardown_runtime_surface

    set_failure_hints \
      "kubectl get nodepool,nodeclaim" \
      "kubectl get ec2nodeclass ${KARPENTER_NODECLASS_NAME} -o yaml" \
      "kubectl get nodes -L workload,node.kubernetes.io/instance-type"
    run_stage 5 "${TOTAL_STAGES}" "delete gpu capacity definitions" delete_gpu_capacity

    set_failure_hints \
      "helm list -n ${MONITORING_NAMESPACE}" \
      "kubectl get apiservice ${PROMETHEUS_ADAPTER_APISERVICE_NAME}" \
      "kubectl get all -n ${MONITORING_NAMESPACE}"
    run_stage 6 "${TOTAL_STAGES}" "remove observability stack" uninstall_observability_stack

    set_failure_hints \
      "helm list -n ${KARPENTER_NAMESPACE}" \
      "kubectl get namespaces" \
      "kubectl get daemonset -n kube-system nvidia-device-plugin-daemonset -o yaml"
    run_stage 7 "${TOTAL_STAGES}" "uninstall karpenter and nvidia device plugin" uninstall_karpenter_and_gpu_plugin
  fi

  if [[ "${TERRAFORM_ONLY}" == "1" ]]; then
    set_failure_hints \
      "terraform -chdir=${TF_DIR} state list" \
      "terraform -chdir=${TF_DIR} plan -destroy" \
      "terraform -chdir=${TF_DIR} output"
  else
    set_failure_hints \
      "terraform -chdir=${TF_DIR} state list" \
      "terraform -chdir=${TF_DIR} plan -destroy" \
      "terraform -chdir=${TF_DIR} output" \
      "aws ec2 describe-network-interfaces --region ${AWS_REGION} --filters Name=vpc-id,Values=${VPC_ID} Name=status,Values=available" \
      "aws ec2 describe-security-groups --region ${AWS_REGION} --filters Name=vpc-id,Values=${VPC_ID}"
  fi

  print_stage_banner 8 "${TOTAL_STAGES}" "terraform destroy"
  set +e
  run_terraform_destroy "${DESTROY_ARGS[@]}"
  status=$?
  set -e

  if [[ "${status}" != "0" && "${CLEANUP_ORPHAN_NETWORK_DEPENDENCIES}" == "1" && "${TERRAFORM_ONLY}" != "1" ]]; then
    printf 'terraform destroy failed; checking for cleanup-eligible orphan network dependencies.\n'
    print_destroy_dependency_diagnostics
    diagnostics_printed=1

    cleanup_status=0
    cleanup_orphan_enis || cleanup_status=1
    cleanup_orphan_security_groups || cleanup_status=1

    if (( ORPHAN_ENI_DELETE_COUNT > 0 || ORPHAN_SECURITY_GROUP_DELETE_COUNT > 0 )); then
      printf 'Retrying terraform destroy after orphan network dependency cleanup...\n'
      set +e
      run_terraform_destroy "${DESTROY_ARGS[@]}"
      status=$?
      set -e
    elif (( cleanup_status > 0 )); then
      printf 'No cleanup-eligible orphan network dependencies were removed; not retrying terraform destroy.\n'
    fi
  fi

  if [[ "${status}" != "0" ]]; then
    print_stage_result "FAIL" 8 "${TOTAL_STAGES}" "terraform destroy"
    print_failure_hints
    if [[ "${diagnostics_printed}" == "0" ]]; then
      print_destroy_dependency_diagnostics
    fi
    exit "${status}"
  fi
  print_stage_result "OK" 8 "${TOTAL_STAGES}" "terraform destroy"

  printf '\nRemoved:\n'
  printf '  Environment destroyed for %s\n' "${TF_DIR}"
}

main "$@"
