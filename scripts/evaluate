usage() {
  cat <<EOF
Usage:
  ./scripts/evaluate [--profile zero-idle|warm-1] [--policy running|active-pressure|compare|sweep] [--resilience healthy|spot-unavailable|spot-interruption] [--active-target requests] [--active-targets csv] [--report path] [--json-report path]

Examples:
  ./scripts/evaluate --profile zero-idle
  ./scripts/evaluate --profile warm-1
  ./scripts/evaluate --profile zero-idle --policy active-pressure
  ./scripts/evaluate --profile zero-idle --resilience spot-unavailable
  ./scripts/evaluate --profile zero-idle --resilience spot-interruption
  ./scripts/evaluate --profile warm-1 --policy compare --active-target 6
  ./scripts/evaluate --profile zero-idle --policy sweep --active-targets 2,4,6,8
  ./scripts/evaluate --profile zero-idle --report docs/reports/latest.md
EOF
}

require_option_value() {
  local option_name=$1
  local option_value=${2-}

  if [[ -z "${option_value}" || "${option_value}" == -* ]]; then
    printf '%s requires a value\n' "${option_name}" >&2
    usage >&2
    exit 1
  fi

  printf '%s\n' "${option_value}"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile)
        EVALUATION_PROFILE=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --policy)
        EVALUATION_POLICY=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --resilience)
        EVALUATION_RESILIENCE=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --active-target)
        ACTIVE_PRESSURE_TARGET=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --active-targets)
        ACTIVE_TARGETS_INPUT=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --report)
        USER_REPORT_PATH=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --json-report)
        USER_JSON_REPORT_PATH=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        printf 'Unexpected argument: %s\n' "$1" >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  case "${EVALUATION_PROFILE}" in
    zero-idle|warm-1)
      ;;
    *)
      printf 'Unsupported profile: %s\n' "${EVALUATION_PROFILE}" >&2
      printf 'Supported profiles: zero-idle, warm-1\n' >&2
      exit 1
      ;;
  esac

  case "${EVALUATION_POLICY}" in
    running|active-pressure|compare|sweep)
      ;;
    *)
      printf 'Unsupported policy: %s\n' "${EVALUATION_POLICY}" >&2
      printf 'Supported policies: running, active-pressure, compare, sweep\n' >&2
      exit 1
      ;;
  esac

  case "${EVALUATION_RESILIENCE}" in
    healthy|spot-unavailable|spot-interruption)
      ;;
    *)
      printf 'Unsupported resilience mode: %s\n' "${EVALUATION_RESILIENCE}" >&2
      printf 'Supported resilience modes: healthy, spot-unavailable, spot-interruption\n' >&2
      exit 1
      ;;
  esac

  if [[ ! "${ACTIVE_PRESSURE_TARGET}" =~ ^[1-9][0-9]*$ ]]; then
    printf 'Unsupported active target: %s\n' "${ACTIVE_PRESSURE_TARGET}" >&2
    printf 'Expected a positive integer for --active-target\n' >&2
    exit 1
  fi

  parse_active_targets_input

  if [[ "${EVALUATION_POLICY}" == "sweep" ]]; then
    if [[ -z "${ACTIVE_TARGETS_INPUT}" ]]; then
      printf 'The sweep workflow requires --active-targets with at least two values\n' >&2
      exit 1
    fi

    if ((${#ACTIVE_TARGET_SWEEP_VALUES[@]} < 2)); then
      printf 'The sweep workflow requires at least two distinct active-target values\n' >&2
      exit 1
    fi
  elif [[ -n "${ACTIVE_TARGETS_INPUT}" ]]; then
    printf '--active-targets is only supported with --policy sweep\n' >&2
    exit 1
  fi

  EVALUATION_TIMESTAMP=$(date +%Y%m%d-%H%M%S)
}

parse_active_targets_input() {
  local -a raw_targets=()
  local raw_target
  local normalized_target
  local existing_target
  local duplicate_found

  ACTIVE_TARGET_SWEEP_VALUES=()

  if [[ -z "${ACTIVE_TARGETS_INPUT}" ]]; then
    return 0
  fi

  IFS=',' read -r -a raw_targets <<< "${ACTIVE_TARGETS_INPUT}"

  for raw_target in "${raw_targets[@]}"; do
    normalized_target=$(printf '%s' "${raw_target}" | tr -d '[:space:]')

    if [[ ! "${normalized_target}" =~ ^[1-9][0-9]*$ ]]; then
      printf 'Unsupported sweep target: %s\n' "${raw_target}" >&2
      printf 'Expected --active-targets as a comma-separated list of positive integers\n' >&2
      exit 1
    fi

    duplicate_found=0
    if ((${#ACTIVE_TARGET_SWEEP_VALUES[@]} > 0)); then
      for existing_target in "${ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
        if [[ "${existing_target}" == "${normalized_target}" ]]; then
          duplicate_found=1
          break
        fi
      done
    fi

    if [[ "${duplicate_found}" == "0" ]]; then
      ACTIVE_TARGET_SWEEP_VALUES+=("${normalized_target}")
    fi
  done
}

strip_report_extension() {
  local path=$1

  case "${path}" in
    *.md)
      printf '%s\n' "${path%.md}"
      ;;
    *.json)
      printf '%s\n' "${path%.json}"
      ;;
    *)
      printf '%s\n' "${path}"
      ;;
  esac
}

resilience_report_suffix() {
  if [[ "${EVALUATION_RESILIENCE}" == "healthy" ]]; then
    printf '%s' ""
    return 0
  fi

  printf -- '-%s' "${EVALUATION_RESILIENCE}"
}

default_report_stem() {
  local report_key=$1

  printf '%s/docs/reports/evaluate-%s%s-%s-%s\n' \
    "${REPO_ROOT}" \
    "${EVALUATION_PROFILE}" \
    "$(resilience_report_suffix)" \
    "${report_key}" \
    "${EVALUATION_TIMESTAMP}"
}

user_report_stem() {
  local preferred_path=$1
  local default_report_key=$2

  if [[ -n "${preferred_path}" ]]; then
    strip_report_extension "${preferred_path}"
    return 0
  fi

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    strip_report_extension "${USER_REPORT_PATH}"
    return 0
  fi

  default_report_stem "${default_report_key}"
}

resolve_report_path_for_key() {
  local report_key=$1
  local stem

  if is_multi_run_mode; then
    stem=$(user_report_stem "${USER_REPORT_PATH}" "${report_key}")
    printf '%s-%s.md\n' "${stem}" "${report_key}"
    return 0
  fi

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    printf '%s\n' "${USER_REPORT_PATH}"
    return 0
  fi

  printf '%s.md\n' "$(default_report_stem "${report_key}")"
}

resolve_json_report_path_for_key() {
  local report_key=$1
  local stem

  if is_multi_run_mode; then
    stem=$(user_report_stem "${USER_JSON_REPORT_PATH:-${USER_REPORT_PATH}}" "${report_key}")
    printf '%s-%s.json\n' "${stem}" "${report_key}"
    return 0
  fi

  if [[ -n "${USER_JSON_REPORT_PATH}" ]]; then
    printf '%s\n' "${USER_JSON_REPORT_PATH}"
    return 0
  fi

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    printf '%s.json\n' "$(strip_report_extension "${USER_REPORT_PATH}")"
    return 0
  fi

  printf '%s.json\n' "$(default_report_stem "${report_key}")"
}

cleanup_evaluate() {
  local temporary_file

  if [[ -n "${PROMETHEUS_PORT_FORWARD_PID}" ]]; then
    kill "${PROMETHEUS_PORT_FORWARD_PID}" 2>/dev/null || true
    wait "${PROMETHEUS_PORT_FORWARD_PID}" 2>/dev/null || true
    rm -f "${PROMETHEUS_PORT_FORWARD_LOG}" 2>/dev/null || true
  fi

  if [[ -n "${PUSHGATEWAY_PORT_FORWARD_PID}" ]]; then
    kill "${PUSHGATEWAY_PORT_FORWARD_PID}" 2>/dev/null || true
    wait "${PUSHGATEWAY_PORT_FORWARD_PID}" 2>/dev/null || true
    rm -f "${PUSHGATEWAY_PORT_FORWARD_LOG}" 2>/dev/null || true
  fi

  stop_metric_seed_requests || true

  if [[ "${LOAD_TEST_APPLIED}" == "1" ]]; then
    kubectl delete -f "${GPU_LOAD_TEST_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi
  if [[ "${HPA_APPLIED}" == "1" ]]; then
    kubectl delete hpa "${GPU_INFERENCE_HPA_NAME}" -n "${APP_NAMESPACE}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi
  if [[ "${DEPLOYMENT_APPLIED}" == "1" ]]; then
    kubectl delete -f "${GPU_INFERENCE_DEPLOYMENT_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi
  if [[ "${WARM_PLACEHOLDER_APPLIED}" == "1" && "${PRESERVE_WARM_PROFILE_DEBUG_ARTIFACTS}" != "1" ]]; then
    kubectl delete -f "${GPU_WARM_PLACEHOLDER_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi
  if [[ "${SPOT_NODEPOOL_DISABLED}" == "1" ]]; then
    kubectl apply -f "${KARPENTER_SPOT_NODEPOOL_MANIFEST}" >/dev/null 2>&1 || true
    SPOT_NODEPOOL_DISABLED=0
  fi
  if [[ "${ONDEMAND_NODEPOOL_DISABLED}" == "1" ]]; then
    kubectl apply -f "${KARPENTER_ONDEMAND_NODEPOOL_MANIFEST}" >/dev/null 2>&1 || true
    ONDEMAND_NODEPOOL_DISABLED=0
  fi

  if ((${#TEMP_FILES[@]} > 0)); then
    for temporary_file in "${TEMP_FILES[@]}"; do
      rm -f "${temporary_file}" >/dev/null 2>&1 || true
    done
  fi
}

