usage() {
  cat <<EOF
Usage:
  ./scripts/evaluate [--profile zero-idle|warm-1] [--policy running|active-pressure|compare] [--active-target requests] [--report path] [--json-report path]

Examples:
  ./scripts/evaluate --profile zero-idle
  ./scripts/evaluate --profile warm-1
  ./scripts/evaluate --profile zero-idle --policy active-pressure
  ./scripts/evaluate --profile warm-1 --policy compare --active-target 6
  ./scripts/evaluate --profile zero-idle --report docs/reports/latest.md
EOF
}

require_option_value() {
  local option_name=$1
  local option_value=${2-}

  if [[ -z "${option_value}" || "${option_value}" == -* ]]; then
    printf '%s requires a value\n' "${option_name}" >&2
    usage >&2
    exit 1
  fi

  printf '%s\n' "${option_value}"
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile)
        EVALUATION_PROFILE=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --policy)
        EVALUATION_POLICY=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --active-target)
        ACTIVE_PRESSURE_TARGET=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --report)
        USER_REPORT_PATH=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --json-report)
        USER_JSON_REPORT_PATH=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        printf 'Unexpected argument: %s\n' "$1" >&2
        usage >&2
        exit 1
        ;;
    esac
  done

  case "${EVALUATION_PROFILE}" in
    zero-idle|warm-1)
      ;;
    *)
      printf 'Unsupported profile: %s\n' "${EVALUATION_PROFILE}" >&2
      printf 'Supported profiles: zero-idle, warm-1\n' >&2
      exit 1
      ;;
  esac

  case "${EVALUATION_POLICY}" in
    running|active-pressure|compare)
      ;;
    *)
      printf 'Unsupported policy: %s\n' "${EVALUATION_POLICY}" >&2
      printf 'Supported policies: running, active-pressure, compare\n' >&2
      exit 1
      ;;
  esac

  if [[ ! "${ACTIVE_PRESSURE_TARGET}" =~ ^[1-9][0-9]*$ ]]; then
    printf 'Unsupported active target: %s\n' "${ACTIVE_PRESSURE_TARGET}" >&2
    printf 'Expected a positive integer for --active-target\n' >&2
    exit 1
  fi

  EVALUATION_TIMESTAMP=$(date +%Y%m%d-%H%M%S)
}

strip_report_extension() {
  local path=$1

  case "${path}" in
    *.md)
      printf '%s\n' "${path%.md}"
      ;;
    *.json)
      printf '%s\n' "${path%.json}"
      ;;
    *)
      printf '%s\n' "${path}"
      ;;
  esac
}

compare_policy_name() {
  local policy=$1

  case "${policy}" in
    running|active-pressure)
      printf '%s\n' "${policy}"
      ;;
    *)
      printf 'compare\n'
      ;;
  esac
}

default_report_stem() {
  local policy=$1

  printf '%s/docs/reports/evaluate-%s-%s-%s\n' \
    "${REPO_ROOT}" \
    "${EVALUATION_PROFILE}" \
    "$(compare_policy_name "${policy}")" \
    "${EVALUATION_TIMESTAMP}"
}

user_report_stem() {
  local preferred_path=$1
  local default_policy=$2

  if [[ -n "${preferred_path}" ]]; then
    strip_report_extension "${preferred_path}"
    return 0
  fi

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    strip_report_extension "${USER_REPORT_PATH}"
    return 0
  fi

  default_report_stem "${default_policy}"
}

resolve_report_path_for_policy() {
  local policy=$1
  local stem

  if [[ "${EVALUATION_POLICY}" == "compare" ]]; then
    stem=$(user_report_stem "${USER_REPORT_PATH}" "${policy}")
    printf '%s-%s.md\n' "${stem}" "$(compare_policy_name "${policy}")"
    return 0
  fi

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    printf '%s\n' "${USER_REPORT_PATH}"
    return 0
  fi

  printf '%s.md\n' "$(default_report_stem "${policy}")"
}

resolve_json_report_path_for_policy() {
  local policy=$1
  local stem

  if [[ "${EVALUATION_POLICY}" == "compare" ]]; then
    stem=$(user_report_stem "${USER_JSON_REPORT_PATH:-${USER_REPORT_PATH}}" "${policy}")
    printf '%s-%s.json\n' "${stem}" "$(compare_policy_name "${policy}")"
    return 0
  fi

  if [[ -n "${USER_JSON_REPORT_PATH}" ]]; then
    printf '%s\n' "${USER_JSON_REPORT_PATH}"
    return 0
  fi

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    printf '%s.json\n' "$(strip_report_extension "${USER_REPORT_PATH}")"
    return 0
  fi

  printf '%s.json\n' "$(default_report_stem "${policy}")"
}

resolve_compare_report_path() {
  local stem

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    stem=$(strip_report_extension "${USER_REPORT_PATH}")
    printf '%s-compare.md\n' "${stem}"
    return 0
  fi

  printf '%s.md\n' "$(default_report_stem compare)"
}

resolve_compare_json_report_path() {
  local stem

  if [[ -n "${USER_JSON_REPORT_PATH}" ]]; then
    stem=$(strip_report_extension "${USER_JSON_REPORT_PATH}")
    printf '%s-compare.json\n' "${stem}"
    return 0
  fi

  if [[ -n "${USER_REPORT_PATH}" ]]; then
    stem=$(strip_report_extension "${USER_REPORT_PATH}")
    printf '%s-compare.json\n' "${stem}"
    return 0
  fi

  printf '%s.json\n' "$(default_report_stem compare)"
}

cleanup_evaluate() {
  local temporary_file

  if [[ -n "${PROMETHEUS_PORT_FORWARD_PID}" ]]; then
    kill "${PROMETHEUS_PORT_FORWARD_PID}" 2>/dev/null || true
    wait "${PROMETHEUS_PORT_FORWARD_PID}" 2>/dev/null || true
    rm -f "${PROMETHEUS_PORT_FORWARD_LOG}" 2>/dev/null || true
  fi

  if [[ -n "${PUSHGATEWAY_PORT_FORWARD_PID}" ]]; then
    kill "${PUSHGATEWAY_PORT_FORWARD_PID}" 2>/dev/null || true
    wait "${PUSHGATEWAY_PORT_FORWARD_PID}" 2>/dev/null || true
    rm -f "${PUSHGATEWAY_PORT_FORWARD_LOG}" 2>/dev/null || true
  fi

  stop_metric_seed_requests || true

  if [[ "${LOAD_TEST_APPLIED}" == "1" ]]; then
    kubectl delete -f "${GPU_LOAD_TEST_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi
  if [[ "${HPA_APPLIED}" == "1" ]]; then
    kubectl delete hpa "${GPU_INFERENCE_HPA_NAME}" -n "${APP_NAMESPACE}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi
  if [[ "${DEPLOYMENT_APPLIED}" == "1" ]]; then
    kubectl delete -f "${GPU_INFERENCE_DEPLOYMENT_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi
  if [[ "${WARM_PLACEHOLDER_APPLIED}" == "1" && "${PRESERVE_WARM_PROFILE_DEBUG_ARTIFACTS}" != "1" ]]; then
    kubectl delete -f "${GPU_WARM_PLACEHOLDER_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi

  if ((${#TEMP_FILES[@]} > 0)); then
    for temporary_file in "${TEMP_FILES[@]}"; do
      rm -f "${temporary_file}" >/dev/null 2>&1 || true
    done
  fi
}

evaluate_prereqs() {
  require_commands kubectl curl awk
}

is_warm_profile() {
  [[ "${EVALUATION_PROFILE}" == "warm-1" ]]
}

is_compare_mode() {
  [[ "${EVALUATION_POLICY}" == "compare" ]]
}

is_active_pressure_policy() {
  [[ "${CURRENT_POLICY}" == "active-pressure" ]]
}

policy_stage_label() {
  local label=$1

  if [[ "${CURRENT_POLICY}" == "running" && "${EVALUATION_POLICY}" != "compare" ]]; then
    printf '%s\n' "${label}"
    return 0
  fi

  printf '%s: %s\n' "${CURRENT_POLICY}" "${label}"
}

