    },
    "estimated_burst_cost": $(json_nullable_number "${ESTIMATED_BURST_COST}"),
    "estimated_burst_cost_by_capacity_type": {
      "on_demand": $(json_nullable_number "${ESTIMATED_BURST_COST_ONDEMAND}"),
      "spot": $(json_nullable_number "${ESTIMATED_BURST_COST_SPOT}")
    }
  }
}
EOF
}

policy_snapshot_key() {
  local policy=$1
  local policy_key

  policy_key=${policy//-/_}
  printf '%s\n' "${policy_key}" | tr '[:lower:]' '[:upper:]'
}

set_policy_snapshot_value() {
  local policy=$1
  local field=$2
  local value=${3-}
  local variable_name

  variable_name="COMPARE_$(policy_snapshot_key "${policy}")_${field}"
  printf -v "${variable_name}" '%s' "${value}"
}

get_policy_snapshot_value() {
  local policy=$1
  local field=$2
  local variable_name

  variable_name="COMPARE_$(policy_snapshot_key "${policy}")_${field}"
  printf '%s\n' "${!variable_name:-}"
}

capture_compare_policy_result() {
  local policy=$1

  set_policy_snapshot_value "${policy}" REPORT_PATH "${REPORT_PATH}"
  set_policy_snapshot_value "${policy}" JSON_REPORT_PATH "${JSON_REPORT_PATH}"
  set_policy_snapshot_value "${policy}" HPA_METRIC_NAME "${CURRENT_HPA_METRIC_NAME}"
  set_policy_snapshot_value "${policy}" HPA_TARGET_AVERAGE_VALUE "${CURRENT_HPA_TARGET_AVERAGE_VALUE}"
  set_policy_snapshot_value "${policy}" METRICS_COLLECTION_STATUS "${METRICS_COLLECTION_STATUS}"
  set_policy_snapshot_value "${policy}" METRICS_COLLECTION_REASON "${METRICS_COLLECTION_REASON}"
  set_policy_snapshot_value "${policy}" P95_REQUEST_LATENCY_SECONDS "${P95_REQUEST_LATENCY_SECONDS}"
  set_policy_snapshot_value "${policy}" P95_ESTIMATED_QUEUE_WAIT_SECONDS "${P95_ESTIMATED_QUEUE_WAIT_SECONDS}"
  set_policy_snapshot_value "${policy}" P95_TTFT_SECONDS "${P95_TTFT_SECONDS}"
  set_policy_snapshot_value "${policy}" PEAK_WAITING_REQUESTS "${PEAK_WAITING_REQUESTS}"
  set_policy_snapshot_value "${policy}" PEAK_ACTIVE_REQUESTS "${PEAK_ACTIVE_REQUESTS}"
  set_policy_snapshot_value "${policy}" PEAK_ACTIVE_REQUESTS_PER_GPU_NODE "${PEAK_ACTIVE_REQUESTS_PER_GPU_NODE}"
  set_policy_snapshot_value "${policy}" AVG_COMPLETED_REQUESTS_PER_SECOND "${AVG_COMPLETED_REQUESTS_PER_SECOND}"
  set_policy_snapshot_value "${policy}" AVG_GPU_UTILIZATION_PERCENT "${AVG_GPU_UTILIZATION_PERCENT}"
  set_policy_snapshot_value "${policy}" AVG_GPU_HEADROOM_PERCENT "${AVG_GPU_HEADROOM_PERCENT}"
  set_policy_snapshot_value "${policy}" MAX_GPU_UTILIZATION_PERCENT "${MAX_GPU_UTILIZATION_PERCENT}"
