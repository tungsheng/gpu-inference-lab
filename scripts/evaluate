set_policy_context() {
  CURRENT_POLICY=$1
  REPORT_PATH=$(resolve_report_path_for_policy "${CURRENT_POLICY}")
  JSON_REPORT_PATH=$(resolve_json_report_path_for_policy "${CURRENT_POLICY}")

  if is_active_pressure_policy; then
    CURRENT_HPA_METRIC_NAME="vllm_requests_active"
    CURRENT_HPA_TARGET_AVERAGE_VALUE="${ACTIVE_PRESSURE_TARGET}"
  else
    CURRENT_HPA_METRIC_NAME="vllm_requests_running"
    CURRENT_HPA_TARGET_AVERAGE_VALUE="128"
  fi
}

set_if_unset() {
  local variable_name=$1
  local value=$2

  if [[ -z "${!variable_name:-}" ]]; then
    printf -v "${variable_name}" '%s' "${value}"
  fi
}

pod_names() {
  kubectl get pods \
    -n "${APP_NAMESPACE}" \
    -l "app=${GPU_INFERENCE_DEPLOYMENT_NAME}" \
    --sort-by=.metadata.creationTimestamp \
    -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null
}

first_pod_name() {
  pod_names | sed -n '1p'
}

first_gpu_node_name() {
  kubectl get nodes \
    -l 'workload=gpu' \
    --sort-by=.metadata.creationTimestamp \
    -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null | sed -n '1p'
}

second_gpu_node_name() {
  kubectl get nodes \
    -l 'workload=gpu' \
    --sort-by=.metadata.creationTimestamp \
    -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' 2>/dev/null | sed -n '2p'
}

node_instance_type() {
  local node_name=$1

  kubectl get node "${node_name}" \
    -o jsonpath='{.metadata.labels.node\.kubernetes\.io/instance-type}' 2>/dev/null
}

populate_first_gpu_node_identity() {
  FIRST_GPU_NODE_NAME=$(first_gpu_node_name)
  if [[ -z "${FIRST_GPU_NODE_NAME}" ]]; then
    return 0
  fi

  FIRST_GPU_INSTANCE_TYPE=$(node_instance_type "${FIRST_GPU_NODE_NAME}")
  FIRST_GPU_NODEPOOL_NAME=$(node_nodepool "${FIRST_GPU_NODE_NAME}")
  FIRST_GPU_CAPACITY_TYPE=$(node_capacity_type "${FIRST_GPU_NODE_NAME}")
  if [[ -z "${FIRST_GPU_CAPACITY_TYPE}" ]]; then
    FIRST_GPU_CAPACITY_TYPE=$(nodepool_capacity_type "${FIRST_GPU_NODEPOOL_NAME}")
  fi
}

populate_second_gpu_node_identity() {
  SECOND_GPU_NODE_NAME=$(second_gpu_node_name)
  if [[ -z "${SECOND_GPU_NODE_NAME}" ]]; then
    return 0
  fi

  SECOND_GPU_INSTANCE_TYPE=$(node_instance_type "${SECOND_GPU_NODE_NAME}")
  SECOND_GPU_NODEPOOL_NAME=$(node_nodepool "${SECOND_GPU_NODE_NAME}")
  SECOND_GPU_CAPACITY_TYPE=$(node_capacity_type "${SECOND_GPU_NODE_NAME}")
  if [[ -z "${SECOND_GPU_CAPACITY_TYPE}" ]]; then
    SECOND_GPU_CAPACITY_TYPE=$(nodepool_capacity_type "${SECOND_GPU_NODEPOOL_NAME}")
  fi
}

wait_for_first_pod_name() {
  local timeout_seconds=$1
  local start_time

  start_time=$(date +%s)

  while true; do
    local pod_name
    pod_name=$(first_pod_name)
    if [[ -n "${pod_name}" ]]; then
      printf '%s\n' "${pod_name}"
      return 0
    fi

    if (( $(date +%s) - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for the first vLLM pod to appear\n' >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

wait_for_pod_condition_timestamp() {
  local pod_name=$1
  local jsonpath=$2
  local timeout_seconds=$3
  local start_time

  start_time=$(date +%s)

  while true; do
    local timestamp
    timestamp=$(kubectl get pod "${pod_name}" -n "${APP_NAMESPACE}" -o "jsonpath=${jsonpath}" 2>/dev/null || true)

    if [[ -n "${timestamp}" ]]; then
      printf '%s\n' "${timestamp}"
      return 0
    fi

    if (( $(date +%s) - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for pod timestamp: %s\n' "${pod_name}" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

print_warm_profile_failure_diagnostics() {
  {
    printf '\nWarm-profile diagnostics:\n'
    printf '  placeholder deployment: %s/%s\n' "${APP_NAMESPACE}" "${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}"
    printf '  preserved for inspection: yes\n'
    printf '\n'
    kubectl get deployment "${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}" -n "${APP_NAMESPACE}" -o wide 2>/dev/null || true
    kubectl get pods -n "${APP_NAMESPACE}" -l "app=${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}" -o wide 2>/dev/null || true
    kubectl get nodeclaims -o wide 2>/dev/null || true
    kubectl get nodes -l workload=gpu -o wide 2>/dev/null || true
    printf '\nRecent cluster events:\n'
    kubectl get events -A --sort-by=.lastTimestamp 2>/dev/null | tail -n 20 || true
    printf '\nClean up with:\n'
    printf '  kubectl delete -f %s --ignore-not-found=true\n' "${GPU_WARM_PLACEHOLDER_MANIFEST}"
    printf '  ./scripts/down\n'
  } >&2
}

preserve_warm_profile_failure_state() {
  PRESERVE_WARM_PROFILE_DEBUG_ARTIFACTS=1
  print_warm_profile_failure_diagnostics
}

print_serving_nodeclaim_snapshot() {
  local output

  output=$(kubectl get nodeclaims \
    -l "${KARPENTER_SERVING_NODEPOOL_SELECTOR}" \
    -o custom-columns='NAME:.metadata.name,NODEPOOL:.metadata.labels.karpenter\.sh/nodepool,NODE:.status.nodeName' \
    --no-headers 2>/dev/null || true)

  if [[ -z "${output}" ]]; then
    printf 'Current serving NodeClaims: none\n' >&2
    return 0
  fi

  printf 'Current serving NodeClaims (name nodepool node):\n%s\n' "${output}" >&2
}

print_serving_node_snapshot() {
  local output

  output=$(kubectl get nodes \
    -l 'workload=gpu' \
    -L karpenter.sh/nodepool,karpenter.sh/capacity-type,node.kubernetes.io/instance-type \
    --no-headers 2>/dev/null || true)

  if [[ -z "${output}" ]]; then
    printf 'Current serving GPU nodes: none\n' >&2
    return 0
  fi

  printf 'Current serving GPU nodes (name status roles age version nodepool capacity-type instance-type):\n%s\n' "${output}" >&2
}

print_serving_pod_snapshot() {
  local output

  output=$(kubectl get pods \
    -n "${APP_NAMESPACE}" \
    -l "app=${GPU_INFERENCE_DEPLOYMENT_NAME}" \
    -o wide \
    --no-headers 2>/dev/null || true)

  if [[ -z "${output}" ]]; then
    printf 'Current serving pods: none\n' >&2
    return 0
  fi

  printf 'Current serving pods:\n%s\n' "${output}" >&2
}

wait_for_serving_nodeclaims_at_least_with_progress() {
  local expected=$1
  local timeout_seconds=$2
  local start_time
  local last_log_time=0

  start_time=$(date +%s)

  while true; do
    local current_count
    local now

    current_count=$(nodeclaim_count)
    if (( current_count >= expected )); then
      return 0
    fi

    now=$(date +%s)
    if (( now - last_log_time >= WAIT_CONTEXT_LOG_INTERVAL_SECONDS )); then
      printf 'Waiting for %s serving NodeClaim(s); currently %s/%s\n' "${expected}" "${current_count}" "${expected}" >&2
      print_serving_nodeclaim_snapshot
      last_log_time=${now}
    fi

    if (( now - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for at least %s NodeClaim(s)\n' "${expected}" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

wait_for_serving_gpu_nodes_at_least_with_progress() {
  local expected=$1
  local timeout_seconds=$2
  local start_time
  local last_log_time=0

  start_time=$(date +%s)

  while true; do
    local current_count
    local now

    current_count=$(all_gpu_node_count)
    if (( current_count >= expected )); then
      return 0
    fi

    now=$(date +%s)
    if (( now - last_log_time >= WAIT_CONTEXT_LOG_INTERVAL_SECONDS )); then
      printf 'Waiting for %s total GPU node(s); currently %s/%s\n' "${expected}" "${current_count}" "${expected}" >&2
      print_serving_node_snapshot
      last_log_time=${now}
    fi

    if (( now - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for at least %s total GPU node(s)\n' "${expected}" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

wait_for_serving_gpu_nodes_at_most_with_progress() {
  local expected=$1
  local timeout_seconds=$2
  local start_time
  local last_log_time=0

  start_time=$(date +%s)

  while true; do
    local current_count
    local now

    current_count=$(all_gpu_node_count)
    if (( current_count <= expected )); then
      return 0
    fi

    now=$(date +%s)
    if (( now - last_log_time >= WAIT_CONTEXT_LOG_INTERVAL_SECONDS )); then
      printf 'Waiting for GPU cleanup to reach at most %s node(s); currently %s\n' "${expected}" "${current_count}" >&2
      print_serving_nodeclaim_snapshot
      print_serving_node_snapshot
      last_log_time=${now}
    fi

    if (( now - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for at most %s total GPU node(s)\n' "${expected}" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

wait_for_ready_replicas_at_least_with_progress() {
  local expected=$1
  local timeout_seconds=$2
  local start_time
  local last_log_time=0

  start_time=$(date +%s)

  while true; do
    local ready_replicas
    local now

    ready_replicas=$(deployment_ready_replicas "${APP_NAMESPACE}" "${GPU_INFERENCE_DEPLOYMENT_NAME}")
    ready_replicas=${ready_replicas:-0}
    if (( ready_replicas >= expected )); then
      return 0
    fi

    now=$(date +%s)
    if (( now - last_log_time >= WAIT_CONTEXT_LOG_INTERVAL_SECONDS )); then
      printf 'Waiting for %s ready replica(s); currently %s/%s\n' "${expected}" "${ready_replicas}" "${expected}" >&2
      print_serving_pod_snapshot
      print_serving_node_snapshot
      last_log_time=${now}
    fi

    if (( now - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for deployment %s/%s to reach at least %s ready replica(s)\n' \
        "${APP_NAMESPACE}" "${GPU_INFERENCE_DEPLOYMENT_NAME}" "${expected}" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

start_metric_seed_requests() {
  local request_count=${1:-4}
  local request_index
  local payload

  if [[ -z "${PUBLIC_INFERENCE_URL}" ]]; then
    return 1
  fi

  payload='{"model":"qwen2.5-0.5b","prompt":"Write a long, detailed numbered outline about autoscaling GPU inference services. Keep going until you reach the token limit.","max_tokens":1024,"temperature":0}'
  METRIC_SEED_REQUEST_PIDS=()

  for (( request_index=0; request_index<request_count; request_index++ )); do
    curl -sS -o /dev/null \
      --connect-timeout 10 \
      --max-time "${HTTP_REQUEST_TIMEOUT_SECONDS}" \
      -H 'Content-Type: application/json' \
      -X POST \
      --data "${payload}" \
      "${PUBLIC_INFERENCE_URL}" >/dev/null 2>&1 &
    METRIC_SEED_REQUEST_PIDS+=("$!")
  done
}

stop_metric_seed_requests() {
  local request_pid
  local deadline

  if ((${#METRIC_SEED_REQUEST_PIDS[@]} == 0)); then
    return 0
  fi

  for request_pid in "${METRIC_SEED_REQUEST_PIDS[@]}"; do
    kill "${request_pid}" 2>/dev/null || true
  done

  for request_pid in "${METRIC_SEED_REQUEST_PIDS[@]}"; do
    deadline=$(( $(date +%s) + 5 ))
    while kill -0 "${request_pid}" 2>/dev/null; do
      if (( $(date +%s) >= deadline )); then
        kill -9 "${request_pid}" 2>/dev/null || true
        break
      fi

      sleep 0.2
    done
  done

  for request_pid in "${METRIC_SEED_REQUEST_PIDS[@]}"; do
    wait "${request_pid}" 2>/dev/null || true
  done

  METRIC_SEED_REQUEST_PIDS=()
}

prepare_warm_profile_capacity() {
  kubectl delete -f "${KARPENTER_WARM_NODEPOOL_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  kubectl apply -f "${GPU_WARM_PLACEHOLDER_MANIFEST}" || return 1
  WARM_PLACEHOLDER_APPLIED=1

  if ! wait_for_all_gpu_nodes_at_least 1 "${EVALUATE_SCALE_TIMEOUT_SECONDS}"; then
    preserve_warm_profile_failure_state
    return 1
  fi

  if ! kubectl rollout status "deployment/${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}" -n "${APP_NAMESPACE}" \
    --timeout="${EVALUATE_SCALE_TIMEOUT_SECONDS}s"; then
    preserve_warm_profile_failure_state
    return 1
  fi
}

prepare_edge_and_profile() {
  ensure_namespace || return 1
  kubectl apply -f "${GPU_INFERENCE_SERVICE_MANIFEST}" || return 1
  kubectl apply -f "${GPU_INFERENCE_INGRESS_MANIFEST}" || return 1
  wait_for_apiservice_available "${PROMETHEUS_ADAPTER_APISERVICE_NAME}" "${MONITORING_TIMEOUT_SECONDS}" || return 1
  PUBLIC_INFERENCE_URL=$(public_inference_url "$(wait_for_ingress_hostname "${INGRESS_HOSTNAME_TIMEOUT_SECONDS}")") || return 1

  kubectl delete -f "${GPU_LOAD_TEST_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
  kubectl delete hpa "${GPU_INFERENCE_HPA_NAME}" -n "${APP_NAMESPACE}" --ignore-not-found=true >/dev/null 2>&1 || true
  kubectl delete -f "${GPU_INFERENCE_DEPLOYMENT_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true

  if is_warm_profile; then
    prepare_warm_profile_capacity || return 1
  else
    kubectl delete -f "${GPU_WARM_PLACEHOLDER_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
    kubectl delete -f "${KARPENTER_WARM_NODEPOOL_MANIFEST}" --ignore-not-found=true >/dev/null 2>&1 || true
    wait_for_all_gpu_nodes_at_most 0 "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  fi
}

seed_profile_baseline_events() {
  if ! is_warm_profile; then
    return 0
  fi

  set_if_unset FIRST_NODECLAIM_TIME "${EVALUATION_START_TIME}"
  set_if_unset FIRST_GPU_NODE_TIME "${EVALUATION_START_TIME}"
  populate_first_gpu_node_identity
}

apply_inference_stack() {
  kubectl apply -f "${GPU_INFERENCE_DEPLOYMENT_MANIFEST}" || return 1
  DEPLOYMENT_APPLIED=1
  EVALUATION_START_TIME=$(date +%s)
  seed_profile_baseline_events
}

wait_for_first_ready_and_response() {
  wait_for_serving_nodeclaims_at_least_with_progress 1 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  set_if_unset FIRST_NODECLAIM_TIME "$(date +%s)"

  wait_for_serving_gpu_nodes_at_least_with_progress 1 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  set_if_unset FIRST_GPU_NODE_TIME "$(date +%s)"

  if [[ -z "${FIRST_GPU_NODE_NAME}" ]]; then
    populate_first_gpu_node_identity
  fi

  FIRST_POD_NAME=$(wait_for_first_pod_name "${EVALUATE_SCALE_TIMEOUT_SECONDS}") || return 1
  FIRST_POD_SCHEDULED_TIME=$(wait_for_pod_condition_timestamp \
    "${FIRST_POD_NAME}" \
    "{.status.conditions[?(@.type=='PodScheduled')].lastTransitionTime}" \
    "${EVALUATE_SCALE_TIMEOUT_SECONDS}") || return 1
  FIRST_CONTAINER_STARTED_TIME=$(wait_for_pod_condition_timestamp \
    "${FIRST_POD_NAME}" \
    '{.status.containerStatuses[0].state.running.startedAt}' \
    "${EVALUATE_SCALE_TIMEOUT_SECONDS}") || return 1

  kubectl rollout status "deployment/${GPU_INFERENCE_DEPLOYMENT_NAME}" -n "${APP_NAMESPACE}" --timeout=20m || return 1
  FIRST_READY_TIME=$(date +%s)
  wait_for_http_200 "${PUBLIC_INFERENCE_URL}" "${VERIFY_RESPONSE_TIMEOUT_SECONDS}" || return 1
  FIRST_RESPONSE_TIME=$(date +%s)
}

run_load_and_wait_for_scale_out() {
  local start_time

  kubectl apply -f "${GPU_LOAD_TEST_MANIFEST}" || return 1
  LOAD_TEST_APPLIED=1
  LOAD_START_TIME=$(date +%s)
  start_time=${LOAD_START_TIME}

  while true; do
    local desired_replicas
    local job_complete

    desired_replicas=$(hpa_desired_replicas "${APP_NAMESPACE}" "${GPU_INFERENCE_HPA_NAME}")
    desired_replicas=${desired_replicas:-0}
    if (( desired_replicas >= 2 )); then
      break
    fi

    job_complete=$(kubectl get job "${GPU_LOAD_TEST_JOB_NAME}" \
      -n "${APP_NAMESPACE}" \
      -o jsonpath="{.status.conditions[?(@.type=='Complete')].status}" 2>/dev/null || true)
    if [[ "${job_complete}" == "True" ]]; then
      printf 'Load job completed before HPA scaled out; desired replicas stayed at %s\n' "${desired_replicas}" >&2
      return 1
    fi

    if (( $(date +%s) - start_time >= EVALUATE_SCALE_TIMEOUT_SECONDS )); then
      printf 'Timed out waiting for HPA %s/%s to reach at least %s desired replica(s)\n' \
        "${APP_NAMESPACE}" "${GPU_INFERENCE_HPA_NAME}" "2" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done

  HPA_SCALE_OUT_TIME=$(date +%s)

  wait_for_serving_nodeclaims_at_least_with_progress 2 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  SECOND_NODECLAIM_TIME=$(date +%s)

  wait_for_serving_gpu_nodes_at_least_with_progress 2 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  SECOND_GPU_NODE_TIME=$(date +%s)
  populate_second_gpu_node_identity

  wait_for_ready_replicas_at_least_with_progress 2 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  SECOND_READY_TIME=$(date +%s)

  wait_for_http_200 "${PUBLIC_INFERENCE_URL}" "${VERIFY_RESPONSE_TIMEOUT_SECONDS}"
}

wait_for_burst_completion() {
  wait_for_job_completion "${APP_NAMESPACE}" "${GPU_LOAD_TEST_JOB_NAME}" "${EVALUATE_LOAD_TIMEOUT_SECONDS}" || return 1
  LOAD_FINISH_TIME=$(date +%s)
}

remove_load_and_wait_for_scale_in() {
  kubectl delete -f "${GPU_LOAD_TEST_MANIFEST}" --ignore-not-found=true || return 1
  LOAD_TEST_APPLIED=0
  wait_for_hpa_desired_replicas_at_most "${APP_NAMESPACE}" "${GPU_INFERENCE_HPA_NAME}" 1 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  wait_for_deployment_ready_replicas_at_most "${APP_NAMESPACE}" "${GPU_INFERENCE_DEPLOYMENT_NAME}" 1 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  wait_for_serving_gpu_nodes_at_most_with_progress 1 "${EVALUATE_SCALE_TIMEOUT_SECONDS}" || return 1
  SCALE_IN_TIME=$(date +%s)
}

delete_inference_and_clean_profile_capacity() {
  kubectl delete hpa "${GPU_INFERENCE_HPA_NAME}" -n "${APP_NAMESPACE}" --ignore-not-found=true || return 1
  HPA_APPLIED=0
  wait_for_resource_deletion hpa "${GPU_INFERENCE_HPA_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1

  kubectl delete -f "${GPU_INFERENCE_DEPLOYMENT_MANIFEST}" --ignore-not-found=true || return 1
  DEPLOYMENT_APPLIED=0
  wait_for_resource_deletion deployment "${GPU_INFERENCE_DEPLOYMENT_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1

  if is_warm_profile; then
    wait_for_serving_gpu_nodes_at_most_with_progress 1 "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
    PROFILE_BASELINE_RESTORED_TIME=$(date +%s)

    if [[ "${PRESERVE_PROFILE_BASELINE}" == "1" ]]; then
      POLICY_FINISH_TIME=${PROFILE_BASELINE_RESTORED_TIME}
      return 0
    fi

    kubectl delete -f "${GPU_WARM_PLACEHOLDER_MANIFEST}" --ignore-not-found=true || return 1
    WARM_PLACEHOLDER_APPLIED=0
    wait_for_resource_deletion deployment "${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}" "${APP_NAMESPACE}" "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  fi

  wait_for_serving_gpu_nodes_at_most_with_progress 0 "${VERIFY_CLEANUP_TIMEOUT_SECONDS}" || return 1
  CLEANUP_FINISH_TIME=$(date +%s)
  POLICY_FINISH_TIME=${CLEANUP_FINISH_TIME}
}

normalize_rfc3339() {
  local timestamp=$1

  if [[ "${timestamp}" == *.*Z ]]; then
    printf '%sZ\n' "${timestamp%%.*}"
    return 0
  fi

  printf '%s\n' "${timestamp}"
}

rfc3339_to_epoch() {
  local timestamp
  timestamp=$(normalize_rfc3339 "$1")

  if date -u -d "${timestamp}" +%s >/dev/null 2>&1; then
    date -u -d "${timestamp}" +%s
    return 0
  fi

  date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "${timestamp}" +%s
}

seconds_since_start() {
  local timestamp=${1:-}

  if [[ -z "${timestamp}" || -z "${EVALUATION_START_TIME}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  printf '%s\n' "$((timestamp - EVALUATION_START_TIME))"
}

seconds_between() {
  local start_timestamp=${1:-}
  local end_timestamp=${2:-}

  if [[ -z "${start_timestamp}" || -z "${end_timestamp}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  printf '%s\n' "$((end_timestamp - start_timestamp))"
}

lookback_window() {
  local end_time
  local window_seconds

  end_time=${POLICY_FINISH_TIME:-$(date +%s)}
  window_seconds=$((end_time - EVALUATION_START_TIME + 120))
  if (( window_seconds < 300 )); then
    window_seconds=300
  fi

  printf '%ss\n' "${window_seconds}"
}

start_port_forward() {
  local resource_name=$1
  local resource_namespace=$2
  local remote_port=$3
  local local_port_var_name=$4
  local pid_var_name=$5
  local log_var_name=$6
  local port_forward_log
  local port_forward_pid
  local local_port=""
  local remaining_attempts=50

  port_forward_log=$(mktemp "${TMPDIR:-/tmp}/gpu-lab-port-forward.XXXXXX")
  kubectl port-forward -n "${resource_namespace}" "${resource_name}" ":${remote_port}" >"${port_forward_log}" 2>&1 &
  port_forward_pid=$!

  while (( remaining_attempts > 0 )); do
    if ! kill -0 "${port_forward_pid}" 2>/dev/null; then
      cat "${port_forward_log}" >&2 || true
      rm -f "${port_forward_log}" || true
      return 1
    fi

    local_port=$(sed -n 's/.*127\.0\.0\.1:\([0-9][0-9]*\).*/\1/p' "${port_forward_log}" | head -n 1)
    if [[ -n "${local_port}" ]]; then
      printf -v "${local_port_var_name}" '%s' "${local_port}"
      printf -v "${pid_var_name}" '%s' "${port_forward_pid}"
      printf -v "${log_var_name}" '%s' "${port_forward_log}"
      return 0
    fi

    remaining_attempts=$((remaining_attempts - 1))
    sleep 0.2
  done

  cat "${port_forward_log}" >&2 || true
  kill "${port_forward_pid}" 2>/dev/null || true
  wait "${port_forward_pid}" 2>/dev/null || true
  rm -f "${port_forward_log}" || true
  return 1
}

ensure_prometheus_local_port() {
  if [[ -n "${PROMETHEUS_LOCAL_PORT}" ]]; then
    return 0
  fi

  start_port_forward \
    "service/${KUBE_PROMETHEUS_STACK_PROMETHEUS_SERVICE}" \
    "${MONITORING_NAMESPACE}" \
    9090 \
    PROMETHEUS_LOCAL_PORT \
    PROMETHEUS_PORT_FORWARD_PID \
    PROMETHEUS_PORT_FORWARD_LOG
}

ensure_pushgateway_local_port() {
  if [[ -n "${PUSHGATEWAY_LOCAL_PORT}" ]]; then
    return 0
  fi

  start_port_forward \
    "service/${PUSHGATEWAY_SERVICE_NAME}" \
    "${MONITORING_NAMESPACE}" \
    9091 \
    PUSHGATEWAY_LOCAL_PORT \
    PUSHGATEWAY_PORT_FORWARD_PID \
    PUSHGATEWAY_PORT_FORWARD_LOG
}

extract_prometheus_scalar() {
  tr -d '\n' | sed -n 's/.*"value":\[[^,]*,"\([^"]*\)"\].*/\1/p'
}

prometheus_query_scalar() {
  local query=$1
  local response
  local scalar_value

  ensure_prometheus_local_port || return 1

  response=$(curl -fsS --get "http://127.0.0.1:${PROMETHEUS_LOCAL_PORT}/api/v1/query" \
    --data-urlencode "query=${query}" 2>/dev/null || true)
  if [[ -z "${response}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  scalar_value=$(printf '%s' "${response}" | extract_prometheus_scalar)
  if [[ "${scalar_value}" == "NaN" || "${scalar_value}" == "+Inf" || "${scalar_value}" == "-Inf" ]]; then
    printf '%s\n' ""
    return 0
  fi

  printf '%s\n' "${scalar_value}"
}

wait_for_prometheus_series() {
  local query=$1
  local timeout_seconds=$2
  local start_time

  start_time=$(date +%s)

  while true; do
    local scalar_value
    scalar_value=$(prometheus_query_scalar "${query}") || return 1
    if [[ -n "${scalar_value}" ]]; then
      return 0
    fi

    if (( $(date +%s) - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for Prometheus series: %s\n' "${query}" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

custom_pod_metric_response() {
  local namespace=$1
  local pod_name=$2
  local metric_name=$3

  kubectl get --raw "/apis/custom.metrics.k8s.io/v1beta1/namespaces/${namespace}/pods/${pod_name}/${metric_name}" 2>/dev/null || true
}

wait_for_custom_pod_metric() {
  local namespace=$1
  local pod_name=$2
  local metric_name=$3
  local timeout_seconds=$4
  local start_time

  start_time=$(date +%s)

  while true; do
    local response
    response=$(custom_pod_metric_response "${namespace}" "${pod_name}" "${metric_name}")
    if [[ -n "${response}" && "${response}" == *'"value"'* ]]; then
      return 0
    fi

    if (( $(date +%s) - start_time >= timeout_seconds )); then
      printf 'Timed out waiting for custom metric %s on pod %s/%s\n' "${metric_name}" "${namespace}" "${pod_name}" >&2
      return 1
    fi

    sleep "${POLL_INTERVAL_SECONDS}"
  done
}

render_active_pressure_hpa_manifest() {
  local rendered_manifest

  rendered_manifest=$(mktemp "${TMPDIR:-/tmp}/gpu-lab-active-hpa.XXXXXX")
  sed -e '/averageValue:/s/"[0-9][0-9]*"/"'"${ACTIVE_PRESSURE_TARGET}"'"/' \
    "${GPU_INFERENCE_ACTIVE_PRESSURE_HPA_MANIFEST}" > "${rendered_manifest}"
  TEMP_FILES+=("${rendered_manifest}")
  CURRENT_HPA_MANIFEST_PATH=${rendered_manifest}
}

wait_for_hpa_metric_pipeline() {
  if [[ -z "${FIRST_POD_NAME}" ]]; then
    printf 'First vLLM pod name is unavailable for metric checks\n' >&2
    return 1
  fi

  start_metric_seed_requests 4 || return 1
  wait_for_custom_pod_metric "${APP_NAMESPACE}" "${FIRST_POD_NAME}" "${CURRENT_HPA_METRIC_NAME}" "${MONITORING_TIMEOUT_SECONDS}" || return 1
  stop_metric_seed_requests || true

  if is_active_pressure_policy; then
    render_active_pressure_hpa_manifest || return 1
  else
    CURRENT_HPA_MANIFEST_PATH=${GPU_INFERENCE_HPA_MANIFEST}
  fi

  kubectl apply -f "${CURRENT_HPA_MANIFEST_PATH}" || return 1
  HPA_APPLIED=1
}

gpu_instance_hourly_cost() {
  local instance_type=${1:-}
  local capacity_type=${2:-on-demand}

  case "${instance_type}" in
    g4dn.xlarge)
      case "${capacity_type}" in
        spot)
          printf '0.316'
          ;;
        *)
          printf '0.526'
          ;;
      esac
      ;;
    g5.xlarge)
      case "${capacity_type}" in
        spot)
          printf '0.604'
          ;;
        *)
          printf '1.006'
          ;;
      esac
      ;;
    *)
      printf '%s\n' ""
      ;;
  esac
}

multiply_decimal_by_seconds_over_hour() {
  local decimal_value=${1:-}
  local duration_seconds=${2:-}

  if [[ -z "${decimal_value}" || -z "${duration_seconds}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  awk -v rate="${decimal_value}" -v seconds="${duration_seconds}" 'BEGIN { printf "%.6f\n", (rate * seconds) / 3600 }'
}

sum_decimal_values() {
  local left_value=${1:-0}
  local right_value=${2:-0}

  awk -v left="${left_value}" -v right="${right_value}" 'BEGIN { printf "%.6f\n", left + right }'
}

estimate_costs() {
  local first_node_hourly_cost
  local second_node_hourly_cost
  local first_node_active_seconds
  local second_node_active_seconds
  local first_node_burst_cost
  local second_node_burst_cost

  first_node_hourly_cost=$(gpu_instance_hourly_cost "${FIRST_GPU_INSTANCE_TYPE}" "${FIRST_GPU_CAPACITY_TYPE}")
  second_node_hourly_cost=$(gpu_instance_hourly_cost "${SECOND_GPU_INSTANCE_TYPE}" "${SECOND_GPU_CAPACITY_TYPE}")

  ESTIMATED_IDLE_COST_ONDEMAND_PER_HOUR="0"
  ESTIMATED_IDLE_COST_SPOT_PER_HOUR="0"
  ESTIMATED_BURST_COST_ONDEMAND="0"
  ESTIMATED_BURST_COST_SPOT="0"

  if is_warm_profile; then
    ESTIMATED_IDLE_COST_PER_HOUR=${first_node_hourly_cost}
    if [[ "${FIRST_GPU_CAPACITY_TYPE}" == "spot" ]]; then
      ESTIMATED_IDLE_COST_SPOT_PER_HOUR=${first_node_hourly_cost}
    else
      ESTIMATED_IDLE_COST_ONDEMAND_PER_HOUR=${first_node_hourly_cost}
    fi
    first_node_active_seconds=$(seconds_between "${EVALUATION_START_TIME}" "${POLICY_FINISH_TIME}")
  else
    ESTIMATED_IDLE_COST_PER_HOUR="0"
    first_node_active_seconds=$(seconds_between "${FIRST_GPU_NODE_TIME}" "${POLICY_FINISH_TIME}")
  fi

  second_node_active_seconds=$(seconds_between "${SECOND_GPU_NODE_TIME}" "${SCALE_IN_TIME}")
  first_node_burst_cost=$(multiply_decimal_by_seconds_over_hour "${first_node_hourly_cost}" "${first_node_active_seconds}")
  second_node_burst_cost=$(multiply_decimal_by_seconds_over_hour "${second_node_hourly_cost}" "${second_node_active_seconds}")
  ESTIMATED_BURST_COST=$(sum_decimal_values "${first_node_burst_cost:-0}" "${second_node_burst_cost:-0}")

  if [[ "${FIRST_GPU_CAPACITY_TYPE}" == "spot" ]]; then
    ESTIMATED_BURST_COST_SPOT=$(sum_decimal_values "${ESTIMATED_BURST_COST_SPOT}" "${first_node_burst_cost:-0}")
  else
    ESTIMATED_BURST_COST_ONDEMAND=$(sum_decimal_values "${ESTIMATED_BURST_COST_ONDEMAND}" "${first_node_burst_cost:-0}")
  fi

  if [[ "${SECOND_GPU_CAPACITY_TYPE}" == "spot" ]]; then
    ESTIMATED_BURST_COST_SPOT=$(sum_decimal_values "${ESTIMATED_BURST_COST_SPOT}" "${second_node_burst_cost:-0}")
  else
    ESTIMATED_BURST_COST_ONDEMAND=$(sum_decimal_values "${ESTIMATED_BURST_COST_ONDEMAND}" "${second_node_burst_cost:-0}")
  fi
}

collect_production_metrics() {
  local window
  local waiting_query
  local active_query
  local running_query
  local latency_query
  local ttft_query
  local throughput_query
  local nodeclaim_query
  local ondemand_nodeclaim_query
  local spot_nodeclaim_query

  window=$(lookback_window)
  waiting_query="max_over_time((sum(vllm:num_requests_waiting{namespace=\"${APP_NAMESPACE}\"}))[${window}:15s])"
  active_query="max_over_time(((sum(vllm:num_requests_running{namespace=\"${APP_NAMESPACE}\"}) + sum(vllm:num_requests_waiting{namespace=\"${APP_NAMESPACE}\"}))[${window}:15s]))"
  running_query="max_over_time((sum(vllm:num_requests_running{namespace=\"${APP_NAMESPACE}\"}))[${window}:15s])"
  latency_query="quantile_over_time(0.95, (histogram_quantile(0.95, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{namespace=\"${APP_NAMESPACE}\"}[1m]))))[${window}:1m])"
  ttft_query="quantile_over_time(0.95, (histogram_quantile(0.95, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{namespace=\"${APP_NAMESPACE}\"}[1m]))))[${window}:1m])"
  throughput_query="avg_over_time((sum(rate(vllm:generation_tokens_total{namespace=\"${APP_NAMESPACE}\"}[1m])))[${window}:1m])"
  nodeclaim_query="max_over_time(((sum(karpenter_nodeclaims_created_total{nodepool=~\"${KARPENTER_SERVING_NODEPOOL_REGEX}\"}) - sum(karpenter_nodeclaims_terminated_total{nodepool=~\"${KARPENTER_SERVING_NODEPOOL_REGEX}\"})))[${window}:1m])"
  ondemand_nodeclaim_query="max_over_time(((sum(karpenter_nodeclaims_created_total{nodepool=\"${KARPENTER_ONDEMAND_NODEPOOL_NAME}\"}) - sum(karpenter_nodeclaims_terminated_total{nodepool=\"${KARPENTER_ONDEMAND_NODEPOOL_NAME}\"})))[${window}:1m])"
  spot_nodeclaim_query="max_over_time(((sum(karpenter_nodeclaims_created_total{nodepool=\"${KARPENTER_SPOT_NODEPOOL_NAME}\"}) - sum(karpenter_nodeclaims_terminated_total{nodepool=\"${KARPENTER_SPOT_NODEPOOL_NAME}\"})))[${window}:1m])"

  ensure_prometheus_local_port || return 1

  P95_REQUEST_LATENCY_SECONDS=$(prometheus_query_scalar "${latency_query}") || return 1
  P95_TTFT_SECONDS=$(prometheus_query_scalar "${ttft_query}") || return 1
  PEAK_WAITING_REQUESTS=$(prometheus_query_scalar "${waiting_query}") || return 1
  PEAK_ACTIVE_REQUESTS=$(prometheus_query_scalar "${active_query}") || return 1
  PEAK_RUNNING_REQUESTS=$(prometheus_query_scalar "${running_query}") || return 1
  AVG_GENERATION_TOKENS_PER_SECOND=$(prometheus_query_scalar "${throughput_query}") || return 1
  AVG_GPU_UTILIZATION_PERCENT=$(prometheus_query_scalar "avg_over_time((avg(DCGM_FI_DEV_GPU_UTIL))[${window}:1m])") || return 1
  MAX_GPU_UTILIZATION_PERCENT=$(prometheus_query_scalar "max_over_time((max(DCGM_FI_DEV_GPU_UTIL))[${window}:1m])") || return 1
  PEAK_ACTIVE_NODECLAIMS=$(prometheus_query_scalar "${nodeclaim_query}") || return 1
  PEAK_ACTIVE_ONDEMAND_NODECLAIMS=$(prometheus_query_scalar "${ondemand_nodeclaim_query}") || return 1
  PEAK_ACTIVE_SPOT_NODECLAIMS=$(prometheus_query_scalar "${spot_nodeclaim_query}") || return 1

  estimate_costs
}

append_pushgateway_metric() {
  local output_file=$1
  local metric_name=$2
  local metric_value=${3:-}

  if [[ -z "${metric_value}" ]]; then
    return 0
  fi

  printf '%s %s\n' "${metric_name}" "${metric_value}" >> "${output_file}"
}

append_pushgateway_labeled_metric() {
  local output_file=$1
  local metric_name=$2
  local label_key=$3
  local label_value=${4:-}
  local metric_value=${5:-}

  if [[ -z "${label_value}" || -z "${metric_value}" ]]; then
    return 0
  fi

  printf '%s{%s="%s"} %s\n' "${metric_name}" "${label_key}" "${label_value}" "${metric_value}" >> "${output_file}"
}

push_summary_metrics() {
  local payload_file
  local push_path

  ensure_pushgateway_local_port || return 0

  payload_file=$(mktemp "${TMPDIR:-/tmp}/gpu-lab-pushgateway.XXXXXX")
  push_path="http://127.0.0.1:${PUSHGATEWAY_LOCAL_PORT}/metrics/job/gpu-serving-measure/profile/${EVALUATION_PROFILE}/policy/${CURRENT_POLICY}"

  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_first_gpu_node_seconds" "$(seconds_since_start "${FIRST_GPU_NODE_TIME}")"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_model_ready_seconds" "$(seconds_since_start "${FIRST_READY_TIME}")"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_first_external_completion_seconds" "$(seconds_since_start "${FIRST_RESPONSE_TIME}")"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_second_gpu_node_seconds" "$(seconds_since_start "${SECOND_GPU_NODE_TIME}")"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_second_ready_replica_seconds" "$(seconds_since_start "${SECOND_READY_TIME}")"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_scale_down_to_zero_gpu_nodes_seconds" "$(seconds_between "${LOAD_FINISH_TIME}" "${POLICY_FINISH_TIME}")"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_estimated_idle_cost_per_hour" "${ESTIMATED_IDLE_COST_PER_HOUR}"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_estimated_burst_cost" "${ESTIMATED_BURST_COST}"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_p95_request_latency_seconds" "${P95_REQUEST_LATENCY_SECONDS}"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_p95_ttft_seconds" "${P95_TTFT_SECONDS}"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_peak_waiting_requests" "${PEAK_WAITING_REQUESTS}"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_peak_active_requests" "${PEAK_ACTIVE_REQUESTS}"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_average_gpu_utilization_percent" "${AVG_GPU_UTILIZATION_PERCENT}"
  append_pushgateway_metric "${payload_file}" "gpu_serving_measure_peak_active_nodeclaims" "${PEAK_ACTIVE_NODECLAIMS}"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_peak_active_nodeclaims" "capacity_type" "on-demand" "${PEAK_ACTIVE_ONDEMAND_NODECLAIMS}"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_peak_active_nodeclaims" "capacity_type" "spot" "${PEAK_ACTIVE_SPOT_NODECLAIMS}"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_estimated_idle_cost_per_hour" "capacity_type" "on-demand" "${ESTIMATED_IDLE_COST_ONDEMAND_PER_HOUR}"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_estimated_idle_cost_per_hour" "capacity_type" "spot" "${ESTIMATED_IDLE_COST_SPOT_PER_HOUR}"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_estimated_burst_cost" "capacity_type" "on-demand" "${ESTIMATED_BURST_COST_ONDEMAND}"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_estimated_burst_cost" "capacity_type" "spot" "${ESTIMATED_BURST_COST_SPOT}"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_first_gpu_node_capacity_type" "capacity_type" "${FIRST_GPU_CAPACITY_TYPE}" "1"
  append_pushgateway_labeled_metric "${payload_file}" "gpu_serving_measure_second_gpu_node_capacity_type" "capacity_type" "${SECOND_GPU_CAPACITY_TYPE}" "1"

  if [[ ! -s "${payload_file}" ]]; then
    rm -f "${payload_file}"
    return 0
  fi

  curl -fsS --data-binary @"${payload_file}" "${push_path}" >/dev/null 2>&1 || true
  rm -f "${payload_file}"
}

json_escape() {
  local value=$1

  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '"%s"' "${value}"
}

json_nullable_string() {
  local value=${1:-}

  if [[ -z "${value}" ]]; then
    printf 'null'
    return 0
  fi

  json_escape "${value}"
}

json_nullable_number() {
  local value=${1:-}

  if [[ -z "${value}" ]]; then
    printf 'null'
    return 0
  fi

  printf '%s' "${value}"
}

display_duration() {
  local seconds=${1:-}

  if [[ -z "${seconds}" ]]; then
    printf 'n/a'
    return 0
  fi

  format_duration "${seconds}"
}

display_metric() {
  local value=${1:-}
  local suffix=${2:-}

  if [[ -z "${value}" ]]; then
    printf 'n/a'
    return 0
  fi

  printf '%s%s' "${value}" "${suffix}"
}

pod_schedule_to_ready_seconds() {
  if [[ -z "${FIRST_POD_SCHEDULED_TIME}" || -z "${FIRST_READY_TIME}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  printf '%s\n' "$((FIRST_READY_TIME - $(rfc3339_to_epoch "${FIRST_POD_SCHEDULED_TIME}")))"
}

container_started_to_ready_seconds() {
  if [[ -z "${FIRST_CONTAINER_STARTED_TIME}" || -z "${FIRST_READY_TIME}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  printf '%s\n' "$((FIRST_READY_TIME - $(rfc3339_to_epoch "${FIRST_CONTAINER_STARTED_TIME}")))"
}

write_reports() {
  local pod_schedule_ready_seconds
  local container_ready_seconds
  local cleanup_note='- The script cleans up the profile at the end so the environment returns to zero GPU nodes after reporting.'
  local compare_mode_cleanup_note=""

  pod_schedule_ready_seconds=$(pod_schedule_to_ready_seconds)
  container_ready_seconds=$(container_started_to_ready_seconds)

  if [[ "${PRESERVE_PROFILE_BASELINE}" == "1" && -z "${CLEANUP_FINISH_TIME}" ]]; then
    cleanup_note='- This policy run restores the warm baseline after reporting so the compare workflow can execute the next policy before final cleanup.'
    compare_mode_cleanup_note='- This compare-mode policy run restores the warm baseline between policies, so final cleanup to zero GPU nodes is deferred until the last policy run.'
  fi

  mkdir -p "$(dirname "${REPORT_PATH}")"
  mkdir -p "$(dirname "${JSON_REPORT_PATH}")"

  cat > "${REPORT_PATH}" <<EOF
# Load-Aware GPU Serving Report

- Generated at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
- Profile: ${EVALUATION_PROFILE}
- Policy: ${CURRENT_POLICY}
- HPA metric name: ${CURRENT_HPA_METRIC_NAME}
- HPA target average value: ${CURRENT_HPA_TARGET_AVERAGE_VALUE}
- Public endpoint: ${PUBLIC_INFERENCE_URL}
- First GPU capacity type: ${FIRST_GPU_CAPACITY_TYPE:-n/a}
- First GPU instance type: ${FIRST_GPU_INSTANCE_TYPE:-n/a}
- Second GPU capacity type: ${SECOND_GPU_CAPACITY_TYPE:-n/a}
- Second GPU instance type: ${SECOND_GPU_INSTANCE_TYPE:-n/a}

## Timeline

| Event | Delta from start |
| --- | --- |
| First NodeClaim | $(display_duration "$(seconds_since_start "${FIRST_NODECLAIM_TIME}")") |
| First GPU node | $(display_duration "$(seconds_since_start "${FIRST_GPU_NODE_TIME}")") |
| First ready replica | $(display_duration "$(seconds_since_start "${FIRST_READY_TIME}")") |
| First public response | $(display_duration "$(seconds_since_start "${FIRST_RESPONSE_TIME}")") |
| Load job started | $(display_duration "$(seconds_since_start "${LOAD_START_TIME}")") |
| HPA desired replicas = 2 | $(display_duration "$(seconds_since_start "${HPA_SCALE_OUT_TIME}")") |
| Second NodeClaim | $(display_duration "$(seconds_since_start "${SECOND_NODECLAIM_TIME}")") |
| Second GPU node | $(display_duration "$(seconds_since_start "${SECOND_GPU_NODE_TIME}")") |
| Second ready replica | $(display_duration "$(seconds_since_start "${SECOND_READY_TIME}")") |
| Load job complete | $(display_duration "$(seconds_since_start "${LOAD_FINISH_TIME}")") |
| Scale-in back to one GPU node | $(display_duration "$(seconds_since_start "${SCALE_IN_TIME}")") |
| Warm baseline restored | $(display_duration "$(seconds_since_start "${PROFILE_BASELINE_RESTORED_TIME}")") |
| Final cleanup to zero GPU nodes | $(display_duration "$(seconds_since_start "${CLEANUP_FINISH_TIME}")") |

## Operator Summary

- Node launch latency: $(display_duration "$(seconds_since_start "${FIRST_GPU_NODE_TIME}")")
- Pod scheduled to Ready: $(display_duration "${pod_schedule_ready_seconds}")
- Container started to Ready (model-load proxy): $(display_duration "${container_ready_seconds}")
- First public response: $(display_duration "$(seconds_since_start "${FIRST_RESPONSE_TIME}")")
- Scale-out to second GPU node: $(display_duration "$(seconds_since_start "${SECOND_GPU_NODE_TIME}")")
- Scale-out to second ready replica: $(display_duration "$(seconds_since_start "${SECOND_READY_TIME}")")
- Scale-in after load completion: $(display_duration "$(seconds_between "${LOAD_FINISH_TIME}" "${SCALE_IN_TIME}")")
- Final cleanup to zero GPU nodes: $(display_duration "$(seconds_between "${LOAD_FINISH_TIME}" "${CLEANUP_FINISH_TIME}")")

## Metrics

- p95 request latency during burst: $(display_metric "${P95_REQUEST_LATENCY_SECONDS}" "s")
- p95 queue/TTFT proxy during burst: $(display_metric "${P95_TTFT_SECONDS}" "s")
- Peak waiting requests: $(display_metric "${PEAK_WAITING_REQUESTS}")
- Peak active requests: $(display_metric "${PEAK_ACTIVE_REQUESTS}")
- Peak running requests: $(display_metric "${PEAK_RUNNING_REQUESTS}")
- Average generation tokens per second: $(display_metric "${AVG_GENERATION_TOKENS_PER_SECOND}")
- Average GPU utilization: $(display_metric "${AVG_GPU_UTILIZATION_PERCENT}" "%")
- Max GPU utilization: $(display_metric "${MAX_GPU_UTILIZATION_PERCENT}" "%")
- Peak active NodeClaims: $(display_metric "${PEAK_ACTIVE_NODECLAIMS}")
- Peak active on-demand NodeClaims: $(display_metric "${PEAK_ACTIVE_ONDEMAND_NODECLAIMS}")
- Peak active spot NodeClaims: $(display_metric "${PEAK_ACTIVE_SPOT_NODECLAIMS}")

## Cost

- Estimated idle cost per hour for profile: ${ESTIMATED_IDLE_COST_PER_HOUR:-n/a}
- Estimated idle on-demand cost per hour: ${ESTIMATED_IDLE_COST_ONDEMAND_PER_HOUR:-n/a}
- Estimated idle spot cost per hour: ${ESTIMATED_IDLE_COST_SPOT_PER_HOUR:-n/a}
- Estimated burst cost for this run: ${ESTIMATED_BURST_COST:-n/a}
- Estimated burst on-demand cost for this run: ${ESTIMATED_BURST_COST_ONDEMAND:-n/a}
- Estimated burst spot cost for this run: ${ESTIMATED_BURST_COST_SPOT:-n/a}

## Notes

- \`Container started -> Ready\` is reported as the model-load proxy because the baseline experiment does not rely on a separate vLLM model-load completion metric.
- \`p95 queue/TTFT proxy\` uses \`time_to_first_token_seconds\` because the current telemetry does not expose a dedicated queue-wait histogram.
- The HPA is validated from the custom metric \`${CURRENT_HPA_METRIC_NAME}\` with target average value \`${CURRENT_HPA_TARGET_AVERAGE_VALUE}\`, not CPU utilization.
- Spot prices use the repo's fixed conservative estimate table so reports stay deterministic across runs.
- ${cleanup_note#- }
${compare_mode_cleanup_note}
EOF

  cat > "${JSON_REPORT_PATH}" <<EOF
{
  "generated_at": $(json_escape "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"),
  "profile": $(json_escape "${EVALUATION_PROFILE}"),
  "policy": $(json_escape "${CURRENT_POLICY}"),
  "hpa_metric_name": $(json_escape "${CURRENT_HPA_METRIC_NAME}"),
  "hpa_target_average_value": $(json_escape "${CURRENT_HPA_TARGET_AVERAGE_VALUE}"),
  "public_endpoint": $(json_escape "${PUBLIC_INFERENCE_URL}"),
  "first_gpu_capacity_type": $(json_nullable_string "${FIRST_GPU_CAPACITY_TYPE}"),
  "first_gpu_instance_type": $(json_nullable_string "${FIRST_GPU_INSTANCE_TYPE}"),
  "first_gpu_nodepool": $(json_nullable_string "${FIRST_GPU_NODEPOOL_NAME}"),
  "second_gpu_capacity_type": $(json_nullable_string "${SECOND_GPU_CAPACITY_TYPE}"),
  "second_gpu_instance_type": $(json_nullable_string "${SECOND_GPU_INSTANCE_TYPE}"),
  "second_gpu_nodepool": $(json_nullable_string "${SECOND_GPU_NODEPOOL_NAME}"),
  "timeline": {
    "first_nodeclaim_seconds": $(json_nullable_number "$(seconds_since_start "${FIRST_NODECLAIM_TIME}")"),
    "first_gpu_node_seconds": $(json_nullable_number "$(seconds_since_start "${FIRST_GPU_NODE_TIME}")"),
    "first_ready_seconds": $(json_nullable_number "$(seconds_since_start "${FIRST_READY_TIME}")"),
    "first_public_response_seconds": $(json_nullable_number "$(seconds_since_start "${FIRST_RESPONSE_TIME}")"),
    "load_started_seconds": $(json_nullable_number "$(seconds_since_start "${LOAD_START_TIME}")"),
    "hpa_scale_out_seconds": $(json_nullable_number "$(seconds_since_start "${HPA_SCALE_OUT_TIME}")"),
    "second_nodeclaim_seconds": $(json_nullable_number "$(seconds_since_start "${SECOND_NODECLAIM_TIME}")"),
    "second_gpu_node_seconds": $(json_nullable_number "$(seconds_since_start "${SECOND_GPU_NODE_TIME}")"),
    "second_ready_seconds": $(json_nullable_number "$(seconds_since_start "${SECOND_READY_TIME}")"),
    "load_complete_seconds": $(json_nullable_number "$(seconds_since_start "${LOAD_FINISH_TIME}")"),
    "scale_in_seconds": $(json_nullable_number "$(seconds_since_start "${SCALE_IN_TIME}")"),
    "warm_baseline_restored_seconds": $(json_nullable_number "$(seconds_since_start "${PROFILE_BASELINE_RESTORED_TIME}")"),
    "cleanup_finish_seconds": $(json_nullable_number "$(seconds_since_start "${CLEANUP_FINISH_TIME}")")
  },
  "operator_summary": {
    "pod_scheduled_to_ready_seconds": $(json_nullable_number "${pod_schedule_ready_seconds}"),
    "container_started_to_ready_seconds": $(json_nullable_number "${container_ready_seconds}")
  },
  "metrics": {
    "p95_request_latency_seconds": $(json_nullable_number "${P95_REQUEST_LATENCY_SECONDS}"),
    "p95_ttft_seconds": $(json_nullable_number "${P95_TTFT_SECONDS}"),
    "peak_waiting_requests": $(json_nullable_number "${PEAK_WAITING_REQUESTS}"),
    "peak_active_requests": $(json_nullable_number "${PEAK_ACTIVE_REQUESTS}"),
    "peak_running_requests": $(json_nullable_number "${PEAK_RUNNING_REQUESTS}"),
    "average_generation_tokens_per_second": $(json_nullable_number "${AVG_GENERATION_TOKENS_PER_SECOND}"),
    "average_gpu_utilization_percent": $(json_nullable_number "${AVG_GPU_UTILIZATION_PERCENT}"),
    "max_gpu_utilization_percent": $(json_nullable_number "${MAX_GPU_UTILIZATION_PERCENT}"),
    "peak_active_nodeclaims": $(json_nullable_number "${PEAK_ACTIVE_NODECLAIMS}"),
    "peak_active_nodeclaims_by_capacity_type": {
      "on_demand": $(json_nullable_number "${PEAK_ACTIVE_ONDEMAND_NODECLAIMS}"),
      "spot": $(json_nullable_number "${PEAK_ACTIVE_SPOT_NODECLAIMS}")
    }
  },
  "cost": {
    "estimated_idle_cost_per_hour": $(json_nullable_number "${ESTIMATED_IDLE_COST_PER_HOUR}"),
    "estimated_idle_cost_per_hour_by_capacity_type": {
      "on_demand": $(json_nullable_number "${ESTIMATED_IDLE_COST_ONDEMAND_PER_HOUR}"),
      "spot": $(json_nullable_number "${ESTIMATED_IDLE_COST_SPOT_PER_HOUR}")
    },
    "estimated_burst_cost": $(json_nullable_number "${ESTIMATED_BURST_COST}"),
    "estimated_burst_cost_by_capacity_type": {
      "on_demand": $(json_nullable_number "${ESTIMATED_BURST_COST_ONDEMAND}"),
      "spot": $(json_nullable_number "${ESTIMATED_BURST_COST_SPOT}")
    }
  }
}
