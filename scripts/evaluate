    },
    "capacity_assessment": {
      "status": $(json_nullable_string "$(get_policy_snapshot_value active-pressure CAPACITY_ASSESSMENT)"),
      "reason": $(json_nullable_string "$(get_policy_snapshot_value active-pressure CAPACITY_ASSESSMENT_REASON)")
    }
  }
}
EOF
}

write_sweep_reports() {
  local target
  local first_result=1

  determine_sweep_recommendation
  mkdir -p "$(dirname "${SWEEP_REPORT_PATH}")"
  mkdir -p "$(dirname "${SWEEP_JSON_REPORT_PATH}")"

  cat > "${SWEEP_REPORT_PATH}" <<EOF
# Active-Pressure Target Sweep Report

- Generated at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
- Profile: ${EVALUATION_PROFILE}
- Policy: active-pressure
- Resilience mode: ${EVALUATION_RESILIENCE}
- Targets evaluated: $(format_active_target_sweep_list)
- Recommended active target: ${SWEEP_RECOMMENDED_TARGET:-n/a}
- Recommendation status: ${SWEEP_RECOMMENDATION_STATUS:-n/a}
- Recommendation rationale: ${SWEEP_RECOMMENDATION_REASON:-n/a}

## Target Summary

| Active target | Status | Metrics collection | p95 request latency | p95 estimated queue wait | p95 TTFT | Peak waiting requests | Peak active requests | Peak active/GPU node | Average GPU utilization | Max GPU utilization | Peak active NodeClaims | Second ready replica | Recovery ready after interruption | Burst cost | Markdown report |
| --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- | --- |
EOF

  for target in "${ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
    printf '| %s | %s | %s | %s | %s | %s | %s | %s | %s | %s | %s | %s | %s | %s | %s | %s |\n' \
      "${target}" \
      "$(get_sweep_target_value "${target}" STATUS)" \
      "$(get_sweep_target_value "${target}" METRICS_COLLECTION_STATUS)" \
      "$(sweep_metric_value "${target}" P95_REQUEST_LATENCY_SECONDS "s")" \
      "$(sweep_metric_value "${target}" P95_ESTIMATED_QUEUE_WAIT_SECONDS "s")" \
      "$(sweep_metric_value "${target}" P95_TTFT_SECONDS "s")" \
      "$(sweep_metric_value "${target}" PEAK_WAITING_REQUESTS)" \
      "$(sweep_metric_value "${target}" PEAK_ACTIVE_REQUESTS)" \
      "$(sweep_metric_value "${target}" PEAK_ACTIVE_REQUESTS_PER_GPU_NODE)" \
      "$(sweep_metric_value "${target}" AVG_GPU_UTILIZATION_PERCENT "%")" \
      "$(sweep_metric_value "${target}" MAX_GPU_UTILIZATION_PERCENT "%")" \
      "$(sweep_metric_value "${target}" PEAK_ACTIVE_NODECLAIMS)" \
      "$(sweep_duration_value "${target}" SECOND_READY_SECONDS)" \
      "$(sweep_duration_value "${target}" RECOVERY_READY_SECONDS)" \
      "$(sweep_metric_value "${target}" ESTIMATED_BURST_COST)" \
      "$(get_sweep_target_value "${target}" REPORT_PATH)" \
      >> "${SWEEP_REPORT_PATH}"
  done

  cat >> "${SWEEP_REPORT_PATH}" <<EOF

## Target Interpretation

EOF

  for target in "${ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
    printf -- '- %s: %s\n' \
      "${target}" \
      "$(get_sweep_target_value "${target}" STATUS_REASON)" \
      >> "${SWEEP_REPORT_PATH}"
  done

  cat >> "${SWEEP_REPORT_PATH}" <<EOF

## Heuristic

- \`balanced\` means estimated queue wait, TTFT, and GPU utilization stayed inside the guardrails for the configured target.
- \`underutilized\` means the run stayed below the saturation guardrails while average GPU utilization remained below 55% and queue wait stayed low.
- \`saturated\` means queue wait, TTFT, waiting pressure, or max GPU utilization crossed the heuristic guardrail.
- The recommendation picks the highest balanced target, then the highest underutilized target, otherwise the lowest-score saturated target.
EOF

  {
    printf '{\n'
    printf '  "generated_at": %s,\n' "$(json_escape "$(date -u +"%Y-%m-%dT%H:%M:%SZ")")"
    printf '  "profile": %s,\n' "$(json_escape "${EVALUATION_PROFILE}")"
    printf '  "resilience_mode": %s,\n' "$(json_escape "${EVALUATION_RESILIENCE}")"
    printf '  "policy": "active-pressure",\n'
    printf '  "mode": "sweep",\n'
    printf '  "targets_evaluated": ['
    for target in "${ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
      if [[ "${first_result}" == "0" ]]; then
        printf ', '
      fi
      printf '%s' "${target}"
      first_result=0
    done
    printf '],\n'
    printf '  "recommendation": {\n'
    printf '    "active_target": %s,\n' "$(json_nullable_number "${SWEEP_RECOMMENDED_TARGET}")"
    printf '    "status": %s,\n' "$(json_nullable_string "${SWEEP_RECOMMENDATION_STATUS}")"
    printf '    "rationale": %s\n' "$(json_nullable_string "${SWEEP_RECOMMENDATION_REASON}")"
    printf '  },\n'
    printf '  "heuristic": {\n'
    printf '    "balanced_waiting_at_or_below_target": true,\n'
    printf '    "balanced_p95_estimated_queue_wait_seconds_max": 1.0,\n'
    printf '    "balanced_p95_ttft_seconds_max": 1.0,\n'
    printf '    "balanced_max_gpu_utilization_percent_max": 95,\n'
    printf '    "underutilized_average_gpu_utilization_percent_max": 55\n'
    printf '  },\n'
    printf '  "results": [\n'

    first_result=1
    for target in "${ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
      if [[ "${first_result}" == "0" ]]; then
        printf ',\n'
      fi
      printf '    {\n'
      printf '      "active_target": %s,\n' "$(json_nullable_number "${target}")"
      printf '      "status": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" STATUS)")"
      printf '      "status_reason": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" STATUS_REASON)")"
      printf '      "score": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" SCORE)")"
      printf '      "report_path": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" REPORT_PATH)")"
      printf '      "json_report_path": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" JSON_REPORT_PATH)")"
      printf '      "hpa_metric_name": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" HPA_METRIC_NAME)")"
      printf '      "hpa_target_average_value": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" HPA_TARGET_AVERAGE_VALUE)")"
      printf '      "metrics_collection_status": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" METRICS_COLLECTION_STATUS)")"
      printf '      "metrics_collection_reason": %s,\n' "$(json_nullable_string "$(get_sweep_target_value "${target}" METRICS_COLLECTION_REASON)")"
      printf '      "metrics": {\n'
      printf '        "p95_request_latency_seconds": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" P95_REQUEST_LATENCY_SECONDS)")"
      printf '        "p95_estimated_queue_wait_seconds": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" P95_ESTIMATED_QUEUE_WAIT_SECONDS)")"
      printf '        "p95_ttft_seconds": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" P95_TTFT_SECONDS)")"
      printf '        "peak_waiting_requests": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" PEAK_WAITING_REQUESTS)")"
      printf '        "peak_active_requests": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" PEAK_ACTIVE_REQUESTS)")"
      printf '        "peak_active_requests_per_gpu_node": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" PEAK_ACTIVE_REQUESTS_PER_GPU_NODE)")"
      printf '        "average_completed_requests_per_second": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" AVG_COMPLETED_REQUESTS_PER_SECOND)")"
      printf '        "average_gpu_utilization_percent": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" AVG_GPU_UTILIZATION_PERCENT)")"
      printf '        "average_gpu_headroom_percent": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" AVG_GPU_HEADROOM_PERCENT)")"
      printf '        "max_gpu_utilization_percent": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" MAX_GPU_UTILIZATION_PERCENT)")"
      printf '        "peak_active_nodeclaims": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" PEAK_ACTIVE_NODECLAIMS)")"
      printf '        "second_ready_seconds": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" SECOND_READY_SECONDS)")"
      printf '        "recovery_ready_seconds": %s,\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" RECOVERY_READY_SECONDS)")"
      printf '        "estimated_burst_cost": %s\n' "$(json_nullable_number "$(get_sweep_target_value "${target}" ESTIMATED_BURST_COST)")"
      printf '      }\n'
      printf '    }'
      first_result=0
    done

    printf '\n  ]\n'
    printf '}\n'
  } > "${SWEEP_JSON_REPORT_PATH}"
}

collect_metrics_and_write_reports() {
  if ! collect_production_metrics; then
    METRICS_COLLECTION_STATUS="partial"
    METRICS_COLLECTION_REASON="Prometheus metric collection failed after workload cleanup; report contains Kubernetes timeline, cost, and resilience data with unavailable metrics set to null."
    printf 'Warning: unable to collect Prometheus metrics; writing partial report with available timeline, cost, and resilience data.\n' >&2
    finalize_derived_readouts
  fi

  push_summary_metrics || true
  write_reports
}

run_single_policy_evaluation() {
  local policy=$1
  local report_key=${2:-$1}
  local stage_prefix=${3:-}
  local preserve_profile_baseline=${4:-0}

  reset_policy_measurements
  set_policy_context "${policy}" "${report_key}" "${stage_prefix}"

  if [[ "${preserve_profile_baseline}" == "1" ]]; then
    PRESERVE_PROFILE_BASELINE=1
  fi

  set_failure_hints \
    "command -v kubectl curl awk" \
    "kubectl config current-context" \
    "kubectl get apiservice ${PROMETHEUS_ADAPTER_APISERVICE_NAME}"
  run_stage 1 "${TOTAL_STAGES}" "$(policy_stage_label "checking prerequisites")" evaluate_prereqs

  set_failure_hints \
    "kubectl get ingress,service -n ${APP_NAMESPACE}" \
    "kubectl get apiservice ${PROMETHEUS_ADAPTER_APISERVICE_NAME} -o yaml" \
    "kubectl get deployment,pods -n ${APP_NAMESPACE} -l app=${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}" \
    "kubectl get nodeclaims,nodes -o wide" \
    "kubectl logs -n ${KARPENTER_NAMESPACE} deployment/karpenter --since=10m"
  run_stage 2 "${TOTAL_STAGES}" "$(policy_stage_label "prepare evaluation edge and profile")" prepare_edge_and_profile

  set_failure_hints \
    "kubectl get deployment,hpa -n ${APP_NAMESPACE}" \
    "kubectl describe hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE}" \
    "kubectl get pods -n ${APP_NAMESPACE}"
  run_stage 3 "${TOTAL_STAGES}" "$(policy_stage_label "apply inference deployment")" apply_inference_stack

  set_failure_hints \
    "kubectl get pods -n ${APP_NAMESPACE} -o wide" \
    "kubectl get nodeclaims" \
    "kubectl logs -n ${APP_NAMESPACE} deployment/${GPU_INFERENCE_DEPLOYMENT_NAME} --tail=100"
  run_stage 4 "${TOTAL_STAGES}" "$(policy_stage_label "wait for first ready replica and first public response")" wait_for_first_ready_and_response

  set_failure_hints \
    "kubectl get deployment,pods -n ${APP_NAMESPACE}" \
    "kubectl get --raw /apis/custom.metrics.k8s.io/v1beta1/namespaces/${APP_NAMESPACE}/pods/${FIRST_POD_NAME:-<pod-name>}/${CURRENT_HPA_METRIC_NAME}" \
    "kubectl logs -n ${APP_NAMESPACE} deployment/${GPU_INFERENCE_DEPLOYMENT_NAME} --tail=100" \
    "kubectl port-forward -n ${MONITORING_NAMESPACE} service/${KUBE_PROMETHEUS_STACK_PROMETHEUS_SERVICE} 9090:9090"
  run_stage 5 "${TOTAL_STAGES}" "$(policy_stage_label "wait for hpa metric pipeline and apply hpa")" wait_for_hpa_metric_pipeline

  set_failure_hints \
    "kubectl get --raw /apis/custom.metrics.k8s.io/v1beta1/namespaces/${APP_NAMESPACE}/pods/${FIRST_POD_NAME:-<pod-name>}/${CURRENT_HPA_METRIC_NAME}" \
    "kubectl describe hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE}" \
    "kubectl port-forward -n ${MONITORING_NAMESPACE} service/${KUBE_PROMETHEUS_STACK_PROMETHEUS_SERVICE} 9090:9090" \
    "kubectl get nodeclaims,nodes" \
    "kubectl logs -n ${APP_NAMESPACE} job/${GPU_LOAD_TEST_JOB_NAME} --tail=100"
  run_stage 6 "${TOTAL_STAGES}" "$(policy_stage_label "run load and wait for scale-out")" run_load_and_wait_for_scale_out

  set_failure_hints \
    "kubectl get nodeclaims -o wide" \
    "kubectl get nodes -L workload,karpenter.sh/nodepool,karpenter.sh/capacity-type,node.kubernetes.io/instance-type -o wide" \
    "kubectl get pods -n ${APP_NAMESPACE} -o wide" \
    "kubectl describe hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE}"
  run_stage 7 "${TOTAL_STAGES}" "$(policy_stage_label "handle resilience event and wait for recovery")" trigger_spot_interruption_and_wait_for_recovery

  set_failure_hints \
    "kubectl get job ${GPU_LOAD_TEST_JOB_NAME} -n ${APP_NAMESPACE} -o yaml" \
    "kubectl logs -n ${APP_NAMESPACE} job/${GPU_LOAD_TEST_JOB_NAME}" \
    "kubectl get hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE} -o yaml"
  run_stage 8 "${TOTAL_STAGES}" "$(policy_stage_label "wait for the burst to complete")" wait_for_burst_completion

  set_failure_hints \
    "kubectl get hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE}" \
    "kubectl get deployment ${GPU_INFERENCE_DEPLOYMENT_NAME} -n ${APP_NAMESPACE} -o yaml" \
    "kubectl get nodes -L workload,node.kubernetes.io/instance-type"
  run_stage 9 "${TOTAL_STAGES}" "$(policy_stage_label "remove load and wait for scale-in")" remove_load_and_wait_for_scale_in

  set_failure_hints \
    "kubectl get deployment,hpa -n ${APP_NAMESPACE}" \
    "kubectl get deployment ${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME} -n ${APP_NAMESPACE}" \
    "kubectl get nodes -L workload,node.kubernetes.io/instance-type"
  run_stage 10 "${TOTAL_STAGES}" "$(policy_stage_label "delete inference workload and clean profile capacity")" delete_inference_and_clean_profile_capacity

  set_failure_hints \
    "kubectl get svc -n ${MONITORING_NAMESPACE}" \
    "kubectl get pods -n ${MONITORING_NAMESPACE}" \
    "kubectl get podmonitor,servicemonitor -n ${MONITORING_NAMESPACE}"
  run_stage 11 "${TOTAL_STAGES}" "$(policy_stage_label "collect metrics and write reports")" collect_metrics_and_write_reports
}

print_single_policy_summary() {
  printf '\nEvaluated:\n'
  printf '  Profile: %s\n' "${EVALUATION_PROFILE}"
  printf '  Policy: %s\n' "${CURRENT_POLICY}"
  printf '  Resilience mode: %s\n' "${EVALUATION_RESILIENCE}"
  printf '  HPA metric: %s\n' "${CURRENT_HPA_METRIC_NAME}"
  printf '  HPA target average value: %s\n' "${CURRENT_HPA_TARGET_AVERAGE_VALUE}"
  printf '  First GPU capacity type: %s\n' "${FIRST_GPU_CAPACITY_TYPE:-n/a}"
  printf '  Second GPU capacity type: %s\n' "${SECOND_GPU_CAPACITY_TYPE:-n/a}"
  printf '  Recovery GPU capacity type: %s\n' "${RECOVERY_GPU_CAPACITY_TYPE:-n/a}"
  printf '  Resilience outcome: %s\n' "${RESILIENCE_OUTCOME:-n/a}"
  printf '  First public response: %s\n' "$(display_duration "$(seconds_since_start "${FIRST_RESPONSE_TIME}")")"
  printf '  Second ready replica: %s\n' "$(display_duration "$(seconds_since_start "${SECOND_READY_TIME}")")"
  printf '  Recovery ready replica after interruption: %s\n' "$(display_duration "$(seconds_since_start "${RECOVERY_READY_TIME}")")"
  printf '  p95 request latency: %s\n' "$(display_metric "${P95_REQUEST_LATENCY_SECONDS}" "s")"
  printf '  p95 estimated queue wait: %s\n' "$(display_metric "${P95_ESTIMATED_QUEUE_WAIT_SECONDS}" "s")"
  printf '  Peak waiting requests: %s\n' "$(display_metric "${PEAK_WAITING_REQUESTS}")"
  printf '  Peak active requests: %s\n' "$(display_metric "${PEAK_ACTIVE_REQUESTS}")"
  printf '  Peak active requests per GPU node: %s\n' "$(display_metric "${PEAK_ACTIVE_REQUESTS_PER_GPU_NODE}")"
  printf '  Average GPU utilization: %s\n' "$(display_metric "${AVG_GPU_UTILIZATION_PERCENT}" "%")"
  printf '  Capacity assessment: %s\n' "${CAPACITY_ASSESSMENT:-n/a}"
  printf '  Markdown report: %s\n' "${REPORT_PATH}"
  printf '  JSON report: %s\n' "${JSON_REPORT_PATH}"
}

print_compare_summary() {
  printf '\nCompared:\n'
  printf '  Profile: %s\n' "${EVALUATION_PROFILE}"
  printf '  Resilience mode: %s\n' "${EVALUATION_RESILIENCE}"
  printf '  Running report: %s\n' "$(get_policy_snapshot_value running REPORT_PATH)"
  printf '  Active-pressure report: %s\n' "$(get_policy_snapshot_value active-pressure REPORT_PATH)"
  printf '  Compare report: %s\n' "${COMPARE_REPORT_PATH}"
  printf '  Compare JSON report: %s\n' "${COMPARE_JSON_REPORT_PATH}"
}

print_sweep_summary() {
  printf '\nSwept:\n'
  printf '  Profile: %s\n' "${EVALUATION_PROFILE}"
  printf '  Resilience mode: %s\n' "${EVALUATION_RESILIENCE}"
  printf '  Targets: %s\n' "$(format_active_target_sweep_list)"
  printf '  Recommended active target: %s\n' "${SWEEP_RECOMMENDED_TARGET:-n/a}"
  printf '  Recommendation status: %s\n' "${SWEEP_RECOMMENDATION_STATUS:-n/a}"
  printf '  Recommendation rationale: %s\n' "${SWEEP_RECOMMENDATION_REASON:-n/a}"
  printf '  Sweep report: %s\n' "${SWEEP_REPORT_PATH}"
  printf '  Sweep JSON report: %s\n' "${SWEEP_JSON_REPORT_PATH}"
}

main() {
  local stage_prefix=""
  local last_target_index
  local target_index
  local sweep_target
  local preserve_baseline

  parse_args "$@"
  trap cleanup_evaluate EXIT

  if is_compare_mode; then
    COMPARE_REPORT_PATH=$(resolve_report_path_for_key "compare")
    COMPARE_JSON_REPORT_PATH=$(resolve_json_report_path_for_key "compare")

    preserve_baseline=0
    if is_warm_profile; then
      preserve_baseline=1
    fi

    run_single_policy_evaluation running running running "${preserve_baseline}"
    capture_compare_policy_result running

    run_single_policy_evaluation active-pressure active-pressure active-pressure 0
    capture_compare_policy_result active-pressure

    write_compare_reports
    restore_resilience_mode
    print_compare_summary
    return 0
  fi

  if is_sweep_mode; then
    SWEEP_REPORT_PATH=$(resolve_report_path_for_key "active-pressure-sweep")
    SWEEP_JSON_REPORT_PATH=$(resolve_json_report_path_for_key "active-pressure-sweep")
    last_target_index=$((${#ACTIVE_TARGET_SWEEP_VALUES[@]} - 1))

    for target_index in "${!ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
      sweep_target=${ACTIVE_TARGET_SWEEP_VALUES[${target_index}]}
      ACTIVE_PRESSURE_TARGET=${sweep_target}
      preserve_baseline=0
      if is_warm_profile && (( target_index < last_target_index )); then
        preserve_baseline=1
      fi

      run_single_policy_evaluation \
        active-pressure \
        "active-pressure-target-${sweep_target}" \
        "active-pressure@${sweep_target}" \
        "${preserve_baseline}"
      capture_sweep_target_result "${sweep_target}"
    done

    write_sweep_reports
    restore_resilience_mode
    print_sweep_summary
    return 0
  fi

  if [[ "${EVALUATION_POLICY}" != "running" ]]; then
    stage_prefix=${EVALUATION_POLICY}
  fi

  run_single_policy_evaluation "${EVALUATION_POLICY}" "${EVALUATION_POLICY}" "${stage_prefix}" 0
  restore_resilience_mode
  print_single_policy_summary
}

main "$@"
