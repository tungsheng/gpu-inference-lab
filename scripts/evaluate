| Average GPU utilization | $(compare_metric_value running AVG_GPU_UTILIZATION_PERCENT "%") | $(compare_metric_value active-pressure AVG_GPU_UTILIZATION_PERCENT "%") |
| Max GPU utilization | $(compare_metric_value running MAX_GPU_UTILIZATION_PERCENT "%") | $(compare_metric_value active-pressure MAX_GPU_UTILIZATION_PERCENT "%") |
| Peak active NodeClaims | $(compare_metric_value running PEAK_ACTIVE_NODECLAIMS "") | $(compare_metric_value active-pressure PEAK_ACTIVE_NODECLAIMS "") |
| Second ready replica | $(compare_duration_value running SECOND_READY_SECONDS) | $(compare_duration_value active-pressure SECOND_READY_SECONDS) |
| Burst cost | $(compare_metric_value running ESTIMATED_BURST_COST "") | $(compare_metric_value active-pressure ESTIMATED_BURST_COST "") |
EOF

  cat > "${COMPARE_JSON_REPORT_PATH}" <<EOF
{
  "generated_at": $(json_escape "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"),
  "profile": $(json_escape "${EVALUATION_PROFILE}"),
  "running": {
    "report_path": $(json_escape "$(get_policy_snapshot_value running REPORT_PATH)"),
    "json_report_path": $(json_escape "$(get_policy_snapshot_value running JSON_REPORT_PATH)"),
    "hpa_metric_name": $(json_escape "$(get_policy_snapshot_value running HPA_METRIC_NAME)"),
    "hpa_target_average_value": $(json_escape "$(get_policy_snapshot_value running HPA_TARGET_AVERAGE_VALUE)"),
    "metrics": {
      "p95_request_latency_seconds": $(json_nullable_number "$(get_policy_snapshot_value running P95_REQUEST_LATENCY_SECONDS)"),
      "p95_ttft_seconds": $(json_nullable_number "$(get_policy_snapshot_value running P95_TTFT_SECONDS)"),
      "peak_waiting_requests": $(json_nullable_number "$(get_policy_snapshot_value running PEAK_WAITING_REQUESTS)"),
      "peak_active_requests": $(json_nullable_number "$(get_policy_snapshot_value running PEAK_ACTIVE_REQUESTS)"),
      "average_gpu_utilization_percent": $(json_nullable_number "$(get_policy_snapshot_value running AVG_GPU_UTILIZATION_PERCENT)"),
      "max_gpu_utilization_percent": $(json_nullable_number "$(get_policy_snapshot_value running MAX_GPU_UTILIZATION_PERCENT)"),
      "peak_active_nodeclaims": $(json_nullable_number "$(get_policy_snapshot_value running PEAK_ACTIVE_NODECLAIMS)"),
      "second_ready_seconds": $(json_nullable_number "$(get_policy_snapshot_value running SECOND_READY_SECONDS)"),
      "estimated_burst_cost": $(json_nullable_number "$(get_policy_snapshot_value running ESTIMATED_BURST_COST)")
    }
  },
  "active_pressure": {
    "report_path": $(json_escape "$(get_policy_snapshot_value active-pressure REPORT_PATH)"),
    "json_report_path": $(json_escape "$(get_policy_snapshot_value active-pressure JSON_REPORT_PATH)"),
    "hpa_metric_name": $(json_escape "$(get_policy_snapshot_value active-pressure HPA_METRIC_NAME)"),
    "hpa_target_average_value": $(json_escape "$(get_policy_snapshot_value active-pressure HPA_TARGET_AVERAGE_VALUE)"),
    "metrics": {
      "p95_request_latency_seconds": $(json_nullable_number "$(get_policy_snapshot_value active-pressure P95_REQUEST_LATENCY_SECONDS)"),
      "p95_ttft_seconds": $(json_nullable_number "$(get_policy_snapshot_value active-pressure P95_TTFT_SECONDS)"),
      "peak_waiting_requests": $(json_nullable_number "$(get_policy_snapshot_value active-pressure PEAK_WAITING_REQUESTS)"),
      "peak_active_requests": $(json_nullable_number "$(get_policy_snapshot_value active-pressure PEAK_ACTIVE_REQUESTS)"),
      "average_gpu_utilization_percent": $(json_nullable_number "$(get_policy_snapshot_value active-pressure AVG_GPU_UTILIZATION_PERCENT)"),
      "max_gpu_utilization_percent": $(json_nullable_number "$(get_policy_snapshot_value active-pressure MAX_GPU_UTILIZATION_PERCENT)"),
      "peak_active_nodeclaims": $(json_nullable_number "$(get_policy_snapshot_value active-pressure PEAK_ACTIVE_NODECLAIMS)"),
      "second_ready_seconds": $(json_nullable_number "$(get_policy_snapshot_value active-pressure SECOND_READY_SECONDS)"),
      "estimated_burst_cost": $(json_nullable_number "$(get_policy_snapshot_value active-pressure ESTIMATED_BURST_COST)")
    }
  }
}
EOF
}

collect_metrics_and_write_reports() {
  collect_production_metrics || return 1
  push_summary_metrics || true
  write_reports
}

run_single_policy_evaluation() {
  local policy=$1

  reset_policy_measurements
  set_policy_context "${policy}"

  if is_compare_mode && is_warm_profile && [[ "${CURRENT_POLICY}" == "running" ]]; then
    PRESERVE_PROFILE_BASELINE=1
  fi

  set_failure_hints \
    "command -v kubectl curl awk" \
    "kubectl config current-context" \
    "kubectl get apiservice ${PROMETHEUS_ADAPTER_APISERVICE_NAME}"
  run_stage 1 "${TOTAL_STAGES}" "$(policy_stage_label "checking prerequisites")" evaluate_prereqs

  set_failure_hints \
    "kubectl get ingress,service -n ${APP_NAMESPACE}" \
    "kubectl get apiservice ${PROMETHEUS_ADAPTER_APISERVICE_NAME} -o yaml" \
    "kubectl get deployment,pods -n ${APP_NAMESPACE} -l app=${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME}" \
    "kubectl get nodeclaims,nodes -o wide" \
    "kubectl logs -n ${KARPENTER_NAMESPACE} deployment/karpenter --since=10m"
  run_stage 2 "${TOTAL_STAGES}" "$(policy_stage_label "prepare evaluation edge and profile")" prepare_edge_and_profile

  set_failure_hints \
    "kubectl get deployment,hpa -n ${APP_NAMESPACE}" \
    "kubectl describe hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE}" \
    "kubectl get pods -n ${APP_NAMESPACE}"
  run_stage 3 "${TOTAL_STAGES}" "$(policy_stage_label "apply inference deployment")" apply_inference_stack

  set_failure_hints \
    "kubectl get pods -n ${APP_NAMESPACE} -o wide" \
    "kubectl get nodeclaims" \
    "kubectl logs -n ${APP_NAMESPACE} deployment/${GPU_INFERENCE_DEPLOYMENT_NAME} --tail=100"
  run_stage 4 "${TOTAL_STAGES}" "$(policy_stage_label "wait for first ready replica and first public response")" wait_for_first_ready_and_response

  set_failure_hints \
    "kubectl get deployment,pods -n ${APP_NAMESPACE}" \
    "kubectl get --raw /apis/custom.metrics.k8s.io/v1beta1/namespaces/${APP_NAMESPACE}/pods/${FIRST_POD_NAME:-<pod-name>}/${CURRENT_HPA_METRIC_NAME}" \
    "kubectl logs -n ${APP_NAMESPACE} deployment/${GPU_INFERENCE_DEPLOYMENT_NAME} --tail=100" \
    "kubectl port-forward -n ${MONITORING_NAMESPACE} service/${KUBE_PROMETHEUS_STACK_PROMETHEUS_SERVICE} 9090:9090"
  run_stage 5 "${TOTAL_STAGES}" "$(policy_stage_label "wait for hpa metric pipeline and apply hpa")" wait_for_hpa_metric_pipeline

  set_failure_hints \
    "kubectl get --raw /apis/custom.metrics.k8s.io/v1beta1/namespaces/${APP_NAMESPACE}/pods/${FIRST_POD_NAME:-<pod-name>}/${CURRENT_HPA_METRIC_NAME}" \
    "kubectl describe hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE}" \
    "kubectl port-forward -n ${MONITORING_NAMESPACE} service/${KUBE_PROMETHEUS_STACK_PROMETHEUS_SERVICE} 9090:9090" \
    "kubectl get nodeclaims,nodes" \
    "kubectl logs -n ${APP_NAMESPACE} job/${GPU_LOAD_TEST_JOB_NAME} --tail=100"
  run_stage 6 "${TOTAL_STAGES}" "$(policy_stage_label "run load and wait for scale-out")" run_load_and_wait_for_scale_out

  set_failure_hints \
    "kubectl get job ${GPU_LOAD_TEST_JOB_NAME} -n ${APP_NAMESPACE} -o yaml" \
    "kubectl logs -n ${APP_NAMESPACE} job/${GPU_LOAD_TEST_JOB_NAME}" \
    "kubectl get hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE} -o yaml"
  run_stage 7 "${TOTAL_STAGES}" "$(policy_stage_label "wait for the burst to complete")" wait_for_burst_completion

  set_failure_hints \
    "kubectl get hpa ${GPU_INFERENCE_HPA_NAME} -n ${APP_NAMESPACE}" \
    "kubectl get deployment ${GPU_INFERENCE_DEPLOYMENT_NAME} -n ${APP_NAMESPACE} -o yaml" \
    "kubectl get nodes -L workload,node.kubernetes.io/instance-type"
  run_stage 8 "${TOTAL_STAGES}" "$(policy_stage_label "remove load and wait for scale-in")" remove_load_and_wait_for_scale_in

  set_failure_hints \
    "kubectl get deployment,hpa -n ${APP_NAMESPACE}" \
    "kubectl get deployment ${GPU_WARM_PLACEHOLDER_DEPLOYMENT_NAME} -n ${APP_NAMESPACE}" \
    "kubectl get nodes -L workload,node.kubernetes.io/instance-type"
  run_stage 9 "${TOTAL_STAGES}" "$(policy_stage_label "delete inference workload and clean profile capacity")" delete_inference_and_clean_profile_capacity

  set_failure_hints \
    "kubectl get svc -n ${MONITORING_NAMESPACE}" \
    "kubectl get pods -n ${MONITORING_NAMESPACE}" \
    "kubectl get podmonitor,servicemonitor -n ${MONITORING_NAMESPACE}"
  run_stage 10 "${TOTAL_STAGES}" "$(policy_stage_label "collect metrics and write reports")" collect_metrics_and_write_reports
}

print_single_policy_summary() {
  printf '\nEvaluated:\n'
  printf '  Profile: %s\n' "${EVALUATION_PROFILE}"
  printf '  Policy: %s\n' "${CURRENT_POLICY}"
  printf '  HPA metric: %s\n' "${CURRENT_HPA_METRIC_NAME}"
  printf '  HPA target average value: %s\n' "${CURRENT_HPA_TARGET_AVERAGE_VALUE}"
  printf '  First GPU capacity type: %s\n' "${FIRST_GPU_CAPACITY_TYPE:-n/a}"
  printf '  Second GPU capacity type: %s\n' "${SECOND_GPU_CAPACITY_TYPE:-n/a}"
  printf '  First public response: %s\n' "$(display_duration "$(seconds_since_start "${FIRST_RESPONSE_TIME}")")"
  printf '  Second ready replica: %s\n' "$(display_duration "$(seconds_since_start "${SECOND_READY_TIME}")")"
  printf '  p95 request latency: %s\n' "$(display_metric "${P95_REQUEST_LATENCY_SECONDS}" "s")"
  printf '  Peak waiting requests: %s\n' "$(display_metric "${PEAK_WAITING_REQUESTS}")"
  printf '  Peak active requests: %s\n' "$(display_metric "${PEAK_ACTIVE_REQUESTS}")"
  printf '  Average GPU utilization: %s\n' "$(display_metric "${AVG_GPU_UTILIZATION_PERCENT}" "%")"
  printf '  Markdown report: %s\n' "${REPORT_PATH}"
  printf '  JSON report: %s\n' "${JSON_REPORT_PATH}"
}

print_compare_summary() {
  printf '\nCompared:\n'
  printf '  Profile: %s\n' "${EVALUATION_PROFILE}"
  printf '  Running report: %s\n' "$(get_policy_snapshot_value running REPORT_PATH)"
  printf '  Active-pressure report: %s\n' "$(get_policy_snapshot_value active-pressure REPORT_PATH)"
  printf '  Compare report: %s\n' "${COMPARE_REPORT_PATH}"
  printf '  Compare JSON report: %s\n' "${COMPARE_JSON_REPORT_PATH}"
}

main() {
  parse_args "$@"
  trap cleanup_evaluate EXIT

  if is_compare_mode; then
    COMPARE_REPORT_PATH=$(resolve_compare_report_path)
    COMPARE_JSON_REPORT_PATH=$(resolve_compare_json_report_path)

    run_single_policy_evaluation running
    capture_compare_policy_result running

    run_single_policy_evaluation active-pressure
    capture_compare_policy_result active-pressure

    write_compare_reports
    print_compare_summary
    return 0
  fi

  run_single_policy_evaluation "${EVALUATION_POLICY}"
  print_single_policy_summary
}

main "$@"
