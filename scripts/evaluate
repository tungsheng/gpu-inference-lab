compare_duration_value() {
  display_duration "$(get_policy_snapshot_value "$1" "$2")"
}

compare_metric_value() {
  display_metric "$(get_policy_snapshot_value "$1" "$2")" "$3"
}

decimal_less_than() {
  local left_value=${1:-}
  local right_value=${2:-}

  if [[ -z "${left_value}" || -z "${right_value}" ]]; then
    return 1
  fi

  awk -v left="${left_value}" -v right="${right_value}" 'BEGIN { exit !(left < right) }'
}

sweep_target_snapshot_key() {
  printf 'TARGET_%s\n' "$1"
}

set_sweep_target_value() {
  local target=$1
  local field=$2
  local value=${3-}
  local variable_name

  variable_name="SWEEP_$(sweep_target_snapshot_key "${target}")_${field}"
  printf -v "${variable_name}" '%s' "${value}"
}

get_sweep_target_value() {
  local target=$1
  local field=$2
  local variable_name

  variable_name="SWEEP_$(sweep_target_snapshot_key "${target}")_${field}"
  printf '%s\n' "${!variable_name:-}"
}

sweep_target_status() {
  local target=$1
  local queue_wait_seconds=${2:-}
  local ttft_seconds=${3:-}
  local waiting_requests=${4:-}
  local average_gpu_utilization=${5:-}
  local max_gpu_utilization=${6:-}

  capacity_assessment_status \
    "${target}" \
    "${queue_wait_seconds}" \
    "${ttft_seconds}" \
    "${waiting_requests}" \
    "${average_gpu_utilization}" \
    "${max_gpu_utilization}"
}

sweep_target_score() {
  local target=$1
  local latency_seconds=${2:-}
  local queue_wait_seconds=${3:-}
  local ttft_seconds=${4:-}
  local waiting_requests=${5:-}
  local active_requests_per_gpu_node=${6:-}
  local average_gpu_utilization=${7:-}
  local max_gpu_utilization=${8:-}
  local burst_cost=${9:-}

  awk \
    -v target="${target}" \
    -v latency="${latency_seconds}" \
    -v queue_wait="${queue_wait_seconds}" \
    -v ttft="${ttft_seconds}" \
    -v waiting="${waiting_requests}" \
    -v per_gpu="${active_requests_per_gpu_node}" \
    -v average_gpu="${average_gpu_utilization}" \
    -v max_gpu="${max_gpu_utilization}" \
    -v burst_cost="${burst_cost}" '
    BEGIN {
      score = 0

      if (latency == "") {
        score += 100000
      } else {
        score += (latency + 0) * 100
      }

      if (queue_wait == "") {
        score += 100000
      } else {
        score += (queue_wait + 0) * 140
      }

      if (ttft == "") {
        score += 100000
      } else {
        score += (ttft + 0) * 60
      }

      if (waiting == "") {
        score += 100000
      } else {
        score += (waiting + 0) * 4
        if ((waiting + 0) > (target + 0)) {
          score += ((waiting + 0) - (target + 0)) * 8
        }
      }

      if (average_gpu == "") {
        score += 100000
      } else if ((average_gpu + 0) < 55) {
        score += (55 - (average_gpu + 0)) * 0.8
      }

      if (per_gpu == "") {
        score += 100000
      } else {
        score -= (per_gpu + 0) * 0.5
      }

      if (max_gpu == "") {
        score += 100000
      } else if ((max_gpu + 0) > 95) {
        score += ((max_gpu + 0) - 95) * 6
      }

      if (burst_cost == "") {
        score += 100000
      } else {
        score += (burst_cost + 0) * 1000
      }

      printf "%.3f\n", score
    }'
}

sweep_target_status_priority() {
  case "$1" in
    balanced)
      printf '3\n'
      ;;
    underutilized)
      printf '2\n'
      ;;
    saturated)
      printf '1\n'
      ;;
    *)
      printf '0\n'
      ;;
  esac
}

capture_sweep_target_result() {
  local target=$1
  local status
  local reason
  local score

  status=$(sweep_target_status \
    "${target}" \
    "${P95_ESTIMATED_QUEUE_WAIT_SECONDS}" \
    "${P95_TTFT_SECONDS}" \
    "${PEAK_WAITING_REQUESTS}" \
    "${AVG_GPU_UTILIZATION_PERCENT}" \
    "${MAX_GPU_UTILIZATION_PERCENT}")
  reason=$(capacity_assessment_reason \
    "${target}" \
    "${status}" \
    "${P95_ESTIMATED_QUEUE_WAIT_SECONDS}" \
    "${P95_TTFT_SECONDS}" \
    "${PEAK_WAITING_REQUESTS}" \
    "${AVG_GPU_UTILIZATION_PERCENT}" \
    "${MAX_GPU_UTILIZATION_PERCENT}")
  score=$(sweep_target_score \
    "${target}" \
    "${P95_REQUEST_LATENCY_SECONDS}" \
    "${P95_ESTIMATED_QUEUE_WAIT_SECONDS}" \
    "${P95_TTFT_SECONDS}" \
    "${PEAK_WAITING_REQUESTS}" \
    "${PEAK_ACTIVE_REQUESTS_PER_GPU_NODE}" \
    "${AVG_GPU_UTILIZATION_PERCENT}" \
    "${MAX_GPU_UTILIZATION_PERCENT}" \
    "${ESTIMATED_BURST_COST}")

  set_sweep_target_value "${target}" REPORT_PATH "${REPORT_PATH}"
  set_sweep_target_value "${target}" JSON_REPORT_PATH "${JSON_REPORT_PATH}"
  set_sweep_target_value "${target}" HPA_METRIC_NAME "${CURRENT_HPA_METRIC_NAME}"
  set_sweep_target_value "${target}" HPA_TARGET_AVERAGE_VALUE "${CURRENT_HPA_TARGET_AVERAGE_VALUE}"
  set_sweep_target_value "${target}" METRICS_COLLECTION_STATUS "${METRICS_COLLECTION_STATUS}"
  set_sweep_target_value "${target}" METRICS_COLLECTION_REASON "${METRICS_COLLECTION_REASON}"
  set_sweep_target_value "${target}" P95_REQUEST_LATENCY_SECONDS "${P95_REQUEST_LATENCY_SECONDS}"
  set_sweep_target_value "${target}" P95_ESTIMATED_QUEUE_WAIT_SECONDS "${P95_ESTIMATED_QUEUE_WAIT_SECONDS}"
  set_sweep_target_value "${target}" P95_TTFT_SECONDS "${P95_TTFT_SECONDS}"
  set_sweep_target_value "${target}" PEAK_WAITING_REQUESTS "${PEAK_WAITING_REQUESTS}"
  set_sweep_target_value "${target}" PEAK_ACTIVE_REQUESTS "${PEAK_ACTIVE_REQUESTS}"
  set_sweep_target_value "${target}" PEAK_ACTIVE_REQUESTS_PER_GPU_NODE "${PEAK_ACTIVE_REQUESTS_PER_GPU_NODE}"
  set_sweep_target_value "${target}" AVG_COMPLETED_REQUESTS_PER_SECOND "${AVG_COMPLETED_REQUESTS_PER_SECOND}"
  set_sweep_target_value "${target}" AVG_GPU_UTILIZATION_PERCENT "${AVG_GPU_UTILIZATION_PERCENT}"
  set_sweep_target_value "${target}" AVG_GPU_HEADROOM_PERCENT "${AVG_GPU_HEADROOM_PERCENT}"
  set_sweep_target_value "${target}" MAX_GPU_UTILIZATION_PERCENT "${MAX_GPU_UTILIZATION_PERCENT}"
  set_sweep_target_value "${target}" PEAK_ACTIVE_NODECLAIMS "${PEAK_ACTIVE_NODECLAIMS}"
  set_sweep_target_value "${target}" SECOND_READY_SECONDS "$(seconds_since_start "${SECOND_READY_TIME}")"
  set_sweep_target_value "${target}" RECOVERY_READY_SECONDS "$(seconds_since_start "${RECOVERY_READY_TIME}")"
  set_sweep_target_value "${target}" ESTIMATED_BURST_COST "${ESTIMATED_BURST_COST}"
  set_sweep_target_value "${target}" STATUS "${status}"
  set_sweep_target_value "${target}" STATUS_REASON "${reason}"
  set_sweep_target_value "${target}" SCORE "${score}"
}

sweep_metric_value() {
  local target=$1
  local field=$2
  local suffix=${3:-}

  display_metric "$(get_sweep_target_value "${target}" "${field}")" "${suffix}"
}

sweep_duration_value() {
  local target=$1
  local field=$2

  display_duration "$(get_sweep_target_value "${target}" "${field}")"
}

format_active_target_sweep_list() {
  local target
  local formatted=""

  for target in "${ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
    if [[ -n "${formatted}" ]]; then
      formatted="${formatted}, "
    fi
    formatted="${formatted}${target}"
  done

  printf '%s\n' "${formatted}"
}

determine_sweep_recommendation() {
  local target
  local best_target=""
  local best_status=""
  local best_score=""
  local best_priority=-1
  local current_status
  local current_score
  local current_priority

  SWEEP_RECOMMENDED_TARGET=""
  SWEEP_RECOMMENDATION_STATUS=""
  SWEEP_RECOMMENDATION_REASON=""

  for target in "${ACTIVE_TARGET_SWEEP_VALUES[@]}"; do
    current_status=$(get_sweep_target_value "${target}" STATUS)
    current_score=$(get_sweep_target_value "${target}" SCORE)
    current_priority=$(sweep_target_status_priority "${current_status}")

    if [[ -z "${best_target}" ]]; then
      best_target=${target}
      best_status=${current_status}
      best_score=${current_score}
      best_priority=${current_priority}
      continue
    fi

    if (( current_priority > best_priority )); then
      best_target=${target}
      best_status=${current_status}
      best_score=${current_score}
      best_priority=${current_priority}
      continue
    fi

    if (( current_priority < best_priority )); then
      continue
    fi

    if (( current_priority >= 2 )); then
      if (( target > best_target )); then
        best_target=${target}
        best_status=${current_status}
        best_score=${current_score}
        best_priority=${current_priority}
      elif (( target == best_target )) && decimal_less_than "${current_score}" "${best_score}"; then
        best_target=${target}
        best_status=${current_status}
        best_score=${current_score}
        best_priority=${current_priority}
      fi
      continue
    fi

    if decimal_less_than "${current_score}" "${best_score}"; then
      best_target=${target}
      best_status=${current_status}
      best_score=${current_score}
      best_priority=${current_priority}
    elif [[ "${current_score}" == "${best_score}" ]] && (( target < best_target )); then
      best_target=${target}
      best_status=${current_status}
      best_score=${current_score}
      best_priority=${current_priority}
    fi
  done

  SWEEP_RECOMMENDED_TARGET=${best_target}
  SWEEP_RECOMMENDATION_STATUS=${best_status}

  case "${best_status}" in
    balanced)
      SWEEP_RECOMMENDATION_REASON="highest balanced target from the sweep heuristic"
      ;;
    underutilized)
      SWEEP_RECOMMENDATION_REASON="no balanced target found; using the highest underutilized target to increase useful GPU work without current queue pressure"
      ;;
    saturated)
      SWEEP_RECOMMENDATION_REASON="all sweep targets saturated the heuristic, so the lowest-score target is recommended"
      ;;
    *)
      SWEEP_RECOMMENDATION_REASON="the sweep results were incomplete, so the first available target is recommended"
      ;;
  esac
}

write_compare_reports() {
  mkdir -p "$(dirname "${COMPARE_REPORT_PATH}")"
  mkdir -p "$(dirname "${COMPARE_JSON_REPORT_PATH}")"

  cat > "${COMPARE_REPORT_PATH}" <<EOF
# Capacity-Aware Autoscaling Compare Report

- Generated at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
- Profile: ${EVALUATION_PROFILE}
- Resilience mode: ${EVALUATION_RESILIENCE}
- Running report: $(get_policy_snapshot_value running REPORT_PATH)
- Active-pressure report: $(get_policy_snapshot_value active-pressure REPORT_PATH)

## Policy Settings

| Policy | HPA metric name | HPA target average value |
| --- | --- | --- |
| running | $(get_policy_snapshot_value running HPA_METRIC_NAME) | $(get_policy_snapshot_value running HPA_TARGET_AVERAGE_VALUE) |
| active-pressure | $(get_policy_snapshot_value active-pressure HPA_METRIC_NAME) | $(get_policy_snapshot_value active-pressure HPA_TARGET_AVERAGE_VALUE) |

## Collection Status

| Policy | Metrics collection status | Note |
| --- | --- | --- |
| running | $(get_policy_snapshot_value running METRICS_COLLECTION_STATUS) | $(display_metric "$(get_policy_snapshot_value running METRICS_COLLECTION_REASON)") |
| active-pressure | $(get_policy_snapshot_value active-pressure METRICS_COLLECTION_STATUS) | $(display_metric "$(get_policy_snapshot_value active-pressure METRICS_COLLECTION_REASON)") |

## Side-By-Side Metrics

| Metric | running | active-pressure |
| --- | --- | --- |
| p95 request latency | $(compare_metric_value running P95_REQUEST_LATENCY_SECONDS "s") | $(compare_metric_value active-pressure P95_REQUEST_LATENCY_SECONDS "s") |
| p95 estimated queue wait | $(compare_metric_value running P95_ESTIMATED_QUEUE_WAIT_SECONDS "s") | $(compare_metric_value active-pressure P95_ESTIMATED_QUEUE_WAIT_SECONDS "s") |
| p95 TTFT | $(compare_metric_value running P95_TTFT_SECONDS "s") | $(compare_metric_value active-pressure P95_TTFT_SECONDS "s") |
| Peak waiting requests | $(compare_metric_value running PEAK_WAITING_REQUESTS "") | $(compare_metric_value active-pressure PEAK_WAITING_REQUESTS "") |
| Peak active requests | $(compare_metric_value running PEAK_ACTIVE_REQUESTS "") | $(compare_metric_value active-pressure PEAK_ACTIVE_REQUESTS "") |
| Peak active requests per GPU node | $(compare_metric_value running PEAK_ACTIVE_REQUESTS_PER_GPU_NODE "") | $(compare_metric_value active-pressure PEAK_ACTIVE_REQUESTS_PER_GPU_NODE "") |
| Average completed requests per second | $(compare_metric_value running AVG_COMPLETED_REQUESTS_PER_SECOND "") | $(compare_metric_value active-pressure AVG_COMPLETED_REQUESTS_PER_SECOND "") |
| Average GPU utilization | $(compare_metric_value running AVG_GPU_UTILIZATION_PERCENT "%") | $(compare_metric_value active-pressure AVG_GPU_UTILIZATION_PERCENT "%") |
| Average GPU headroom | $(compare_metric_value running AVG_GPU_HEADROOM_PERCENT "%") | $(compare_metric_value active-pressure AVG_GPU_HEADROOM_PERCENT "%") |
| Max GPU utilization | $(compare_metric_value running MAX_GPU_UTILIZATION_PERCENT "%") | $(compare_metric_value active-pressure MAX_GPU_UTILIZATION_PERCENT "%") |
| Peak active NodeClaims | $(compare_metric_value running PEAK_ACTIVE_NODECLAIMS "") | $(compare_metric_value active-pressure PEAK_ACTIVE_NODECLAIMS "") |
| Second ready replica | $(compare_duration_value running SECOND_READY_SECONDS) | $(compare_duration_value active-pressure SECOND_READY_SECONDS) |
| Recovery ready after interruption | $(compare_duration_value running RECOVERY_READY_SECONDS) | $(compare_duration_value active-pressure RECOVERY_READY_SECONDS) |
| Burst cost | $(compare_metric_value running ESTIMATED_BURST_COST "") | $(compare_metric_value active-pressure ESTIMATED_BURST_COST "") |
| Capacity assessment | $(get_policy_snapshot_value running CAPACITY_ASSESSMENT) | $(get_policy_snapshot_value active-pressure CAPACITY_ASSESSMENT) |
| Resilience outcome | $(get_policy_snapshot_value running RESILIENCE_OUTCOME) | $(get_policy_snapshot_value active-pressure RESILIENCE_OUTCOME) |

## Interpretation

- running: $(get_policy_snapshot_value running CAPACITY_ASSESSMENT_REASON)
- active-pressure: $(get_policy_snapshot_value active-pressure CAPACITY_ASSESSMENT_REASON)
EOF

  cat > "${COMPARE_JSON_REPORT_PATH}" <<EOF
