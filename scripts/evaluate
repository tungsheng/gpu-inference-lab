  [[ "${EVALUATION_RESILIENCE}" == "spot-interruption" ]]
}

is_compare_mode() {
  [[ "${EVALUATION_POLICY}" == "compare" ]]
}

is_sweep_mode() {
  [[ "${EVALUATION_POLICY}" == "sweep" ]]
}

is_multi_run_mode() {
  is_compare_mode || is_sweep_mode
}

is_active_pressure_policy() {
  [[ "${CURRENT_POLICY}" == "active-pressure" ]]
}

policy_stage_label() {
  local label=$1

  if [[ -z "${CURRENT_STAGE_PREFIX}" ]]; then
    printf '%s\n' "${label}"
    return 0
  fi

  printf '%s: %s\n' "${CURRENT_STAGE_PREFIX}" "${label}"
}

