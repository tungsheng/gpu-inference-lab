}

policy_snapshot_key() {
  local policy=$1
  local policy_key

  policy_key=${policy//-/_}
  printf '%s\n' "${policy_key}" | tr '[:lower:]' '[:upper:]'
}

set_policy_snapshot_value() {
  local policy=$1
  local field=$2
  local value=${3-}
  local variable_name

  variable_name="COMPARE_$(policy_snapshot_key "${policy}")_${field}"
  printf -v "${variable_name}" '%s' "${value}"
}

get_policy_snapshot_value() {
  local policy=$1
  local field=$2
  local variable_name

  variable_name="COMPARE_$(policy_snapshot_key "${policy}")_${field}"
  printf '%s\n' "${!variable_name:-}"
}

capture_compare_policy_result() {
  local policy=$1

  set_policy_snapshot_value "${policy}" REPORT_PATH "${REPORT_PATH}"
  set_policy_snapshot_value "${policy}" JSON_REPORT_PATH "${JSON_REPORT_PATH}"
  set_policy_snapshot_value "${policy}" HPA_METRIC_NAME "${CURRENT_HPA_METRIC_NAME}"
  set_policy_snapshot_value "${policy}" HPA_TARGET_AVERAGE_VALUE "${CURRENT_HPA_TARGET_AVERAGE_VALUE}"
  set_policy_snapshot_value "${policy}" P95_REQUEST_LATENCY_SECONDS "${P95_REQUEST_LATENCY_SECONDS}"
  set_policy_snapshot_value "${policy}" P95_TTFT_SECONDS "${P95_TTFT_SECONDS}"
  set_policy_snapshot_value "${policy}" PEAK_WAITING_REQUESTS "${PEAK_WAITING_REQUESTS}"
  set_policy_snapshot_value "${policy}" PEAK_ACTIVE_REQUESTS "${PEAK_ACTIVE_REQUESTS}"
  set_policy_snapshot_value "${policy}" AVG_GPU_UTILIZATION_PERCENT "${AVG_GPU_UTILIZATION_PERCENT}"
  set_policy_snapshot_value "${policy}" MAX_GPU_UTILIZATION_PERCENT "${MAX_GPU_UTILIZATION_PERCENT}"
  set_policy_snapshot_value "${policy}" PEAK_ACTIVE_NODECLAIMS "${PEAK_ACTIVE_NODECLAIMS}"
  set_policy_snapshot_value "${policy}" SECOND_READY_SECONDS "$(seconds_since_start "${SECOND_READY_TIME}")"
  set_policy_snapshot_value "${policy}" ESTIMATED_BURST_COST "${ESTIMATED_BURST_COST}"
}

compare_duration_value() {
  display_duration "$(get_policy_snapshot_value "$1" "$2")"
}

compare_metric_value() {
  display_metric "$(get_policy_snapshot_value "$1" "$2")" "$3"
}

write_compare_reports() {
  mkdir -p "$(dirname "${COMPARE_REPORT_PATH}")"
  mkdir -p "$(dirname "${COMPARE_JSON_REPORT_PATH}")"

  cat > "${COMPARE_REPORT_PATH}" <<EOF
# Capacity-Aware Autoscaling Compare Report

- Generated at: $(date -u +"%Y-%m-%dT%H:%M:%SZ")
- Profile: ${EVALUATION_PROFILE}
- Running report: $(get_policy_snapshot_value running REPORT_PATH)
- Active-pressure report: $(get_policy_snapshot_value active-pressure REPORT_PATH)

## Policy Settings

| Policy | HPA metric name | HPA target average value |
| --- | --- | --- |
| running | $(get_policy_snapshot_value running HPA_METRIC_NAME) | $(get_policy_snapshot_value running HPA_TARGET_AVERAGE_VALUE) |
| active-pressure | $(get_policy_snapshot_value active-pressure HPA_METRIC_NAME) | $(get_policy_snapshot_value active-pressure HPA_TARGET_AVERAGE_VALUE) |

## Side-By-Side Metrics

| Metric | running | active-pressure |
