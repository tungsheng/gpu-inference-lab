render_serving_command() {
  local experiment_name=""
  local profile_id=""
  local output_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --experiment)
        experiment_name=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --profile)
        profile_id=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --output)
        output_path=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unexpected argument: $1"
        ;;
    esac
  done

  if [[ -z "${experiment_name}" ]]; then
    die "render-serving requires --experiment"
  fi

  if [[ -z "${profile_id}" ]]; then
    die "render-serving requires --profile"
  fi

  if [[ -n "${output_path}" ]]; then
    render_serving_manifest "${experiment_name}" "${profile_id}" > "${output_path}"
    printf 'Rendered serving manifest: %s\n' "${output_path}"
  else
    render_serving_manifest "${experiment_name}" "${profile_id}"
  fi
}

main() {
  local command=${1-}

  case "${command}" in
    list)
      shift
      if [[ $# -ne 0 ]]; then
        die "list does not accept arguments"
      fi
      list_experiments
      ;;
    validate)
      shift
      validate_command "$@"
      ;;
    show)
      shift
      if [[ $# -ne 1 ]]; then
        die "show requires exactly one experiment name"
      fi
      show_experiment "$1"
      ;;
    render-load)
      shift
      render_load_command "$@"
      ;;
    render-stream)
      shift
      render_stream_command "$@"
      ;;
    render-serving)
      shift
      render_serving_command "$@"
      ;;
    render-report)
      shift
      render_report_command "$@"
      ;;
    run)
      shift
      run_command "$@"
      ;;
    run-stream)
      shift
      run_stream_command "$@"
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      die "Unknown command: ${command}"
      ;;
  esac
}

main "$@"
