#!/usr/bin/env bash

set -Eeuo pipefail

SCRIPT_DIR=$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/_common.sh"

EXPERIMENTS_DIR="${REPO_ROOT}/experiments"
REPORTS_DIR="${EXPERIMENT_REPORTS_DIR:-${REPO_ROOT}/docs/reports}"
SERVING_DEFAULTS_PATH="${EXPERIMENT_SERVING_DEFAULTS_PATH:-${EXPERIMENTS_DIR}/_profiles/serving-defaults.csv}"
TEMPLATES_DIR="${SCRIPT_DIR}/templates"
LOAD_CLIENT_TEMPLATE="${TEMPLATES_DIR}/experiment-load-test.js.tpl"
STREAM_CLIENT_TEMPLATE="${TEMPLATES_DIR}/experiment-stream-client.py.tpl"

usage() {
  cat <<EOF
Usage:
  ./scripts/experiment list
  ./scripts/experiment validate
  ./scripts/experiment show <experiment>
  ./scripts/experiment render-load --experiment name --case case-id [--output path]
  ./scripts/experiment render-stream --experiment name --case case-id [--samples count] [--output path]
  ./scripts/experiment render-serving --experiment name --profile profile-id [--output path]
  ./scripts/experiment render-report --experiment name --case case-id --profile profile-id [--report path] [--json-report path]
  ./scripts/experiment run --experiment name --case case-id --profile profile-id [--report path] [--json-report path] [--preserve-serving] [--preserve-load]
  ./scripts/experiment run-stream --experiment name --case case-id --profile profile-id [--samples count] [--report path] [--json-report path] [--preserve-serving] [--preserve-load]

Examples:
  ./scripts/experiment list
  ./scripts/experiment validate
  ./scripts/experiment show kv-cache
  ./scripts/experiment render-load --experiment kv-cache --case prompt-512-output-100 --output /tmp/kv-cache-load.yaml
  ./scripts/experiment render-stream --experiment prefill-decode --case prefill-heavy --output /tmp/prefill-stream.yaml
  ./scripts/experiment render-serving --experiment kv-cache --profile long-context --output /tmp/vllm-long-context.yaml
  ./scripts/experiment render-report --experiment kv-cache --case prompt-512-output-100 --profile default
  ./scripts/experiment run --experiment kv-cache --case prompt-512-output-100 --profile default
  ./scripts/experiment run-stream --experiment prefill-decode --case prefill-heavy --profile default
EOF
}

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

require_option_value() {
  local option_name=$1
  local option_value=${2-}

  if [[ -z "${option_value}" || "${option_value}" == -* ]]; then
    die "${option_name} requires a value"
  fi

  printf '%s\n' "${option_value}"
}

require_name() {
  local value=$1
  local label=$2

  if [[ ! "${value}" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    die "Invalid ${label}: ${value}"
  fi
}

experiment_dir() {
  local experiment_name=$1
  printf '%s/%s\n' "${EXPERIMENTS_DIR}" "${experiment_name}"
}

experiment_metadata_path() {
  local experiment_name=$1
  printf '%s/experiment.yaml\n' "$(experiment_dir "${experiment_name}")"
}

experiment_cases_path() {
  local experiment_name=$1
  printf '%s/cases.csv\n' "$(experiment_dir "${experiment_name}")"
}

experiment_serving_profiles_path() {
  local experiment_name=$1
  printf '%s/serving-profiles.csv\n' "$(experiment_dir "${experiment_name}")"
}

experiment_request_shapes_path() {
  local experiment_name=$1
  printf '%s/request-shapes.csv\n' "$(experiment_dir "${experiment_name}")"
}

experiment_client_policies_path() {
  local experiment_name=$1
  printf '%s/client-policies.csv\n' "$(experiment_dir "${experiment_name}")"
}

experiment_cost_profiles_path() {
  local experiment_name=$1
  printf '%s/cost-profiles.csv\n' "$(experiment_dir "${experiment_name}")"
}

require_experiment() {
  local experiment_name=$1
  local metadata_path
  local cases_path

  require_name "${experiment_name}" "experiment name"

  metadata_path=$(experiment_metadata_path "${experiment_name}")
  cases_path=$(experiment_cases_path "${experiment_name}")

  if [[ ! -f "${metadata_path}" ]]; then
    die "Unknown experiment: ${experiment_name}"
  fi

  if [[ ! -f "${cases_path}" ]]; then
    die "Experiment ${experiment_name} is missing cases.csv"
  fi
}

experiment_title() {
  local experiment_name=$1
  local metadata_path

  metadata_path=$(experiment_metadata_path "${experiment_name}")
  awk -F': ' '/^title:/ { print $2; found=1; exit } END { if (!found) print "" }' "${metadata_path}"
}

list_experiments() {
  local experiment_path
  local experiment_name
  local title

  if [[ ! -d "${EXPERIMENTS_DIR}" ]]; then
    return 0
  fi

  find "${EXPERIMENTS_DIR}" -mindepth 1 -maxdepth 1 -type d ! -name '_templates' | sort | while read -r experiment_path; do
    experiment_name=$(basename "${experiment_path}")
    if [[ -f "${experiment_path}/experiment.yaml" ]]; then
      title=$(experiment_title "${experiment_name}")
      printf '%-18s %s\n' "${experiment_name}" "${title}"
    fi
  done
}

show_experiment() {
  local experiment_name=$1
  local metadata_path
  local cases_path
  local serving_profiles_path
  local request_shapes_path
  local client_policies_path
  local cost_profiles_path
  local row_profile_id
  local _row_rest
  local scheduler

  require_experiment "${experiment_name}"

  metadata_path=$(experiment_metadata_path "${experiment_name}")
  cases_path=$(experiment_cases_path "${experiment_name}")
  serving_profiles_path=$(experiment_serving_profiles_path "${experiment_name}")
  request_shapes_path=$(experiment_request_shapes_path "${experiment_name}")
  client_policies_path=$(experiment_client_policies_path "${experiment_name}")
  cost_profiles_path=$(experiment_cost_profiles_path "${experiment_name}")

  printf 'Experiment: %s\n' "${experiment_name}"
  printf 'Title: %s\n' "$(experiment_title "${experiment_name}")"
  printf 'Metadata: %s\n' "${metadata_path}"
  printf 'Cases:\n'

  awk -F',' '
    NR == 1 { next }
    NF > 0 && $1 !~ /^#/ {
      printf "  - %s: prompt=%s output=%s target_rate=%s req/s\n", $1, $2, $3, $5
    }
  ' "${cases_path}"

  if [[ -f "${request_shapes_path}" ]]; then
    printf 'Request shapes:\n'
    awk -F',' '
      NR == 1 { next }
      NF > 0 && $1 !~ /^#/ {
        printf "  - %s/%s: prompt=%s output=%s weight=%s\n", $1, $2, $3, $4, $5
      }
    ' "${request_shapes_path}"
  fi

  if [[ -f "${client_policies_path}" ]]; then
    printf 'Client policies:\n'
    awk -F',' '
      NR == 1 { next }
      NF > 0 && $1 !~ /^#/ {
        printf "  - %s/%s: mode=%s executor=%s buffer_capacity=%s max_queue_wait=%ss\n", $1, $2, $3, $4, $5, $6
      }
    ' "${client_policies_path}"
  fi

  if [[ -f "${cost_profiles_path}" ]]; then
    printf 'Cost profiles:\n'
    awk -F',' '
      NR == 1 { next }
      NF > 0 && $1 !~ /^#/ {
        printf "  - %s: hourly_cost=%s scope=%s p95_slo=%ss p99_slo=%ss\n", $1, $2, $3, $4, $5
      }
    ' "${cost_profiles_path}"
  fi

  if [[ -f "${serving_profiles_path}" ]]; then
    printf 'Serving profiles:\n'
    while IFS=',' read -r row_profile_id _row_rest; do
      if [[ -z "${row_profile_id}" || "${row_profile_id}" == "profile_id" || "${row_profile_id}" == \#* ]]; then
        continue
      fi

      load_serving_profile "${experiment_name}" "${row_profile_id}"
      scheduler="default"
      if [[ -n "${MAX_NUM_SEQS}" || -n "${MAX_NUM_BATCHED_TOKENS}" ]]; then
        scheduler="max_num_seqs=${MAX_NUM_SEQS} max_num_batched_tokens=${MAX_NUM_BATCHED_TOKENS}"
      fi

      printf "  - %s: model=%s served=%s max_model_len=%s gpu_memory=%s scheduler=%s\n" \
        "${PROFILE_ID}" "${MODEL}" "${SERVED_MODEL_NAME}" "${MAX_MODEL_LEN}" "${GPU_MEMORY_UTILIZATION}" "${scheduler}"
    done < "${serving_profiles_path}"
  fi
}

require_positive_integer() {
  local value=$1
  local label=$2

  if [[ ! "${value}" =~ ^[1-9][0-9]*$ ]]; then
    die "Invalid ${label}: ${value}"
  fi
}

require_non_negative_integer() {
  local value=$1
  local label=$2

  if [[ ! "${value}" =~ ^[0-9]+$ ]]; then
    die "Invalid ${label}: ${value}"
  fi
}

require_rate() {
  local value=$1
  local label=$2

  if [[ ! "${value}" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    die "Invalid ${label}: ${value}"
  fi
}

require_fraction_at_most_one() {
  local value=$1
  local label=$2

  require_rate "${value}" "${label}"
  awk -v value="${value}" 'BEGIN { exit !((value + 0) > 0 && (value + 0) <= 1) }' || die "Invalid ${label}: ${value}"
}

require_duration() {
  local value=$1
  local label=$2

  if [[ ! "${value}" =~ ^[1-9][0-9]*[smh]$ ]]; then
    die "Invalid ${label}: ${value}"
  fi
}

require_safe_text() {
  local value=$1
  local label=$2

  if [[ ! "${value}" =~ ^[A-Za-z0-9._:/+=@-]+$ ]]; then
    die "Invalid ${label}: ${value}"
  fi
}

require_resource_quantity() {
  local value=$1
  local label=$2

  if [[ ! "${value}" =~ ^[0-9]+([.][0-9]+)?(m|Ki|Mi|Gi|Ti)?$ ]]; then
    die "Invalid ${label}: ${value}"
  fi
}

json_optional_integer() {
  local value=${1:-}

  if [[ -z "${value}" ]]; then
    printf 'null'
  else
    printf '%s' "${value}"
  fi
}

json_optional_number() {
  local value=${1:-}

  if [[ -z "${value}" ]]; then
    printf 'null'
  else
    printf '%s' "${value}"
  fi
}

json_optional_string() {
  local value=${1:-}

  if [[ -z "${value}" ]]; then
    printf 'null'
  else
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    printf '"%s"' "${value}"
  fi
}

json_optional_boolean() {
  local value=${1:-}

  case "${value}" in
    true|false)
      printf '%s' "${value}"
      ;;
    "")
      printf 'null'
      ;;
    *)
      die "Invalid boolean value: ${value}"
      ;;
  esac
}

display_optional_metric() {
  local value=${1:-}

  if [[ -z "${value}" ]]; then
    printf 'n/a'
  else
    printf '%s' "${value}"
  fi
}

duration_to_seconds() {
  local value=$1
  local amount
  local unit

  require_duration "${value}" "duration"

  amount=${value%?}
  unit=${value: -1}

  case "${unit}" in
    s)
      printf '%s\n' "${amount}"
      ;;
    m)
      printf '%s\n' "$((amount * 60))"
      ;;
    h)
      printf '%s\n' "$((amount * 3600))"
      ;;
    *)
      die "Invalid duration: ${value}"
      ;;
  esac
}

case_planned_duration_seconds() {
  local ramp_up_seconds
  local steady_seconds
  local ramp_down_seconds

  ramp_up_seconds=$(duration_to_seconds "${RAMP_UP_DURATION}")
  steady_seconds=$(duration_to_seconds "${STEADY_DURATION}")
  ramp_down_seconds=$(duration_to_seconds "${RAMP_DOWN_DURATION}")

  printf '%s\n' "$((ramp_up_seconds + steady_seconds + ramp_down_seconds))"
}

multiply_decimal_values() {
  local left_value=${1:-}
  local right_value=${2:-}
  local precision=${3:-6}

  if [[ -z "${left_value}" || -z "${right_value}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  awk -v left="${left_value}" -v right="${right_value}" -v precision="${precision}" '
    BEGIN {
      format = "%." precision "f\n"
      printf format, (left + 0) * (right + 0)
    }'
}

divide_decimal_values() {
  local numerator=${1:-}
  local denominator=${2:-}
  local precision=${3:-6}

  if [[ -z "${numerator}" || -z "${denominator}" ]]; then
    printf '%s\n' ""
    return 0
  fi

  awk -v numerator="${numerator}" -v denominator="${denominator}" -v precision="${precision}" '
    BEGIN {
      if ((denominator + 0) == 0) {
        exit 1
      }

      format = "%." precision "f\n"
      printf format, (numerator + 0) / (denominator + 0)
    }' 2>/dev/null || printf '%s\n' ""
}

utc_timestamp() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

experiment_job_name() {
  local experiment_name=$1
  local case_id=$2

  printf '%s-%s\n' "${experiment_name}" "${case_id}"
}

stream_job_name() {
  local experiment_name=$1
  local case_id=$2

  printf '%s-%s-stream\n' "${experiment_name}" "${case_id}"
}

load_case() {
  local experiment_name=$1
  local requested_case_id=$2
  local cases_path
  local row_case_id

  require_name "${requested_case_id}" "case id"

  cases_path=$(experiment_cases_path "${experiment_name}")

  while IFS=',' read -r row_case_id PROMPT_TOKEN_TARGET MAX_TOKENS START_RATE TARGET_RATE RAMP_UP_DURATION STEADY_DURATION RAMP_DOWN_DURATION PRE_ALLOCATED_VUS MAX_VUS TIMEOUT_SECONDS _description; do
    if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
      continue
    fi

    if [[ "${row_case_id}" == "${requested_case_id}" ]]; then
      CASE_ID=${row_case_id}
      require_positive_integer "${PROMPT_TOKEN_TARGET}" "prompt token target"
      require_positive_integer "${MAX_TOKENS}" "max tokens"
      require_rate "${START_RATE}" "start rate"
      require_rate "${TARGET_RATE}" "target rate"
      require_duration "${RAMP_UP_DURATION}" "ramp-up duration"
      require_duration "${STEADY_DURATION}" "steady duration"
      require_duration "${RAMP_DOWN_DURATION}" "ramp-down duration"
      require_positive_integer "${PRE_ALLOCATED_VUS}" "pre-allocated VUs"
      require_positive_integer "${MAX_VUS}" "max VUs"
      require_positive_integer "${TIMEOUT_SECONDS}" "timeout seconds"
      return 0
    fi
  done < "${cases_path}"

  die "Unknown case ${requested_case_id} for experiment ${experiment_name}"
}

require_serving_profiles() {
  local experiment_name=$1
  local profiles_path

  require_experiment "${experiment_name}"
  profiles_path=$(experiment_serving_profiles_path "${experiment_name}")
  if [[ ! -f "${profiles_path}" ]]; then
    die "Experiment ${experiment_name} is missing serving-profiles.csv"
  fi
}

validate_loaded_serving_profile() {
  require_safe_text "${MODEL}" "model"
  require_safe_text "${SERVED_MODEL_NAME}" "served model name"
  require_safe_text "${VLLM_IMAGE}" "vLLM image"
  require_positive_integer "${MAX_MODEL_LEN}" "max model length"
  require_fraction_at_most_one "${GPU_MEMORY_UTILIZATION}" "GPU memory utilization"
  if [[ -n "${MAX_NUM_SEQS}" ]]; then
    require_positive_integer "${MAX_NUM_SEQS}" "max num seqs"
  fi
  if [[ -n "${MAX_NUM_BATCHED_TOKENS}" ]]; then
    require_positive_integer "${MAX_NUM_BATCHED_TOKENS}" "max num batched tokens"
  fi
  require_resource_quantity "${CPU_REQUEST}" "CPU request"
  require_resource_quantity "${MEMORY_REQUEST}" "memory request"
  require_resource_quantity "${CPU_LIMIT}" "CPU limit"
  require_resource_quantity "${MEMORY_LIMIT}" "memory limit"
  require_resource_quantity "${MODEL_CACHE_SIZE}" "model cache size"
  require_resource_quantity "${SHM_SIZE}" "shared memory size"
}

load_default_serving_profile() {
  local row_profile_id

  MODEL=""
  SERVED_MODEL_NAME=""
  VLLM_IMAGE=""
  MAX_MODEL_LEN=""
  GPU_MEMORY_UTILIZATION=""
  MAX_NUM_SEQS=""
  MAX_NUM_BATCHED_TOKENS=""
  CPU_REQUEST=""
  MEMORY_REQUEST=""
  CPU_LIMIT=""
  MEMORY_LIMIT=""
  MODEL_CACHE_SIZE=""
  SHM_SIZE=""
  PROFILE_DESCRIPTION=""

  if [[ ! -f "${SERVING_DEFAULTS_PATH}" ]]; then
    die "Missing shared serving defaults: ${SERVING_DEFAULTS_PATH}"
  fi

  while IFS=',' read -r row_profile_id MODEL SERVED_MODEL_NAME VLLM_IMAGE MAX_MODEL_LEN GPU_MEMORY_UTILIZATION MAX_NUM_SEQS MAX_NUM_BATCHED_TOKENS CPU_REQUEST MEMORY_REQUEST CPU_LIMIT MEMORY_LIMIT MODEL_CACHE_SIZE SHM_SIZE PROFILE_DESCRIPTION; do
    if [[ -z "${row_profile_id}" || "${row_profile_id}" == "profile_id" || "${row_profile_id}" == \#* ]]; then
      continue
    fi

    if [[ "${row_profile_id}" == "default" ]]; then
      validate_loaded_serving_profile
      return 0
    fi
  done < "${SERVING_DEFAULTS_PATH}"

  die "Shared serving defaults are missing the default profile"
}

load_serving_profile() {
  local experiment_name=$1
  local requested_profile_id=$2
  local profiles_path
  local row_profile_id
  local row_model
  local row_served_model_name
  local row_vllm_image
  local row_max_model_len
  local row_gpu_memory_utilization
  local row_max_num_seqs
  local row_max_num_batched_tokens
  local row_cpu_request
  local row_memory_request
  local row_cpu_limit
  local row_memory_limit
  local row_model_cache_size
  local row_shm_size
  local row_profile_description

  require_name "${requested_profile_id}" "serving profile id"
  require_serving_profiles "${experiment_name}"
  load_default_serving_profile

  profiles_path=$(experiment_serving_profiles_path "${experiment_name}")

  while IFS=',' read -r row_profile_id row_model row_served_model_name row_vllm_image row_max_model_len row_gpu_memory_utilization row_max_num_seqs row_max_num_batched_tokens row_cpu_request row_memory_request row_cpu_limit row_memory_limit row_model_cache_size row_shm_size row_profile_description; do
    if [[ -z "${row_profile_id}" || "${row_profile_id}" == "profile_id" || "${row_profile_id}" == \#* ]]; then
      continue
    fi

    if [[ "${row_profile_id}" == "${requested_profile_id}" ]]; then
      PROFILE_ID=${row_profile_id}
      MODEL=${row_model:-${MODEL}}
      SERVED_MODEL_NAME=${row_served_model_name:-${SERVED_MODEL_NAME}}
      VLLM_IMAGE=${row_vllm_image:-${VLLM_IMAGE}}
      MAX_MODEL_LEN=${row_max_model_len:-${MAX_MODEL_LEN}}
      GPU_MEMORY_UTILIZATION=${row_gpu_memory_utilization:-${GPU_MEMORY_UTILIZATION}}
      MAX_NUM_SEQS=${row_max_num_seqs:-${MAX_NUM_SEQS}}
      MAX_NUM_BATCHED_TOKENS=${row_max_num_batched_tokens:-${MAX_NUM_BATCHED_TOKENS}}
      CPU_REQUEST=${row_cpu_request:-${CPU_REQUEST}}
      MEMORY_REQUEST=${row_memory_request:-${MEMORY_REQUEST}}
      CPU_LIMIT=${row_cpu_limit:-${CPU_LIMIT}}
      MEMORY_LIMIT=${row_memory_limit:-${MEMORY_LIMIT}}
      MODEL_CACHE_SIZE=${row_model_cache_size:-${MODEL_CACHE_SIZE}}
      SHM_SIZE=${row_shm_size:-${SHM_SIZE}}
      PROFILE_DESCRIPTION=${row_profile_description:-${PROFILE_DESCRIPTION}}
      validate_loaded_serving_profile
      return 0
    fi
  done < "${profiles_path}"

  die "Unknown serving profile ${requested_profile_id} for experiment ${experiment_name}"
}

load_client_policy() {
  local experiment_name=$1
  local requested_case_id=$2
  local policies_path
  local row_case_id
  local row_policy_id

  policies_path=$(experiment_client_policies_path "${experiment_name}")

  CLIENT_POLICY_ID="direct"
  CLIENT_MODE="direct"
  CLIENT_EXECUTOR="ramping-arrival-rate"
  CLIENT_BUFFER_CAPACITY_REQUESTS="0"
  CLIENT_MAX_QUEUE_WAIT_SECONDS="0"
  if [[ ! -f "${policies_path}" ]]; then
    return 0
  fi

  while IFS=',' read -r row_case_id row_policy_id CLIENT_MODE CLIENT_EXECUTOR CLIENT_BUFFER_CAPACITY_REQUESTS CLIENT_MAX_QUEUE_WAIT_SECONDS _client_policy_description; do
    if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
      continue
    fi

    if [[ "${row_case_id}" == "${requested_case_id}" ]]; then
      CLIENT_POLICY_ID=${row_policy_id}
      require_name "${CLIENT_POLICY_ID}" "client policy id"
      require_name "${CLIENT_MODE}" "client policy mode"
      case "${CLIENT_EXECUTOR}" in
        ramping-arrival-rate|ramping-vus)
          ;;
        *)
          die "Invalid client executor: ${CLIENT_EXECUTOR}"
          ;;
      esac
      require_non_negative_integer "${CLIENT_BUFFER_CAPACITY_REQUESTS}" "client buffer capacity"
      require_non_negative_integer "${CLIENT_MAX_QUEUE_WAIT_SECONDS}" "client max queue wait seconds"
      return 0
    fi
  done < "${policies_path}"

  return 0
}

load_cost_profile() {
  local experiment_name=$1
  local requested_profile_id=$2
  local cost_profiles_path
  local row_profile_id

  COST_PROFILE_ID=""
  COST_SERVING_HOURLY_COST_USD=""
  COST_SCOPE=""
  COST_SLO_P95_REQUEST_LATENCY_SECONDS=""
  COST_SLO_P99_REQUEST_LATENCY_SECONDS=""

  cost_profiles_path=$(experiment_cost_profiles_path "${experiment_name}")
  if [[ ! -f "${cost_profiles_path}" ]]; then
    return 0
  fi

  while IFS=',' read -r row_profile_id COST_SERVING_HOURLY_COST_USD COST_SCOPE COST_SLO_P95_REQUEST_LATENCY_SECONDS COST_SLO_P99_REQUEST_LATENCY_SECONDS _cost_profile_description; do
    if [[ -z "${row_profile_id}" || "${row_profile_id}" == "profile_id" || "${row_profile_id}" == \#* ]]; then
      continue
    fi

    if [[ "${row_profile_id}" == "${requested_profile_id}" ]]; then
      COST_PROFILE_ID=${row_profile_id}
      require_name "${COST_PROFILE_ID}" "cost profile id"
      require_rate "${COST_SERVING_HOURLY_COST_USD}" "serving hourly cost"
      require_safe_text "${COST_SCOPE}" "cost scope"
      if [[ -n "${COST_SLO_P95_REQUEST_LATENCY_SECONDS}" ]]; then
        require_rate "${COST_SLO_P95_REQUEST_LATENCY_SECONDS}" "p95 request latency SLO"
      fi
      if [[ -n "${COST_SLO_P99_REQUEST_LATENCY_SECONDS}" ]]; then
        require_rate "${COST_SLO_P99_REQUEST_LATENCY_SECONDS}" "p99 request latency SLO"
      fi
      return 0
    fi
  done < "${cost_profiles_path}"

  die "Experiment ${experiment_name} has cost-profiles.csv but no cost profile for serving profile ${requested_profile_id}"
}

render_request_shapes_js() {
  local experiment_name=$1
  local shapes_path
  local row_case_id
  local shape_id
  local shape_prompt_token_target
  local shape_max_tokens
  local shape_weight
  local found=0
  local first=1

  shapes_path=$(experiment_request_shapes_path "${experiment_name}")

  printf '['
  if [[ -f "${shapes_path}" ]]; then
    while IFS=',' read -r row_case_id shape_id shape_prompt_token_target shape_max_tokens shape_weight; do
      if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
        continue
      fi

      if [[ "${row_case_id}" == "${CASE_ID}" ]]; then
        require_name "${shape_id}" "request shape id"
        require_positive_integer "${shape_prompt_token_target}" "request shape prompt token target"
        require_positive_integer "${shape_max_tokens}" "request shape max tokens"
        require_positive_integer "${shape_weight}" "request shape weight"

        if [[ "${first}" == "0" ]]; then
          printf ', '
        fi
        printf '{ label: "%s", promptTokenTarget: %s, maxTokens: %s, weight: %s }' \
          "${shape_id}" "${shape_prompt_token_target}" "${shape_max_tokens}" "${shape_weight}"
        found=1
        first=0
      fi
    done < "${shapes_path}"
  fi

  if [[ "${found}" == "0" ]]; then
    printf '{ label: "%s", promptTokenTarget: %s, maxTokens: %s, weight: 1 }' \
      "${CASE_ID}" "${PROMPT_TOKEN_TARGET}" "${MAX_TOKENS}"
  fi
  printf ']'
}

render_request_shapes_json() {
  local experiment_name=$1
  local shapes_path
  local row_case_id
  local shape_id
  local shape_prompt_token_target
  local shape_max_tokens
  local shape_weight
  local found=0
  local first=1

  shapes_path=$(experiment_request_shapes_path "${experiment_name}")

  printf '['
  if [[ -f "${shapes_path}" ]]; then
    while IFS=',' read -r row_case_id shape_id shape_prompt_token_target shape_max_tokens shape_weight; do
      if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
        continue
      fi

      if [[ "${row_case_id}" == "${CASE_ID}" ]]; then
        require_name "${shape_id}" "request shape id"
        require_positive_integer "${shape_prompt_token_target}" "request shape prompt token target"
        require_positive_integer "${shape_max_tokens}" "request shape max tokens"
        require_positive_integer "${shape_weight}" "request shape weight"

        if [[ "${first}" == "0" ]]; then
          printf ', '
        fi
        printf '{"id":"%s","prompt_token_target":%s,"max_tokens":%s,"weight":%s}' \
          "${shape_id}" "${shape_prompt_token_target}" "${shape_max_tokens}" "${shape_weight}"
        found=1
        first=0
      fi
    done < "${shapes_path}"
  fi

  if [[ "${found}" == "0" ]]; then
    printf '{"id":"%s","prompt_token_target":%s,"max_tokens":%s,"weight":1}' \
      "${CASE_ID}" "${PROMPT_TOKEN_TARGET}" "${MAX_TOKENS}"
  fi
  printf ']'
}

request_shapes_display() {
  local experiment_name=$1
  local shapes_path
  local row_case_id
  local shape_id
  local shape_prompt_token_target
  local shape_max_tokens
  local shape_weight
  local found=0
  local separator=""

  shapes_path=$(experiment_request_shapes_path "${experiment_name}")

  if [[ -f "${shapes_path}" ]]; then
    while IFS=',' read -r row_case_id shape_id shape_prompt_token_target shape_max_tokens shape_weight; do
      if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
        continue
      fi

      if [[ "${row_case_id}" == "${CASE_ID}" ]]; then
        require_name "${shape_id}" "request shape id"
        require_positive_integer "${shape_prompt_token_target}" "request shape prompt token target"
        require_positive_integer "${shape_max_tokens}" "request shape max tokens"
        require_positive_integer "${shape_weight}" "request shape weight"
        printf '%s%s:%s/%s weight=%s' "${separator}" "${shape_id}" "${shape_prompt_token_target}" "${shape_max_tokens}" "${shape_weight}"
        separator=", "
        found=1
      fi
    done < "${shapes_path}"
  fi

  if [[ "${found}" == "0" ]]; then
    printf '%s:%s/%s weight=1' "${CASE_ID}" "${PROMPT_TOKEN_TARGET}" "${MAX_TOKENS}"
  fi
}

case_required_token_budget() {
  local experiment_name=$1
  local shapes_path
  local row_case_id
  local shape_id
  local shape_prompt_token_target
  local shape_max_tokens
  local shape_weight
  local max_required
  local required

  max_required=$((PROMPT_TOKEN_TARGET + MAX_TOKENS))
  shapes_path=$(experiment_request_shapes_path "${experiment_name}")

  if [[ -f "${shapes_path}" ]]; then
    while IFS=',' read -r row_case_id shape_id shape_prompt_token_target shape_max_tokens shape_weight; do
      if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
        continue
      fi

      if [[ "${row_case_id}" == "${CASE_ID}" ]]; then
        require_name "${shape_id}" "request shape id"
        require_positive_integer "${shape_prompt_token_target}" "request shape prompt token target"
        require_positive_integer "${shape_max_tokens}" "request shape max tokens"
        require_positive_integer "${shape_weight}" "request shape weight"
        required=$((shape_prompt_token_target + shape_max_tokens))
        if (( required > max_required )); then
          max_required=${required}
        fi
      fi
    done < "${shapes_path}"
  fi

  printf '%s\n' "${max_required}"
}

validate_case_profile_compatibility() {
  local experiment_name=$1
  local required_tokens

  required_tokens=$(case_required_token_budget "${experiment_name}")
  if (( required_tokens > MAX_MODEL_LEN )); then
    die "Serving profile ${PROFILE_ID} max_model_len ${MAX_MODEL_LEN} is smaller than case ${CASE_ID} prompt+output budget ${required_tokens}"
  fi
}

validate_csv_field_count() {
  local csv_path=$1
  local expected_count=$2

  if [[ ! -f "${csv_path}" ]]; then
    die "Missing CSV file: ${csv_path}"
  fi

  awk -F',' -v expected_count="${expected_count}" '
    /^[[:space:]]*$/ { next }
    $1 ~ /^#/ { next }
    NF != expected_count {
      printf "%s:%d expected %d CSV fields but found %d\n", FILENAME, NR, expected_count, NF > "/dev/stderr"
      failed=1
    }
    END { exit failed ? 1 : 0 }
  ' "${csv_path}" || die "Invalid CSV shape: ${csv_path}"
}

validate_case_rows() {
  local experiment_name=$1
  local cases_path
  local row_case_id
  local _row_rest

  cases_path=$(experiment_cases_path "${experiment_name}")
  while IFS=',' read -r row_case_id _row_rest; do
    if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
      continue
    fi

    load_case "${experiment_name}" "${row_case_id}"
    render_request_shapes_js "${experiment_name}" >/dev/null
    render_request_shapes_json "${experiment_name}" >/dev/null
    request_shapes_display "${experiment_name}" >/dev/null
    case_required_token_budget "${experiment_name}" >/dev/null
  done < "${cases_path}"
}

validate_serving_profile_rows() {
  local experiment_name=$1
  local serving_profiles_path
  local row_profile_id
  local _row_rest

  serving_profiles_path=$(experiment_serving_profiles_path "${experiment_name}")
  while IFS=',' read -r row_profile_id _row_rest; do
    if [[ -z "${row_profile_id}" || "${row_profile_id}" == "profile_id" || "${row_profile_id}" == \#* ]]; then
      continue
    fi

    load_serving_profile "${experiment_name}" "${row_profile_id}"
    render_serving_manifest "${experiment_name}" "${row_profile_id}" >/dev/null
  done < "${serving_profiles_path}"
}

validate_request_shape_rows() {
  local experiment_name=$1
  local request_shapes_path
  local row_case_id
  local shape_id
  local shape_prompt_token_target
  local shape_max_tokens
  local shape_weight

  request_shapes_path=$(experiment_request_shapes_path "${experiment_name}")
  if [[ ! -f "${request_shapes_path}" ]]; then
    return 0
  fi

  while IFS=',' read -r row_case_id shape_id shape_prompt_token_target shape_max_tokens shape_weight; do
    if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
      continue
    fi

    load_case "${experiment_name}" "${row_case_id}" >/dev/null
    require_name "${shape_id}" "request shape id"
    require_positive_integer "${shape_prompt_token_target}" "request shape prompt token target"
    require_positive_integer "${shape_max_tokens}" "request shape max tokens"
    require_positive_integer "${shape_weight}" "request shape weight"
  done < "${request_shapes_path}"
}

validate_client_policy_rows() {
  local experiment_name=$1
  local client_policies_path
  local row_case_id
  local row_policy_id
  local row_client_mode
  local row_client_executor
  local row_buffer_capacity
  local row_max_queue_wait
  local _row_description

  client_policies_path=$(experiment_client_policies_path "${experiment_name}")
  if [[ ! -f "${client_policies_path}" ]]; then
    return 0
  fi

  while IFS=',' read -r row_case_id row_policy_id row_client_mode row_client_executor row_buffer_capacity row_max_queue_wait _row_description; do
    if [[ -z "${row_case_id}" || "${row_case_id}" == "case_id" || "${row_case_id}" == \#* ]]; then
      continue
    fi

    load_case "${experiment_name}" "${row_case_id}" >/dev/null
    require_name "${row_policy_id}" "client policy id"
    require_name "${row_client_mode}" "client policy mode"
    case "${row_client_executor}" in
      ramping-arrival-rate|ramping-vus)
        ;;
      *)
        die "Invalid client executor: ${row_client_executor}"
        ;;
    esac
    require_non_negative_integer "${row_buffer_capacity}" "client buffer capacity"
    require_non_negative_integer "${row_max_queue_wait}" "client max queue wait seconds"
  done < "${client_policies_path}"
}

validate_cost_profile_rows() {
  local experiment_name=$1
  local cost_profiles_path
  local row_profile_id
  local row_hourly_cost
  local row_scope
  local row_p95_slo
  local row_p99_slo
  local _row_description

  cost_profiles_path=$(experiment_cost_profiles_path "${experiment_name}")
  if [[ ! -f "${cost_profiles_path}" ]]; then
    return 0
  fi

  while IFS=',' read -r row_profile_id row_hourly_cost row_scope row_p95_slo row_p99_slo _row_description; do
    if [[ -z "${row_profile_id}" || "${row_profile_id}" == "profile_id" || "${row_profile_id}" == \#* ]]; then
      continue
    fi

    load_serving_profile "${experiment_name}" "${row_profile_id}" >/dev/null
    require_rate "${row_hourly_cost}" "serving hourly cost"
    require_safe_text "${row_scope}" "cost scope"
    if [[ -n "${row_p95_slo}" ]]; then
      require_rate "${row_p95_slo}" "p95 request latency SLO"
    fi
    if [[ -n "${row_p99_slo}" ]]; then
      require_rate "${row_p99_slo}" "p99 request latency SLO"
    fi
  done < "${cost_profiles_path}"
}

validate_experiment() {
  local experiment_name=$1
  local cases_path
  local serving_profiles_path
  local request_shapes_path
  local client_policies_path
  local cost_profiles_path

  require_experiment "${experiment_name}"
  require_serving_profiles "${experiment_name}"

  cases_path=$(experiment_cases_path "${experiment_name}")
  serving_profiles_path=$(experiment_serving_profiles_path "${experiment_name}")
  request_shapes_path=$(experiment_request_shapes_path "${experiment_name}")
  client_policies_path=$(experiment_client_policies_path "${experiment_name}")
  cost_profiles_path=$(experiment_cost_profiles_path "${experiment_name}")

  validate_csv_field_count "${cases_path}" 12
  validate_csv_field_count "${serving_profiles_path}" 15
  if [[ -f "${request_shapes_path}" ]]; then
    validate_csv_field_count "${request_shapes_path}" 5
  fi
  if [[ -f "${client_policies_path}" ]]; then
    validate_csv_field_count "${client_policies_path}" 7
  fi
  if [[ -f "${cost_profiles_path}" ]]; then
    validate_csv_field_count "${cost_profiles_path}" 6
  fi

  validate_case_rows "${experiment_name}"
  validate_serving_profile_rows "${experiment_name}"
  validate_request_shape_rows "${experiment_name}"
  validate_client_policy_rows "${experiment_name}"
  validate_cost_profile_rows "${experiment_name}"
}

validate_experiment_catalog() {
  local experiment_path
  local experiment_name
  local validated_count=0

  validate_csv_field_count "${SERVING_DEFAULTS_PATH}" 15
  load_default_serving_profile
  require_template "${LOAD_CLIENT_TEMPLATE}"
  require_template "${STREAM_CLIENT_TEMPLATE}"

  while read -r experiment_path; do
    experiment_name=$(basename "${experiment_path}")
    validate_experiment "${experiment_name}"
    validated_count=$((validated_count + 1))
  done < <(find "${EXPERIMENTS_DIR}" -mindepth 1 -maxdepth 1 -type d ! -name '_profiles' ! -name '_templates' | sort)

  printf 'Validated %s experiment(s).\n' "${validated_count}"
}

render_k6_scenario() {
  case "${CLIENT_EXECUTOR}" in
    ramping-arrival-rate)
      cat <<EOF
        inference_burst: {
          executor: "ramping-arrival-rate",
          startRate: ${START_RATE},
          timeUnit: "1s",
          preAllocatedVUs: ${PRE_ALLOCATED_VUS},
          maxVUs: ${MAX_VUS},
          stages: [
            { duration: "${RAMP_UP_DURATION}", target: ${TARGET_RATE} },
            { duration: "${STEADY_DURATION}", target: ${TARGET_RATE} },
            { duration: "${RAMP_DOWN_DURATION}", target: 0 },
          ],
        },
EOF
      ;;
    ramping-vus)
      require_non_negative_integer "${START_RATE}" "ramping-vus start VUs"
      require_non_negative_integer "${TARGET_RATE}" "ramping-vus target VUs"
      cat <<EOF
        inference_burst: {
          executor: "ramping-vus",
          startVUs: ${START_RATE},
          stages: [
            { duration: "${RAMP_UP_DURATION}", target: ${TARGET_RATE} },
            { duration: "${STEADY_DURATION}", target: ${TARGET_RATE} },
            { duration: "${RAMP_DOWN_DURATION}", target: 0 },
          ],
        },
EOF
      ;;
    *)
      die "Invalid client executor: ${CLIENT_EXECUTOR}"
      ;;
  esac
}

render_optional_vllm_scheduler_args() {
  if [[ -n "${MAX_NUM_SEQS}" ]]; then
    cat <<EOF
            - --max-num-seqs
            - "${MAX_NUM_SEQS}"
EOF
  fi

  if [[ -n "${MAX_NUM_BATCHED_TOKENS}" ]]; then
    cat <<EOF
            - --max-num-batched-tokens
            - "${MAX_NUM_BATCHED_TOKENS}"
EOF
  fi
}

require_template() {
  local template_path=$1

  if [[ ! -f "${template_path}" ]]; then
    die "Missing render template: ${template_path}"
  fi
}

indent_manifest_script() {
  sed 's/^/    /'
}

render_load_client_script() {
  local experiment_name=$1
  local served_model_name=$2
  local request_shapes_js=$3
  local target_url="http://${GPU_INFERENCE_SERVICE_NAME}.${APP_NAMESPACE}.svc.cluster.local/v1/completions"
  local scenario
  local rendered

  require_template "${LOAD_CLIENT_TEMPLATE}"
  scenario=$(render_k6_scenario)
  rendered=$(<"${LOAD_CLIENT_TEMPLATE}")
  rendered=${rendered//@EXPERIMENT_NAME@/${experiment_name}}
  rendered=${rendered//@CASE_ID@/${CASE_ID}}
  rendered=${rendered//@PROMPT_TOKEN_TARGET@/${PROMPT_TOKEN_TARGET}}
  rendered=${rendered//@MAX_TOKENS@/${MAX_TOKENS}}
  rendered=${rendered//@TIMEOUT_SECONDS@/${TIMEOUT_SECONDS}}
  rendered=${rendered//@CLIENT_POLICY_ID@/${CLIENT_POLICY_ID}}
  rendered=${rendered//@CLIENT_MODE@/${CLIENT_MODE}}
  rendered=${rendered//@CLIENT_BUFFER_CAPACITY_REQUESTS@/${CLIENT_BUFFER_CAPACITY_REQUESTS}}
  rendered=${rendered//@CLIENT_MAX_QUEUE_WAIT_SECONDS@/${CLIENT_MAX_QUEUE_WAIT_SECONDS}}
  rendered=${rendered//@REQUEST_SHAPES_JS@/${request_shapes_js}}
  rendered=${rendered//@K6_SCENARIO@/${scenario}}
  rendered=${rendered//@TARGET_URL@/${target_url}}
  rendered=${rendered//@MODEL_NAME@/${served_model_name}}
  printf '%s\n' "${rendered}"
}

render_stream_client_script() {
  local experiment_name=$1
  local served_model_name=$2
  local samples=$3
  local target_url="http://${GPU_INFERENCE_SERVICE_NAME}.${APP_NAMESPACE}.svc.cluster.local/v1/completions"
  local rendered

  require_template "${STREAM_CLIENT_TEMPLATE}"
  rendered=$(<"${STREAM_CLIENT_TEMPLATE}")
  rendered=${rendered//@EXPERIMENT_NAME@/${experiment_name}}
  rendered=${rendered//@CASE_ID@/${CASE_ID}}
  rendered=${rendered//@PROMPT_TOKEN_TARGET@/${PROMPT_TOKEN_TARGET}}
  rendered=${rendered//@MAX_TOKENS@/${MAX_TOKENS}}
  rendered=${rendered//@SAMPLES@/${samples}}
  rendered=${rendered//@TIMEOUT_SECONDS@/${TIMEOUT_SECONDS}}
  rendered=${rendered//@TARGET_URL@/${target_url}}
  rendered=${rendered//@MODEL_NAME@/${served_model_name}}
  printf '%s\n' "${rendered}"
}

render_serving_manifest() {
  local experiment_name=$1
  local profile_id=$2

  load_serving_profile "${experiment_name}" "${profile_id}"

  cat <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: vllm-openai
  namespace: app
spec:
  replicas: 1
  selector:
    matchLabels:
      app: vllm-openai
  template:
    metadata:
      labels:
        app: vllm-openai
    spec:
      terminationGracePeriodSeconds: 120
      nodeSelector:
        workload: gpu
      tolerations:
        - key: gpu
          operator: Equal
          value: "true"
          effect: NoSchedule
      containers:
        - name: server
          image: ${VLLM_IMAGE}
          args:
            - --model
            - ${MODEL}
            - --served-model-name
            - ${SERVED_MODEL_NAME}
            - --host
            - 0.0.0.0
            - --port
            - "8000"
            - --dtype
            - float16
            - --max-model-len
            - "${MAX_MODEL_LEN}"
            - --gpu-memory-utilization
            - "${GPU_MEMORY_UTILIZATION}"
EOF
  render_optional_vllm_scheduler_args
  cat <<EOF
          env:
            - name: HF_HOME
              value: /cache/huggingface
            - name: HF_HUB_DISABLE_TELEMETRY
              value: "1"
          ports:
            - containerPort: 8000
              name: http
          readinessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 20
            periodSeconds: 10
            failureThreshold: 60
          livenessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 60
            periodSeconds: 20
            failureThreshold: 6
          resources:
            requests:
              cpu: "${CPU_REQUEST}"
              memory: ${MEMORY_REQUEST}
              nvidia.com/gpu: "1"
            limits:
              cpu: "${CPU_LIMIT}"
              memory: ${MEMORY_LIMIT}
              nvidia.com/gpu: "1"
          volumeMounts:
            - name: model-cache
              mountPath: /cache/huggingface
            - name: shm
              mountPath: /dev/shm
      volumes:
        - name: model-cache
          emptyDir:
            sizeLimit: ${MODEL_CACHE_SIZE}
        - name: shm
          emptyDir:
            medium: Memory
            sizeLimit: ${SHM_SIZE}
EOF
}

render_load_manifest() {
  local experiment_name=$1
  local case_id=$2
  local job_name
  local configmap_name
  local load_served_model_name
  local request_shapes_js

  require_experiment "${experiment_name}"
  load_case "${experiment_name}" "${case_id}"
  load_client_policy "${experiment_name}" "${CASE_ID}"

  job_name="${experiment_name}-${CASE_ID}"
  configmap_name="${job_name}-load"
  load_served_model_name="${SERVED_MODEL_NAME:-${GPU_INFERENCE_SERVED_MODEL_NAME}}"
  request_shapes_js=$(render_request_shapes_js "${experiment_name}")

  cat <<EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: ${configmap_name}
  namespace: ${APP_NAMESPACE}
  labels:
    experiment.gpu-lab/name: ${experiment_name}
    experiment.gpu-lab/case: ${CASE_ID}
data:
  load-test.js: |
EOF
  render_load_client_script "${experiment_name}" "${load_served_model_name}" "${request_shapes_js}" | indent_manifest_script
  cat <<EOF
---
apiVersion: batch/v1
kind: Job
metadata:
  name: ${job_name}
  namespace: ${APP_NAMESPACE}
  labels:
    experiment.gpu-lab/name: ${experiment_name}
    experiment.gpu-lab/case: ${CASE_ID}
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        experiment.gpu-lab/name: ${experiment_name}
        experiment.gpu-lab/case: ${CASE_ID}
    spec:
      restartPolicy: Never
      containers:
        - name: k6
          image: grafana/k6:0.49.0
          args:
            - run
            - /scripts/load-test.js
          env:
            - name: TARGET_URL
              value: http://${GPU_INFERENCE_SERVICE_NAME}.${APP_NAMESPACE}.svc.cluster.local/v1/completions
            - name: MODEL_NAME
              value: ${load_served_model_name}
          volumeMounts:
            - name: scripts
              mountPath: /scripts
      volumes:
        - name: scripts
          configMap:
            name: ${configmap_name}
EOF
}

render_stream_manifest() {
  local experiment_name=$1
  local case_id=$2
  local samples=$3
  local job_name
  local configmap_name
  local stream_served_model_name

  require_experiment "${experiment_name}"
  load_case "${experiment_name}" "${case_id}"
  require_positive_integer "${samples}" "stream samples"

  job_name=$(stream_job_name "${experiment_name}" "${CASE_ID}")
  configmap_name="${job_name}-client"
  stream_served_model_name="${SERVED_MODEL_NAME:-${GPU_INFERENCE_SERVED_MODEL_NAME}}"

  cat <<EOF
apiVersion: v1
kind: ConfigMap
metadata:
  name: ${configmap_name}
  namespace: ${APP_NAMESPACE}
  labels:
    experiment.gpu-lab/name: ${experiment_name}
    experiment.gpu-lab/case: ${CASE_ID}
    experiment.gpu-lab/client: stream
data:
  stream-client.py: |
EOF
  render_stream_client_script "${experiment_name}" "${stream_served_model_name}" "${samples}" | indent_manifest_script
  cat <<EOF
---
apiVersion: batch/v1
kind: Job
metadata:
  name: ${job_name}
  namespace: ${APP_NAMESPACE}
  labels:
    experiment.gpu-lab/name: ${experiment_name}
    experiment.gpu-lab/case: ${CASE_ID}
    experiment.gpu-lab/client: stream
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        experiment.gpu-lab/name: ${experiment_name}
        experiment.gpu-lab/case: ${CASE_ID}
        experiment.gpu-lab/client: stream
    spec:
      restartPolicy: Never
      containers:
        - name: stream-client
          image: python:3.12-slim
          args:
            - python
            - /scripts/stream-client.py
          volumeMounts:
            - name: scripts
              mountPath: /scripts
      volumes:
        - name: scripts
          configMap:
            name: ${configmap_name}
EOF
}

render_report_markdown() {
  local experiment_name=$1
  local case_id=$2
  local profile_id=$3
  local generated_at=$4
  local experiment_title_value
  local max_num_seqs_display="n/a"
  local max_num_batched_tokens_display="n/a"
  local run_status="${RUN_STATUS:-pending}"
  local run_source="${RUN_SOURCE:-scripts/experiment render-report}"
  local request_shapes_display_value
  local load_unit="req/s"
  local dropped_iterations_display
  local buffering_required_display
  local failure_attribution_display
  local completed_requests_display
  local successful_requests_display
  local failed_requests_display
  local oom_events_display
  local p50_latency_display
  local p95_latency_display
  local p99_latency_display
  local p50_ttft_display
  local p95_ttft_display
  local p50_inter_token_latency_display
  local p95_inter_token_latency_display
  local requests_per_second_display
  local generated_tokens_display
  local generation_tokens_per_second_display
  local run_duration_display
  local peak_waiting_requests_display
  local peak_running_requests_display
  local peak_active_requests_display
  local average_gpu_utilization_display
  local max_gpu_utilization_display
  local gpu_memory_used_display
  local gpu_memory_free_display
  local first_nodeclaim_display
  local first_gpu_node_display
  local pod_scheduled_display
  local container_started_display
  local model_ready_display
  local first_successful_completion_display
  local cost_scope_display
  local serving_hourly_cost_display
  local estimated_burst_cost_display
  local cost_per_1000_display
  local cost_per_1m_tokens_display
  local slo_p95_target_display
  local slo_p99_target_display
  local slo_passed_display

  require_experiment "${experiment_name}"
  load_case "${experiment_name}" "${case_id}"
  load_client_policy "${experiment_name}" "${CASE_ID}"
  load_serving_profile "${experiment_name}" "${profile_id}"
  load_cost_profile "${experiment_name}" "${profile_id}"

  experiment_title_value=$(experiment_title "${experiment_name}")
  request_shapes_display_value=$(request_shapes_display "${experiment_name}")
  if [[ "${CLIENT_EXECUTOR}" == "ramping-vus" ]]; then
    load_unit="VUs"
  fi
  if [[ -n "${MAX_NUM_SEQS}" ]]; then
    max_num_seqs_display=${MAX_NUM_SEQS}
  fi
  if [[ -n "${MAX_NUM_BATCHED_TOKENS}" ]]; then
    max_num_batched_tokens_display=${MAX_NUM_BATCHED_TOKENS}
  fi

  completed_requests_display=$(display_optional_metric "${RESULT_COMPLETED_REQUESTS:-}")
  successful_requests_display=$(display_optional_metric "${RESULT_SUCCESSFUL_REQUESTS:-}")
  failed_requests_display=$(display_optional_metric "${RESULT_FAILED_REQUESTS:-}")
  oom_events_display=$(display_optional_metric "${RESULT_OOM_EVENTS:-}")
  dropped_iterations_display=$(display_optional_metric "${RESULT_DROPPED_ITERATIONS:-}")
  buffering_required_display=$(display_optional_metric "${RESULT_BUFFERING_REQUIRED_REQUESTS:-}")
  failure_attribution_display=$(display_optional_metric "${RESULT_FAILURE_ATTRIBUTION:-}")
  p50_latency_display=$(display_optional_metric "${RESULT_P50_REQUEST_LATENCY_SECONDS:-}")
  p95_latency_display=$(display_optional_metric "${RESULT_P95_REQUEST_LATENCY_SECONDS:-}")
  p99_latency_display=$(display_optional_metric "${RESULT_P99_REQUEST_LATENCY_SECONDS:-}")
  p50_ttft_display=$(display_optional_metric "${RESULT_P50_TTFT_SECONDS:-}")
  p95_ttft_display=$(display_optional_metric "${RESULT_P95_TTFT_SECONDS:-}")
  p50_inter_token_latency_display=$(display_optional_metric "${RESULT_P50_INTER_TOKEN_LATENCY_SECONDS:-}")
  p95_inter_token_latency_display=$(display_optional_metric "${RESULT_P95_INTER_TOKEN_LATENCY_SECONDS:-}")
  requests_per_second_display=$(display_optional_metric "${RESULT_REQUESTS_PER_SECOND:-}")
  generated_tokens_display=$(display_optional_metric "${RESULT_GENERATED_TOKENS:-}")
  generation_tokens_per_second_display=$(display_optional_metric "${RESULT_GENERATION_TOKENS_PER_SECOND:-}")
  run_duration_display=$(display_optional_metric "${RESULT_RUN_DURATION_SECONDS:-}")
  peak_waiting_requests_display=$(display_optional_metric "${RESULT_PEAK_WAITING_REQUESTS:-}")
  peak_running_requests_display=$(display_optional_metric "${RESULT_PEAK_RUNNING_REQUESTS:-}")
  peak_active_requests_display=$(display_optional_metric "${RESULT_PEAK_ACTIVE_REQUESTS:-}")
  average_gpu_utilization_display=$(display_optional_metric "${RESULT_AVERAGE_GPU_UTILIZATION_PERCENT:-}")
  max_gpu_utilization_display=$(display_optional_metric "${RESULT_MAX_GPU_UTILIZATION_PERCENT:-}")
  gpu_memory_used_display=$(display_optional_metric "${RESULT_GPU_MEMORY_USED_BYTES:-}")
  gpu_memory_free_display=$(display_optional_metric "${RESULT_GPU_MEMORY_FREE_BYTES:-}")
  first_nodeclaim_display=$(display_optional_metric "${RESULT_FIRST_NODECLAIM_SECONDS:-}")
  first_gpu_node_display=$(display_optional_metric "${RESULT_FIRST_GPU_NODE_SECONDS:-}")
  pod_scheduled_display=$(display_optional_metric "${RESULT_POD_SCHEDULED_SECONDS:-}")
  container_started_display=$(display_optional_metric "${RESULT_CONTAINER_STARTED_SECONDS:-}")
  model_ready_display=$(display_optional_metric "${RESULT_MODEL_READY_SECONDS:-}")
  first_successful_completion_display=$(display_optional_metric "${RESULT_FIRST_SUCCESSFUL_COMPLETION_SECONDS:-}")
  cost_scope_display=$(display_optional_metric "${COST_SCOPE:-}")
  serving_hourly_cost_display=$(display_optional_metric "${COST_SERVING_HOURLY_COST_USD:-}")
  estimated_burst_cost_display=$(display_optional_metric "${RESULT_ESTIMATED_BURST_COST_USD:-}")
  cost_per_1000_display=$(display_optional_metric "${RESULT_COST_PER_1000_SUCCESSFUL_REQUESTS_USD:-}")
  cost_per_1m_tokens_display=$(display_optional_metric "${RESULT_COST_PER_1M_GENERATED_TOKENS_USD:-}")
  slo_p95_target_display=$(display_optional_metric "${COST_SLO_P95_REQUEST_LATENCY_SECONDS:-}")
  slo_p99_target_display=$(display_optional_metric "${COST_SLO_P99_REQUEST_LATENCY_SECONDS:-}")
  slo_passed_display=$(display_optional_metric "${RESULT_SLO_PASSED:-}")

  cat <<EOF
# ${experiment_title_value} - ${CASE_ID}

- Schema version: experiment-report/v1
- Status: ${run_status}
- Generated at: ${generated_at}
- Requires live cluster: true
- Source: ${run_source}

## Workload

| Field | Value |
| --- | --- |
| Experiment | ${experiment_name} |
| Case | ${CASE_ID} |
| Prompt token target | ${PROMPT_TOKEN_TARGET} |
| Max output tokens | ${MAX_TOKENS} |
| Request shapes | ${request_shapes_display_value} |
| Client policy | ${CLIENT_POLICY_ID} |
| Client mode | ${CLIENT_MODE} |
| Load executor | ${CLIENT_EXECUTOR} |
| Buffer capacity | ${CLIENT_BUFFER_CAPACITY_REQUESTS} requests |
| Max queue wait | ${CLIENT_MAX_QUEUE_WAIT_SECONDS}s |
| Start load | ${START_RATE} ${load_unit} |
| Target load | ${TARGET_RATE} ${load_unit} |
| Ramp up | ${RAMP_UP_DURATION} |
| Steady duration | ${STEADY_DURATION} |
| Ramp down | ${RAMP_DOWN_DURATION} |
| Pre-allocated VUs | ${PRE_ALLOCATED_VUS} |
| Max VUs | ${MAX_VUS} |
| Timeout | ${TIMEOUT_SECONDS}s |

## Serving Profile

| Field | Value |
| --- | --- |
| Profile | ${PROFILE_ID} |
| Model | ${MODEL} |
| Served model name | ${SERVED_MODEL_NAME} |
| vLLM image | ${VLLM_IMAGE} |
| Max model length | ${MAX_MODEL_LEN} |
| GPU memory utilization | ${GPU_MEMORY_UTILIZATION} |
| Max sequences | ${max_num_seqs_display} |
| Max batched tokens | ${max_num_batched_tokens_display} |
| Cost scope | ${cost_scope_display} |
| Serving hourly cost | ${serving_hourly_cost_display} |
| p95 request SLO | ${slo_p95_target_display} |
| p99 request SLO | ${slo_p99_target_display} |

## Results

| Metric | Value |
| --- | --- |
| Completed requests | ${completed_requests_display} |
| Successful requests | ${successful_requests_display} |
| Failed requests | ${failed_requests_display} |
| Dropped client iterations | ${dropped_iterations_display} |
| Buffering required | ${buffering_required_display} |
| Failure attribution | ${failure_attribution_display} |
| OOM events | ${oom_events_display} |
| p50 request latency | ${p50_latency_display} |
| p95 request latency | ${p95_latency_display} |
| p99 request latency | ${p99_latency_display} |
| p50 TTFT | ${p50_ttft_display} |
| p95 TTFT | ${p95_ttft_display} |
| p50 inter-token latency | ${p50_inter_token_latency_display} |
| p95 inter-token latency | ${p95_inter_token_latency_display} |
| Requests/sec | ${requests_per_second_display} |
| Generated tokens | ${generated_tokens_display} |
| Generation tokens/sec | ${generation_tokens_per_second_display} |
| Run duration | ${run_duration_display} |
| Peak waiting requests | ${peak_waiting_requests_display} |
| Peak running requests | ${peak_running_requests_display} |
| Peak active requests | ${peak_active_requests_display} |
| Average GPU utilization | ${average_gpu_utilization_display} |
| Max GPU utilization | ${max_gpu_utilization_display} |
| GPU memory used | ${gpu_memory_used_display} |
| GPU memory free | ${gpu_memory_free_display} |
| First NodeClaim | ${first_nodeclaim_display} |
| First GPU node | ${first_gpu_node_display} |
| Pod scheduled | ${pod_scheduled_display} |
| Container started | ${container_started_display} |
| Model ready | ${model_ready_display} |
| First successful completion | ${first_successful_completion_display} |
| SLO passed | ${slo_passed_display} |
| Estimated burst cost | ${estimated_burst_cost_display} |
| Cost per 1K successful requests | ${cost_per_1000_display} |
| Cost per 1M generated tokens | ${cost_per_1m_tokens_display} |

## Notes

- This report records the workload and serving contract for the selected case.
- Result fields remain \`n/a\` until a live cluster run collects k6, Prometheus,
  DCGM, Kubernetes, and cost signals.
EOF
}

render_report_json() {
  local experiment_name=$1
  local case_id=$2
  local profile_id=$3
  local generated_at=$4
  local experiment_title_value
  local max_num_seqs_json
  local max_num_batched_tokens_json
  local request_shapes_json
  local run_status="${RUN_STATUS:-pending}"
  local run_source="${RUN_SOURCE:-scripts/experiment render-report}"

  require_experiment "${experiment_name}"
  load_case "${experiment_name}" "${case_id}"
  load_client_policy "${experiment_name}" "${CASE_ID}"
  load_serving_profile "${experiment_name}" "${profile_id}"
  load_cost_profile "${experiment_name}" "${profile_id}"

  experiment_title_value=$(experiment_title "${experiment_name}")
  max_num_seqs_json=$(json_optional_integer "${MAX_NUM_SEQS}")
  max_num_batched_tokens_json=$(json_optional_integer "${MAX_NUM_BATCHED_TOKENS}")
  request_shapes_json=$(render_request_shapes_json "${experiment_name}")

  cat <<EOF
{
  "schema_version": "experiment-report/v1",
  "experiment": {
    "name": "${experiment_name}",
    "title": "${experiment_title_value}"
  },
  "case": {
    "id": "${CASE_ID}",
    "prompt_token_target": ${PROMPT_TOKEN_TARGET},
    "max_tokens": ${MAX_TOKENS},
    "request_shapes": ${request_shapes_json},
    "client_policy": {
      "id": "${CLIENT_POLICY_ID}",
      "mode": "${CLIENT_MODE}",
      "executor": "${CLIENT_EXECUTOR}",
      "buffer_capacity_requests": ${CLIENT_BUFFER_CAPACITY_REQUESTS},
      "max_queue_wait_seconds": ${CLIENT_MAX_QUEUE_WAIT_SECONDS}
    },
    "arrival": {
      "start_rate": ${START_RATE},
      "target_rate": ${TARGET_RATE},
      "ramp_up_duration": "${RAMP_UP_DURATION}",
      "steady_duration": "${STEADY_DURATION}",
      "ramp_down_duration": "${RAMP_DOWN_DURATION}",
      "pre_allocated_vus": ${PRE_ALLOCATED_VUS},
      "max_vus": ${MAX_VUS},
      "timeout_seconds": ${TIMEOUT_SECONDS}
    }
  },
  "serving_profile": {
    "id": "${PROFILE_ID}",
    "model": "${MODEL}",
    "served_model_name": "${SERVED_MODEL_NAME}",
    "vllm_image": "${VLLM_IMAGE}",
    "max_model_len": ${MAX_MODEL_LEN},
    "gpu_memory_utilization": ${GPU_MEMORY_UTILIZATION},
    "max_num_seqs": ${max_num_seqs_json},
    "max_num_batched_tokens": ${max_num_batched_tokens_json},
    "cost_profile": {
      "id": $(json_optional_string "${COST_PROFILE_ID:-}"),
      "cost_scope": $(json_optional_string "${COST_SCOPE:-}"),
      "serving_hourly_cost_usd": $(json_optional_number "${COST_SERVING_HOURLY_COST_USD:-}"),
      "slo_p95_request_latency_seconds": $(json_optional_number "${COST_SLO_P95_REQUEST_LATENCY_SECONDS:-}"),
      "slo_p99_request_latency_seconds": $(json_optional_number "${COST_SLO_P99_REQUEST_LATENCY_SECONDS:-}")
    }
  },
  "run": {
    "status": "${run_status}",
    "generated_at": "${generated_at}",
    "source": "${run_source}",
    "requires_live_cluster": true
  },
  "results": {
    "success": {
      "completed_requests": $(json_optional_number "${RESULT_COMPLETED_REQUESTS:-}"),
      "successful_requests": $(json_optional_number "${RESULT_SUCCESSFUL_REQUESTS:-}"),
      "failed_requests": $(json_optional_number "${RESULT_FAILED_REQUESTS:-}"),
      "oom_events": $(json_optional_number "${RESULT_OOM_EVENTS:-}")
    },
    "latency": {
      "p50_request_latency_seconds": $(json_optional_number "${RESULT_P50_REQUEST_LATENCY_SECONDS:-}"),
      "p95_request_latency_seconds": $(json_optional_number "${RESULT_P95_REQUEST_LATENCY_SECONDS:-}"),
      "p99_request_latency_seconds": $(json_optional_number "${RESULT_P99_REQUEST_LATENCY_SECONDS:-}")
    },
    "serving": {
      "p50_ttft_seconds": $(json_optional_number "${RESULT_P50_TTFT_SECONDS:-}"),
      "p95_ttft_seconds": $(json_optional_number "${RESULT_P95_TTFT_SECONDS:-}"),
      "p50_inter_token_latency_seconds": $(json_optional_number "${RESULT_P50_INTER_TOKEN_LATENCY_SECONDS:-}"),
      "p95_inter_token_latency_seconds": $(json_optional_number "${RESULT_P95_INTER_TOKEN_LATENCY_SECONDS:-}"),
      "requests_per_second": $(json_optional_number "${RESULT_REQUESTS_PER_SECOND:-}"),
      "generated_tokens": $(json_optional_number "${RESULT_GENERATED_TOKENS:-}"),
      "run_duration_seconds": $(json_optional_number "${RESULT_RUN_DURATION_SECONDS:-}"),
      "generation_tokens_per_second": $(json_optional_number "${RESULT_GENERATION_TOKENS_PER_SECOND:-}")
    },
    "queue": {
      "peak_waiting_requests": $(json_optional_number "${RESULT_PEAK_WAITING_REQUESTS:-}"),
      "peak_running_requests": $(json_optional_number "${RESULT_PEAK_RUNNING_REQUESTS:-}"),
      "peak_active_requests": $(json_optional_number "${RESULT_PEAK_ACTIVE_REQUESTS:-}"),
      "dropped_iterations": $(json_optional_number "${RESULT_DROPPED_ITERATIONS:-}"),
      "buffering_required_requests": $(json_optional_number "${RESULT_BUFFERING_REQUIRED_REQUESTS:-}"),
      "failure_attribution": $(json_optional_string "${RESULT_FAILURE_ATTRIBUTION:-}")
    },
    "gpu": {
      "average_gpu_utilization_percent": $(json_optional_number "${RESULT_AVERAGE_GPU_UTILIZATION_PERCENT:-}"),
      "max_gpu_utilization_percent": $(json_optional_number "${RESULT_MAX_GPU_UTILIZATION_PERCENT:-}"),
      "gpu_memory_used_bytes": $(json_optional_number "${RESULT_GPU_MEMORY_USED_BYTES:-}"),
      "gpu_memory_free_bytes": $(json_optional_number "${RESULT_GPU_MEMORY_FREE_BYTES:-}")
    },
    "scaling": {
      "first_nodeclaim_seconds": $(json_optional_number "${RESULT_FIRST_NODECLAIM_SECONDS:-}"),
      "first_gpu_node_seconds": $(json_optional_number "${RESULT_FIRST_GPU_NODE_SECONDS:-}"),
      "pod_scheduled_seconds": $(json_optional_number "${RESULT_POD_SCHEDULED_SECONDS:-}"),
      "container_started_seconds": $(json_optional_number "${RESULT_CONTAINER_STARTED_SECONDS:-}"),
      "model_ready_seconds": $(json_optional_number "${RESULT_MODEL_READY_SECONDS:-}"),
      "first_successful_completion_seconds": $(json_optional_number "${RESULT_FIRST_SUCCESSFUL_COMPLETION_SECONDS:-}")
    },
    "slo": {
      "p95_request_latency_target_seconds": $(json_optional_number "${COST_SLO_P95_REQUEST_LATENCY_SECONDS:-}"),
      "p99_request_latency_target_seconds": $(json_optional_number "${COST_SLO_P99_REQUEST_LATENCY_SECONDS:-}"),
      "passed": $(json_optional_boolean "${RESULT_SLO_PASSED:-}")
    },
    "cost": {
      "cost_scope": $(json_optional_string "${COST_SCOPE:-}"),
      "serving_hourly_cost_usd": $(json_optional_number "${COST_SERVING_HOURLY_COST_USD:-}"),
      "estimated_burst_cost_usd": $(json_optional_number "${RESULT_ESTIMATED_BURST_COST_USD:-}"),
      "cost_per_1000_successful_requests_usd": $(json_optional_number "${RESULT_COST_PER_1000_SUCCESSFUL_REQUESTS_USD:-}"),
      "cost_per_1m_generated_tokens_usd": $(json_optional_number "${RESULT_COST_PER_1M_GENERATED_TOKENS_USD:-}")
    }
  },
  "notes": [
    "This report records the workload and serving contract for the selected case.",
    "Result fields remain null until a live cluster run collects k6, Prometheus, DCGM, Kubernetes, and cost signals."
  ]
}
EOF
}

default_report_prefix() {
  local experiment_name=$1
  local case_id=$2
  local profile_id=$3
  local timestamp=$4

  printf '%s/experiment-%s-%s-%s-%s' "${REPORTS_DIR}" "${experiment_name}" "${case_id}" "${profile_id}" "${timestamp}"
}

write_report_files() {
  local experiment_name=$1
  local case_id=$2
  local profile_id=$3
  local report_path=$4
  local json_report_path=$5
  local generated_at=$6

  mkdir -p "$(dirname "${report_path}")"
  mkdir -p "$(dirname "${json_report_path}")"

  render_report_markdown "${experiment_name}" "${case_id}" "${profile_id}" "${generated_at}" > "${report_path}"
  render_report_json "${experiment_name}" "${case_id}" "${profile_id}" "${generated_at}" > "${json_report_path}"
}

parse_k6_summary_log() {
  local log_path=$1
  local in_summary=0
  local key
  local value

  RESULT_COMPLETED_REQUESTS=""
  RESULT_SUCCESSFUL_REQUESTS=""
  RESULT_FAILED_REQUESTS=""
  RESULT_DROPPED_ITERATIONS=""
  RESULT_BUFFERING_REQUIRED_REQUESTS=""
  RESULT_FAILURE_ATTRIBUTION=""
  RESULT_P50_REQUEST_LATENCY_SECONDS=""
  RESULT_P95_REQUEST_LATENCY_SECONDS=""
  RESULT_P99_REQUEST_LATENCY_SECONDS=""
  RESULT_REQUESTS_PER_SECOND=""
  RESULT_GENERATED_TOKENS=""
  RESULT_GENERATION_TOKENS_PER_SECOND=""
  RESULT_RUN_DURATION_SECONDS=""

  while IFS= read -r line; do
    case "${line}" in
      GPU_LAB_K6_SUMMARY_BEGIN)
        in_summary=1
        continue
        ;;
      GPU_LAB_K6_SUMMARY_END)
        in_summary=0
        continue
        ;;
    esac

    if [[ "${in_summary}" != "1" || "${line}" != *=* ]]; then
      continue
    fi

    key=${line%%=*}
    value=${line#*=}
    case "${key}" in
      completed_requests)
        RESULT_COMPLETED_REQUESTS=${value}
        ;;
      failed_requests)
        RESULT_FAILED_REQUESTS=${value}
        ;;
      generated_tokens)
        RESULT_GENERATED_TOKENS=${value}
        ;;
      dropped_iterations)
        RESULT_DROPPED_ITERATIONS=${value}
        ;;
      buffering_required_requests)
        RESULT_BUFFERING_REQUIRED_REQUESTS=${value}
        ;;
      p50_request_latency_seconds)
        RESULT_P50_REQUEST_LATENCY_SECONDS=${value}
        ;;
      p95_request_latency_seconds)
        RESULT_P95_REQUEST_LATENCY_SECONDS=${value}
        ;;
      p99_request_latency_seconds)
        RESULT_P99_REQUEST_LATENCY_SECONDS=${value}
        ;;
      requests_per_second)
        RESULT_REQUESTS_PER_SECOND=${value}
        ;;
      generation_tokens_per_second)
        RESULT_GENERATION_TOKENS_PER_SECOND=${value}
        ;;
      run_duration_seconds)
        RESULT_RUN_DURATION_SECONDS=${value}
        ;;
    esac
  done < "${log_path}"

  if [[ -n "${RESULT_DROPPED_ITERATIONS}" ]] && awk -v value="${RESULT_DROPPED_ITERATIONS}" 'BEGIN { exit !((value + 0) > 0) }'; then
    RESULT_FAILURE_ATTRIBUTION="client_queue_limit"
  elif [[ -n "${RESULT_FAILED_REQUESTS}" ]] && awk -v value="${RESULT_FAILED_REQUESTS}" 'BEGIN { exit !((value + 0) > 0) }'; then
    RESULT_FAILURE_ATTRIBUTION="serving_or_provisioning"
  elif [[ -n "${RESULT_COMPLETED_REQUESTS}" ]]; then
    RESULT_FAILURE_ATTRIBUTION="none"
  fi
}

parse_stream_summary_log() {
  local log_path=$1
  local in_summary=0
  local key
  local value

  RESULT_COMPLETED_REQUESTS=""
  RESULT_SUCCESSFUL_REQUESTS=""
  RESULT_FAILED_REQUESTS=""
  RESULT_P50_REQUEST_LATENCY_SECONDS=""
  RESULT_P95_REQUEST_LATENCY_SECONDS=""
  RESULT_P99_REQUEST_LATENCY_SECONDS=""
  RESULT_P50_TTFT_SECONDS=""
  RESULT_P95_TTFT_SECONDS=""
  RESULT_P50_INTER_TOKEN_LATENCY_SECONDS=""
  RESULT_P95_INTER_TOKEN_LATENCY_SECONDS=""
  RESULT_GENERATION_TOKENS_PER_SECOND=""
  RESULT_RUN_DURATION_SECONDS=""

  while IFS= read -r line; do
    case "${line}" in
      GPU_LAB_STREAM_SUMMARY_BEGIN)
        in_summary=1
        continue
        ;;
      GPU_LAB_STREAM_SUMMARY_END)
        in_summary=0
        continue
        ;;
    esac

    if [[ "${in_summary}" != "1" || "${line}" != *=* ]]; then
      continue
    fi

    key=${line%%=*}
    value=${line#*=}
    case "${key}" in
      completed_requests)
        RESULT_COMPLETED_REQUESTS=${value}
        ;;
      failed_requests)
        RESULT_FAILED_REQUESTS=${value}
        ;;
      p50_request_latency_seconds)
        RESULT_P50_REQUEST_LATENCY_SECONDS=${value}
        ;;
      p95_request_latency_seconds)
        RESULT_P95_REQUEST_LATENCY_SECONDS=${value}
        ;;
      p99_request_latency_seconds)
        RESULT_P99_REQUEST_LATENCY_SECONDS=${value}
        ;;
      p50_ttft_seconds)
        RESULT_P50_TTFT_SECONDS=${value}
        ;;
      p95_ttft_seconds)
        RESULT_P95_TTFT_SECONDS=${value}
        ;;
      p50_inter_token_latency_seconds)
        RESULT_P50_INTER_TOKEN_LATENCY_SECONDS=${value}
        ;;
      p95_inter_token_latency_seconds)
        RESULT_P95_INTER_TOKEN_LATENCY_SECONDS=${value}
        ;;
      generation_tokens_per_second)
        RESULT_GENERATION_TOKENS_PER_SECOND=${value}
        ;;
      run_duration_seconds)
        RESULT_RUN_DURATION_SECONDS=${value}
        ;;
    esac
  done < "${log_path}"
}

derive_successful_requests() {
  if [[ -z "${RESULT_COMPLETED_REQUESTS:-}" ]]; then
    RESULT_SUCCESSFUL_REQUESTS=""
    return 0
  fi

  awk \
    -v completed="${RESULT_COMPLETED_REQUESTS}" \
    -v failed="${RESULT_FAILED_REQUESTS:-0}" '
      BEGIN {
        successful = (completed + 0) - (failed + 0)
        if (successful < 0) {
          successful = 0
        }
        printf "%.0f\n", successful
      }'
}

derive_slo_passed() {
  local evaluated=0
  local failed=0

  RESULT_SLO_PASSED=""

  if [[ -n "${COST_SLO_P95_REQUEST_LATENCY_SECONDS:-}" && -n "${RESULT_P95_REQUEST_LATENCY_SECONDS:-}" ]]; then
    evaluated=1
    if ! awk -v actual="${RESULT_P95_REQUEST_LATENCY_SECONDS}" -v target="${COST_SLO_P95_REQUEST_LATENCY_SECONDS}" 'BEGIN { exit !((actual + 0) <= (target + 0)) }'; then
      failed=1
    fi
  fi

  if [[ -n "${COST_SLO_P99_REQUEST_LATENCY_SECONDS:-}" && -n "${RESULT_P99_REQUEST_LATENCY_SECONDS:-}" ]]; then
    evaluated=1
    if ! awk -v actual="${RESULT_P99_REQUEST_LATENCY_SECONDS}" -v target="${COST_SLO_P99_REQUEST_LATENCY_SECONDS}" 'BEGIN { exit !((actual + 0) <= (target + 0)) }'; then
      failed=1
    fi
  fi

  if [[ "${evaluated}" == "0" ]]; then
    return 0
  fi

  if [[ "${failed}" == "1" ]]; then
    RESULT_SLO_PASSED="false"
  else
    RESULT_SLO_PASSED="true"
  fi
}

derive_cost_metrics() {
  local experiment_name=$1
  local profile_id=$2
  local duration_seconds

  load_cost_profile "${experiment_name}" "${profile_id}"

  RESULT_SUCCESSFUL_REQUESTS=$(derive_successful_requests)
  RESULT_ESTIMATED_BURST_COST_USD=""
  RESULT_COST_PER_1000_SUCCESSFUL_REQUESTS_USD=""
  RESULT_COST_PER_1M_GENERATED_TOKENS_USD=""
  RESULT_SLO_PASSED=""

  if [[ -z "${RESULT_RUN_DURATION_SECONDS:-}" && -n "${CASE_ID:-}" ]]; then
    RESULT_RUN_DURATION_SECONDS=$(case_planned_duration_seconds)
  fi

  duration_seconds=${RESULT_RUN_DURATION_SECONDS:-}
  if [[ -n "${COST_SERVING_HOURLY_COST_USD:-}" && -n "${duration_seconds}" ]]; then
    RESULT_ESTIMATED_BURST_COST_USD=$(awk \
      -v hourly="${COST_SERVING_HOURLY_COST_USD}" \
      -v duration="${duration_seconds}" \
      'BEGIN { printf "%.6f\n", ((hourly + 0) * (duration + 0)) / 3600 }')
  fi

  if [[ -n "${RESULT_ESTIMATED_BURST_COST_USD}" && -n "${RESULT_SUCCESSFUL_REQUESTS}" ]]; then
    RESULT_COST_PER_1000_SUCCESSFUL_REQUESTS_USD=$(divide_decimal_values \
      "$(multiply_decimal_values "${RESULT_ESTIMATED_BURST_COST_USD}" "1000" 6)" \
      "${RESULT_SUCCESSFUL_REQUESTS}" \
      6)
  fi

  if [[ -n "${RESULT_ESTIMATED_BURST_COST_USD}" && -n "${RESULT_GENERATED_TOKENS:-}" ]]; then
    RESULT_COST_PER_1M_GENERATED_TOKENS_USD=$(divide_decimal_values \
      "$(multiply_decimal_values "${RESULT_ESTIMATED_BURST_COST_USD}" "1000000" 6)" \
      "${RESULT_GENERATED_TOKENS}" \
      6)
  fi

  derive_slo_passed
}

detect_vllm_oom_events() {
  local reasons
  local count

  reasons=$(kubectl get pods \
    -n "${APP_NAMESPACE}" \
    -l "app=${GPU_INFERENCE_DEPLOYMENT_NAME}" \
    -o jsonpath='{range .items[*]}{range .status.containerStatuses[*]}{.state.terminated.reason}{"\n"}{.lastState.terminated.reason}{"\n"}{end}{end}' 2>/dev/null || true)

  if [[ -z "${reasons}" ]]; then
    return 0
  fi

  count=$(printf '%s\n' "${reasons}" | awk '$0 == "OOMKilled" { count++ } END { print count + 0 }')
  RESULT_OOM_EVENTS=${count}
}

run_experiment_case() {
  local experiment_name=$1
  local case_id=$2
  local profile_id=$3
  local report_path=$4
  local json_report_path=$5
  local preserve_serving=$6
  local preserve_load=$7
  local serving_manifest
  local load_manifest
  local k6_log_path
  local job_name
  local generated_at
  local job_status

  require_commands kubectl
  require_experiment "${experiment_name}"
  load_case "${experiment_name}" "${case_id}"
  load_serving_profile "${experiment_name}" "${profile_id}"
  validate_case_profile_compatibility "${experiment_name}"

  generated_at=$(utc_timestamp)
  job_name=$(experiment_job_name "${experiment_name}" "${CASE_ID}")
  serving_manifest=$(mktemp "${TMPDIR:-/tmp}/gpu-lab-experiment-serving.XXXXXX")
  load_manifest=$(mktemp "${TMPDIR:-/tmp}/gpu-lab-experiment-load.XXXXXX")
  k6_log_path="${json_report_path%.json}.k6.log"

  render_serving_manifest "${experiment_name}" "${profile_id}" > "${serving_manifest}"
  render_load_manifest "${experiment_name}" "${case_id}" > "${load_manifest}"

  printf 'Applying service manifest: %s\n' "${GPU_INFERENCE_SERVICE_MANIFEST}"
  kubectl apply -f "${GPU_INFERENCE_SERVICE_MANIFEST}"

  printf 'Applying serving profile %s/%s\n' "${experiment_name}" "${profile_id}"
  kubectl apply -f "${serving_manifest}"
  kubectl rollout status "deployment/${GPU_INFERENCE_DEPLOYMENT_NAME}" -n "${APP_NAMESPACE}" --timeout=20m

  printf 'Applying load case %s/%s\n' "${experiment_name}" "${CASE_ID}"
  kubectl apply -f "${load_manifest}"

  set +e
  wait_for_job_completion "${APP_NAMESPACE}" "${job_name}" "${EVALUATE_LOAD_TIMEOUT_SECONDS}"
  job_status=$?
  set -e

  mkdir -p "$(dirname "${k6_log_path}")"
  kubectl logs -n "${APP_NAMESPACE}" "job/${job_name}" > "${k6_log_path}" 2>/dev/null || true
  if [[ -s "${k6_log_path}" ]]; then
    parse_k6_summary_log "${k6_log_path}"
  fi
  detect_vllm_oom_events
  derive_cost_metrics "${experiment_name}" "${PROFILE_ID}"

  if [[ "${job_status}" == "0" ]]; then
    RUN_STATUS="complete"
  else
    RUN_STATUS="failed"
  fi
  RUN_SOURCE="scripts/experiment run"

  write_report_files "${experiment_name}" "${CASE_ID}" "${PROFILE_ID}" "${report_path}" "${json_report_path}" "${generated_at}"

  if [[ "${preserve_load}" != "1" ]]; then
    kubectl delete -f "${load_manifest}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi

  if [[ "${preserve_serving}" != "1" ]]; then
    kubectl delete -f "${serving_manifest}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi

  rm -f "${serving_manifest}" "${load_manifest}" || true

  printf 'Experiment run status: %s\n' "${RUN_STATUS}"
  printf 'K6 log: %s\n' "${k6_log_path}"
  printf 'Markdown report: %s\n' "${report_path}"
  printf 'JSON report: %s\n' "${json_report_path}"

  return "${job_status}"
}

run_stream_case() {
  local experiment_name=$1
  local case_id=$2
  local profile_id=$3
  local samples=$4
  local report_path=$5
  local json_report_path=$6
  local preserve_serving=$7
  local preserve_load=$8
  local serving_manifest
  local stream_manifest
  local stream_log_path
  local job_name
  local generated_at
  local job_status

  require_commands kubectl
  require_experiment "${experiment_name}"
  load_case "${experiment_name}" "${case_id}"
  load_serving_profile "${experiment_name}" "${profile_id}"
  require_positive_integer "${samples}" "stream samples"
  validate_case_profile_compatibility "${experiment_name}"

  generated_at=$(utc_timestamp)
  job_name=$(stream_job_name "${experiment_name}" "${CASE_ID}")
  serving_manifest=$(mktemp "${TMPDIR:-/tmp}/gpu-lab-experiment-serving.XXXXXX")
  stream_manifest=$(mktemp "${TMPDIR:-/tmp}/gpu-lab-experiment-stream.XXXXXX")
  stream_log_path="${json_report_path%.json}.stream.log"

  render_serving_manifest "${experiment_name}" "${profile_id}" > "${serving_manifest}"
  render_stream_manifest "${experiment_name}" "${case_id}" "${samples}" > "${stream_manifest}"

  printf 'Applying service manifest: %s\n' "${GPU_INFERENCE_SERVICE_MANIFEST}"
  kubectl apply -f "${GPU_INFERENCE_SERVICE_MANIFEST}"

  printf 'Applying serving profile %s/%s\n' "${experiment_name}" "${profile_id}"
  kubectl apply -f "${serving_manifest}"
  kubectl rollout status "deployment/${GPU_INFERENCE_DEPLOYMENT_NAME}" -n "${APP_NAMESPACE}" --timeout=20m

  printf 'Applying streaming case %s/%s with %s sample(s)\n' "${experiment_name}" "${CASE_ID}" "${samples}"
  kubectl apply -f "${stream_manifest}"

  set +e
  wait_for_job_completion "${APP_NAMESPACE}" "${job_name}" "${EVALUATE_LOAD_TIMEOUT_SECONDS}"
  job_status=$?
  set -e

  mkdir -p "$(dirname "${stream_log_path}")"
  kubectl logs -n "${APP_NAMESPACE}" "job/${job_name}" > "${stream_log_path}" 2>/dev/null || true
  if [[ -s "${stream_log_path}" ]]; then
    parse_stream_summary_log "${stream_log_path}"
  fi
  detect_vllm_oom_events
  derive_cost_metrics "${experiment_name}" "${PROFILE_ID}"

  if [[ "${job_status}" == "0" ]]; then
    RUN_STATUS="complete"
  else
    RUN_STATUS="failed"
  fi
  RUN_SOURCE="scripts/experiment run-stream"

  write_report_files "${experiment_name}" "${CASE_ID}" "${PROFILE_ID}" "${report_path}" "${json_report_path}" "${generated_at}"

  if [[ "${preserve_load}" != "1" ]]; then
    kubectl delete -f "${stream_manifest}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi

  if [[ "${preserve_serving}" != "1" ]]; then
    kubectl delete -f "${serving_manifest}" --ignore-not-found=true >/dev/null 2>&1 || true
  fi

  rm -f "${serving_manifest}" "${stream_manifest}" || true

  printf 'Streaming experiment run status: %s\n' "${RUN_STATUS}"
  printf 'Stream log: %s\n' "${stream_log_path}"
  printf 'Markdown report: %s\n' "${report_path}"
  printf 'JSON report: %s\n' "${json_report_path}"

  return "${job_status}"
}

render_load_command() {
  local experiment_name=""
  local case_id=""
  local output_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --experiment)
        experiment_name=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --case)
        case_id=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --output)
        output_path=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unexpected argument: $1"
        ;;
    esac
  done

  if [[ -z "${experiment_name}" ]]; then
    die "render-load requires --experiment"
  fi

  if [[ -z "${case_id}" ]]; then
    die "render-load requires --case"
  fi

  if [[ -n "${output_path}" ]]; then
    render_load_manifest "${experiment_name}" "${case_id}" > "${output_path}"
    printf 'Rendered load manifest: %s\n' "${output_path}"
  else
    render_load_manifest "${experiment_name}" "${case_id}"
  fi
}

render_stream_command() {
  local experiment_name=""
  local case_id=""
  local samples=5
  local output_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --experiment)
        experiment_name=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --case)
        case_id=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --samples)
        samples=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --output)
        output_path=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unexpected argument: $1"
        ;;
    esac
  done

  if [[ -z "${experiment_name}" ]]; then
    die "render-stream requires --experiment"
  fi

  if [[ -z "${case_id}" ]]; then
    die "render-stream requires --case"
  fi

  require_positive_integer "${samples}" "stream samples"

  if [[ -n "${output_path}" ]]; then
    render_stream_manifest "${experiment_name}" "${case_id}" "${samples}" > "${output_path}"
    printf 'Rendered stream manifest: %s\n' "${output_path}"
  else
    render_stream_manifest "${experiment_name}" "${case_id}" "${samples}"
  fi
}

render_report_command() {
  local experiment_name=""
  local case_id=""
  local profile_id=""
  local report_path=""
  local json_report_path=""
  local timestamp
  local generated_at
  local report_prefix

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --experiment)
        experiment_name=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --case)
        case_id=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --profile)
        profile_id=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --report)
        report_path=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --json-report)
        json_report_path=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unexpected argument: $1"
        ;;
    esac
  done

  if [[ -z "${experiment_name}" ]]; then
    die "render-report requires --experiment"
  fi

  if [[ -z "${case_id}" ]]; then
    die "render-report requires --case"
  fi

  if [[ -z "${profile_id}" ]]; then
    die "render-report requires --profile"
  fi

  timestamp=$(date +%Y%m%d-%H%M%S)
  generated_at=$(utc_timestamp)

  if [[ -z "${report_path}" || -z "${json_report_path}" ]]; then
    report_prefix=$(default_report_prefix "${experiment_name}" "${case_id}" "${profile_id}" "${timestamp}")
    if [[ -z "${report_path}" ]]; then
      report_path="${report_prefix}.md"
    fi
    if [[ -z "${json_report_path}" ]]; then
      json_report_path="${report_prefix}.json"
    fi
  fi

  write_report_files "${experiment_name}" "${case_id}" "${profile_id}" "${report_path}" "${json_report_path}" "${generated_at}"
  printf 'Rendered Markdown report: %s\n' "${report_path}"
  printf 'Rendered JSON report: %s\n' "${json_report_path}"
}

validate_command() {
  if [[ $# -ne 0 ]]; then
    die "validate does not accept arguments"
  fi

  validate_experiment_catalog
}

run_command() {
  local experiment_name=""
  local case_id=""
  local profile_id=""
  local report_path=""
  local json_report_path=""
  local preserve_serving=0
  local preserve_load=0
  local timestamp
  local report_prefix

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --experiment)
        experiment_name=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --case)
        case_id=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --profile)
        profile_id=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --report)
        report_path=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --json-report)
        json_report_path=$(require_option_value "$1" "${2-}")
        shift 2
        ;;
      --preserve-serving)
        preserve_serving=1
        shift
        ;;
      --preserve-load)
        preserve_load=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unexpected argument: $1"
        ;;
    esac
  done

  if [[ -z "${experiment_name}" ]]; then
    die "run requires --experiment"
  fi

  if [[ -z "${case_id}" ]]; then
    die "run requires --case"
  fi

  if [[ -z "${profile_id}" ]]; then
    die "run requires --profile"
  fi

  timestamp=$(date +%Y%m%d-%H%M%S)
  if [[ -z "${report_path}" || -z "${json_report_path}" ]]; then
    report_prefix=$(default_report_prefix "${experiment_name}" "${case_id}" "${profile_id}" "${timestamp}")
    if [[ -z "${report_path}" ]]; then
      report_path="${report_prefix}.md"
    fi
    if [[ -z "${json_report_path}" ]]; then
      json_report_path="${report_prefix}.json"
    fi
  fi

  run_experiment_case "${experiment_name}" "${case_id}" "${profile_id}" "${report_path}" "${json_report_path}" "${preserve_serving}" "${preserve_load}"
}

